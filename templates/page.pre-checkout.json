info-box\">\n    <strong>Why do I need to do this?<\/strong>\n    <p>\n      We offer doctor-reviewed wellness products, so a quick health check helps ensure everything is safe and suitable for you.\n    <\/p>\n    <p class=\"blx-note\">\n      If you are pregnant or have had a reaction to peptides, a doctor may need to review your information before approval.\n    <\/p>\n  <\/div>\n\n  {% if customer %}\n    {% if medical_check_complete %}\n      <div class=\"blx-actions\">\n        <a class=\"blx-btn blx-btn-primary\" href=\"\/cart\">Back to cart<\/a>\n        <a class=\"blx-btn blx-btn-secondary\" href=\"\/collections\/all\">Continue shopping<\/a>\n      <\/div>\n    {% else %}\n      <div class=\"blx-form-wrapper\">\n        <h3 class=\"blx-form-title\">Step 2 of 3: Quick Medical Check<\/h3>\n        <p class=\"blx-form-subtext\">\n          Takes under 60 seconds. Most customers are approved instantly.\n        <\/p>\n        <div class=\"upform-container\" data-id=\"a6e76e\"><\/div>\n      <\/div>\n\n      <div class=\"blx-actions\">\n        <a class=\"blx-btn blx-btn-secondary\" href=\"\/cart\">Back to cart<\/a>\n        <a class=\"blx-btn blx-btn-secondary\" href=\"\/collections\/all\">Continue shopping<\/a>\n      <\/div>\n    {% endif %}\n  {% else %}\n    <div class=\"blx-actions\">\n      <a class=\"blx-btn blx-btn-primary\" href=\"\/account\/login\">Sign in \/ Sign up<\/a>\n      <a class=\"blx-btn blx-btn-secondary\" href=\"\/cart\">Back to cart<\/a>\n    <\/div>\n  {% endif %}\n<\/div>\n\n<style>\n  .blx-checkout-wrapper {\n    max-width: 1200px;\n    margin: 32px auto;\n    padding: 0 20px;\n    font-family: inherit;\n  }\n\n  .blx-steps {\n    display: grid;\n    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;\n    gap: 14px;\n    align-items: stretch;\n    margin: 24px 0 28px;\n  }\n\n  .blx-step {\n    background: #fafafa;\n    border: 1px solid #ececec;\n    border-radius: 14px;\n    padding: 20px;\n    text-align: center;\n  }\n\n  .blx-step-number {\n    width: 36px;\n    height: 36px;\n    border-radius: 50%;\n    background: #b79d63;\n    color: #fff;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: 700;\n    margin-bottom: 12px;\n  }\n\n  .blx-step h3 {\n    margin: 0 0 8px;\n    font-size: 20px;\n    color: #1f1f1f;\n  }\n\n  .blx-step p {\n    margin: 0;\n    font-size: 15px;\n    line-height: 1.5;\n    color: #666;\n  }\n\n  .blx-step-arrow {\n    align-self: center;\n    font-size: 28px;\n    color: #b79d63;\n    font-weight: 700;\n  }\n\n  .blx-info-box {\n    background: #fffaf0;\n    border: 1px solid #eadfbf;\n    border-radius: 14px;\n    padding: 20px;\n    margin-bottom: 24px;\n  }\n\n  .blx-info-box strong {\n    display: block;\n    margin-bottom: 8px;\n    font-size: 18px;\n    color: #1f1f1f;\n  }\n\n  .blx-info-box p {\n    margin: 0 0 8px;\n    color: #4f4f4f;\n    line-height: 1.6;\n    font-size: 15px;\n  }\n\n  .blx-info-box .blx-note {\n    margin-top: 10px;\n    color: #7a6230;\n  }\n\n  .blx-form-wrapper {\n    margin: 24px 0;\n    padding: 24px;\n    border-radius: 14px;\n    border: 1px solid #e8e2d3;\n    background: #fff;\n  }\n\n  .blx-form-title {\n    margin: 0 0 8px;\n    font-size: 24px;\n    line-height: 1.3;\n    color: #1f1f1f;\n  }\n\n  .blx-form-subtext {\n    margin: 0 0 18px;\n    font-size: 16px;\n    line-height: 1.6;\n    color: #666;\n  }\n\n  .blx-actions {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 14px;\n  }\n\n  .blx-btn {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    min-height: 52px;\n    padding: 0 22px;\n    border-radius: 12px;\n    text-decoration: none;\n    font-weight: 600;\n    font-size: 17px;\n    transition: all 0.2s ease;\n  }\n\n  .blx-btn-primary {\n    background: #b79d63;\n    color: #fff;\n    border: 1px solid #b79d63;\n  }\n\n  .blx-btn-primary:hover {\n    background: #a78c52;\n    border-color: #a78c52;\n  }\n\n  .blx-btn-secondary {\n    background: #fff;\n    color: #9c8247;\n    border: 1px solid #d8cfbc;\n  }\n\n  .blx-btn-secondary:hover {\n    background: #faf7f0;\n  }\n\n  @media screen and (max-width: 990px) {\n    .blx-steps {\n      grid-template-columns: 1fr;\n    }\n\n    .blx-step-arrow {\n      display: none;\n    }\n  }\n\n  @media screen and (max-width: 640px) {\n    .blx-form-subtext {\n      font-size: 15px;\n    }\n\n    .blx-form-title {\n      font-size: 20px;\n    }\n\n    .blx-btn {\n      width: 100%;\n    }\n  }\n<\/style>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    let redirectStarted = false;\n\n    document.body.addEventListener(\"click\", function (event) {\n      const submitButton = event.target.closest(\".uf-submit-form\");\n\n      if (!submitButton || redirectStarted) return;\n\n      redirectStarted = true;\n\n      const formWrapper = document.querySelector(\".blx-form-wrapper\");\n      if (formWrapper) {\n        const notice = document.createElement(\"p\");\n        notice.style.marginTop = \"16px\";\n        notice.style.color = \"#7a6230\";\n        notice.style.fontSize = \"14px\";\n        notice.innerHTML = 'Submitting your Medical Check. You will be redirected in 5 seconds. If not redirected, <a href=\"\/cart\" style=\"text-decoration: underline; color: inherit;\">click here<\/a>.';\n        formWrapper.appendChild(notice);\n      }\n\n      setTimeout(function () {\n        window.location.replace(\"\/cart\");\n      }, 5000);\n    });\n  });\n<\/script>","text_alignment":"center"}},"1775945692275d6065":{"type":"apps","settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"remove_vertical_spacing":false,"remove_horizontal_spacing":false}},"1776121870e8b71098":{"type":"_blocks","blocks":{"ai_gen_block_1103b39_bJjy8c":{"type":"ai_gen_block_1103b39","settings":{"title":"How would you like to continue?","description":"Sign in to your account or continue as a guest","login_button_label":"