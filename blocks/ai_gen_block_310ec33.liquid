{% doc %}
  @prompt
    A toggle button that asks the user if the provided information is still the same. Below the toggle, there will be 2 buttons: one that says "Proceed to Checkout" if the toggle button is "Yes," and another that says "Update Medical Check." if customer is sign in if not show sign in and hide the toggle  and proceed to check out button, open sign in in new tap.  If customer already signed in hide sign in button, control section alignment. Add instruction above button that states user needs to sign in to be able to check out an d make sure that the Medical check form was submitted. check customer tags if there is red flag or green flag all to add ctom message for either. If there are no tags show message " Please submit the  medical check form.  According to the tags the red flag doesn't see proceed to check out button
    
    For update medical form I want to use <div class="upform-container" style="display: none !important;" data-id="a6e76e"></div>
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-checkout-gate-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.alignment }};
  }

  .ai-checkout-gate__instruction-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.instruction_font_size }}px;
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .ai-checkout-gate__message-{{ ai_gen_id }} {
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: {{ block.settings.message_font_size }}px;
    line-height: 1.5;
  }

  .ai-checkout-gate__message--green-{{ ai_gen_id }} {
    background-color: {{ block.settings.green_flag_bg }};
    color: {{ block.settings.green_flag_text }};
    border: 1px solid {{ block.settings.green_flag_border }};
  }

  .ai-checkout-gate__message--red-{{ ai_gen_id }} {
    background-color: {{ block.settings.red_flag_bg }};
    color: {{ block.settings.red_flag_text }};
    border: 1px solid {{ block.settings.red_flag_border }};
  }

  .ai-checkout-gate__message--no-tags-{{ ai_gen_id }} {
    background-color: {{ block.settings.no_tags_bg }};
    color: {{ block.settings.no_tags_text }};
    border: 1px solid {{ block.settings.no_tags_border }};
  }

  .ai-checkout-gate__toggle-wrapper-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-checkout-gate__toggle-label-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.alignment }};
    gap: 12px;
    cursor: pointer;
    font-size: {{ block.settings.toggle_font_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-checkout-gate__toggle-switch-{{ ai_gen_id }} {
    position: relative;
    width: 60px;
    height: 30px;
    background-color: {{ block.settings.toggle_off_color }};
    border-radius: 15px;
    transition: background-color 0.3s ease;
    flex-shrink: 0;
  }

  .ai-checkout-gate__toggle-switch-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    width: 24px;
    height: 24px;
    background-color: #ffffff;
    border-radius: 50%;
    transition: transform 0.3s ease;
  }

  .ai-checkout-gate__toggle-input-{{ ai_gen_id }}:checked + .ai-checkout-gate__toggle-switch-{{ ai_gen_id }} {
    background-color: {{ block.settings.toggle_on_color }};
  }

  .ai-checkout-gate__toggle-input-{{ ai_gen_id }}:checked + .ai-checkout-gate__toggle-switch-{{ ai_gen_id }}::after {
    transform: translateX(30px);
  }

  .ai-checkout-gate__toggle-input-{{ ai_gen_id }} {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .ai-checkout-gate__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: {{ block.settings.alignment }};
  }

  .ai-checkout-gate__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 0.3s ease;
    display: inline-block;
    text-align: center;
    min-width: 200px;
  }

  .ai-checkout-gate__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text }};
  }

  .ai-checkout-gate__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
    color: {{ block.settings.primary_button_hover_text }};
  }

  .ai-checkout-gate__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_text }};
  }

  .ai-checkout-gate__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
    color: {{ block.settings.secondary_button_hover_text }};
  }

  .ai-checkout-gate__hidden-{{ ai_gen_id }} {
    display: none !important;
  }

  @media screen and (max-width: 749px) {
    .ai-checkout-gate-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-checkout-gate__buttons-{{ ai_gen_id }} {
      align-items: stretch;
    }

    .ai-checkout-gate__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<checkout-gate-{{ ai_gen_id }}
  class="ai-checkout-gate-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-customer-logged-in="{% if customer %}true{% else %}false{% endif %}"
  data-customer-tags="{% if customer %}{{ customer.tags | join: ',' }}{% endif %}"
>
  {% if customer %}
    {% assign has_green_flag = false %}
    {% assign has_red_flag = false %}
    {% assign has_tags = false %}

    {% if customer.tags.size > 0 %}
      {% assign has_tags = true %}
      {% for tag in customer.tags %}
        {% assign tag_lower = tag | downcase %}
        {% if tag_lower contains 'green' and tag_lower contains 'flag' %}
          {% assign has_green_flag = true %}
        {% endif %}
        {% if tag_lower contains 'red' and tag_lower contains 'flag' %}
          {% assign has_red_flag = true %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% if has_green_flag %}
      <div class="ai-checkout-gate__message-{{ ai_gen_id }} ai-checkout-gate__message--green-{{ ai_gen_id }}">
        {{ block.settings.green_flag_message }}
      </div>
    {% elsif has_red_flag %}
      <div class="ai-checkout-gate__message-{{ ai_gen_id }} ai-checkout-gate__message--red-{{ ai_gen_id }}">
        {{ block.settings.red_flag_message }}
      </div>
    {% elsif has_tags == false %}
      <div class="ai-checkout-gate__message-{{ ai_gen_id }} ai-checkout-gate__message--no-tags-{{ ai_gen_id }}">
        {{ block.settings.no_tags_message }}
      </div>
    {% endif %}

    <div class="ai-checkout-gate__toggle-wrapper-{{ ai_gen_id }} {% if has_red_flag or has_tags == false %}ai-checkout-gate__hidden-{{ ai_gen_id }}{% endif %}" data-toggle-wrapper>
      <label class="ai-checkout-gate__toggle-label-{{ ai_gen_id }}">
        <span>{{ block.settings.toggle_question }}</span>
        <input
          type="checkbox"
          class="ai-checkout-gate__toggle-input-{{ ai_gen_id }}"
          data-toggle-input
        >
        <span class="ai-checkout-gate__toggle-switch-{{ ai_gen_id }}"></span>
      </label>
    </div>

    <div class="ai-checkout-gate__buttons-{{ ai_gen_id }}">
      <a
        href="/checkout"
        class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--primary-{{ ai_gen_id }} {% if has_red_flag or has_tags == false %}ai-checkout-gate__hidden-{{ ai_gen_id }}{% endif %}"
        data-checkout-button
      >
        {{ block.settings.checkout_button_text }}
      </a>

      <button
        type="button"
        class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--secondary-{{ ai_gen_id }}"
        data-update-button
      >
        {{ block.settings.update_button_text }}
      </button>
    </div>
  {% else %}
    <div class="ai-checkout-gate__instruction-{{ ai_gen_id }}">
      {{ block.settings.signin_instruction }}
    </div>

    <div class="ai-checkout-gate__buttons-{{ ai_gen_id }}">
      <a
        href="/account/login"
        target="_blank"
        class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--primary-{{ ai_gen_id }}"
      >
        {{ block.settings.signin_button_text }}
      </a>
    </div>
  {% endif %}

  <div class="upform-container" style="display: none !important;" data-id="a6e76e"></div>
</checkout-gate-{{ ai_gen_id }}>

<script>
  (function() {
    class CheckoutGate{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.toggleInput = this.querySelector('[data-toggle-input]');
        this.checkoutButton = this.querySelector('[data-checkout-button]');
        this.updateButton = this.querySelector('[data-update-button]');
        this.upformContainer = this.querySelector('.upform-container');
      }

      connectedCallback() {
        if (this.toggleInput && this.checkoutButton) {
          this.toggleInput.addEventListener('change', this.handleToggleChange.bind(this));
        }

        if (this.updateButton && this.upformContainer) {
          this.updateButton.addEventListener('click', this.handleUpdateClick.bind(this));
        }
      }

      handleToggleChange() {
        if (this.toggleInput.checked) {
          this.checkoutButton.textContent = '{{ block.settings.checkout_button_text }}';
        } else {
          this.checkoutButton.textContent = '{{ block.settings.update_button_text }}';
        }
      }

      handleUpdateClick() {
        if (this.upformContainer) {
          this.upformContainer.style.display = 'block';
          this.upformContainer.style.removeProperty('display');
        }
      }
    }

    customElements.define('checkout-gate-{{ ai_gen_id }}', CheckoutGate{{ ai_gen_id }});
  })();
</script>

