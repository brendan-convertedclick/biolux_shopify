{% doc %}
  @prompt
    As first stepAsk user to sign in or continue as quest checkout. If or after signing in show a check box asking if the medical form answer are still the same. By defualt it should be checked if user unchecks show the form. For guest users always show form. Use Shopify forms and form id is 882437
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-eligibility-gate-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-eligibility-gate__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-eligibility-gate__subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-eligibility-gate__auth-section-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
    margin-bottom: {{ block.settings.spacing }}px;
  }

  .ai-eligibility-gate__auth-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.spacing }}px;
    flex-wrap: wrap;
  }

  .ai-eligibility-gate__button-{{ ai_gen_id }} {
    flex: 1;
    min-width: 200px;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .ai-eligibility-gate__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-eligibility-gate__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_background }};
    color: {{ block.settings.secondary_button_text_color }};
    border-color: {{ block.settings.secondary_button_border_color }};
  }

  .ai-eligibility-gate__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_background }};
    color: {{ block.settings.secondary_button_hover_text_color }};
    border-color: {{ block.settings.secondary_button_hover_border_color }};
  }

  .ai-eligibility-gate__checkbox-section-{{ ai_gen_id }} {
    display: none;
    padding: {{ block.settings.spacing }}px;
    background-color: {{ block.settings.checkbox_section_background }};
    border-radius: {{ block.settings.border_radius }}px;
    margin-bottom: {{ block.settings.spacing }}px;
  }

  .ai-eligibility-gate__checkbox-section-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-eligibility-gate__checkbox-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    cursor: pointer;
  }

  .ai-eligibility-gate__checkbox-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    cursor: pointer;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .ai-eligibility-gate__checkbox-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.checkbox_label_size }}px;
    color: {{ block.settings.text_color }};
    cursor: pointer;
    user-select: none;
  }

  .ai-eligibility-gate__form-section-{{ ai_gen_id }} {
    display: none;
  }

  .ai-eligibility-gate__form-section-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-eligibility-gate__divider-{{ ai_gen_id }} {
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    margin: {{ block.settings.spacing }}px 0;
  }

  .ai-eligibility-gate__info-message-{{ ai_gen_id }} {
    padding: {{ block.settings.spacing }}px;
    background-color: {{ block.settings.info_background }};
    color: {{ block.settings.info_text_color }};
    border-radius: {{ block.settings.border_radius }}px;
    font-size: {{ block.settings.subtext_size }}px;
    margin-bottom: {{ block.settings.spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-eligibility-gate__auth-buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-eligibility-gate__button-{{ ai_gen_id }} {
      width: 100%;
      min-width: auto;
    }
  }
{% endstyle %}

<eligibility-gate-{{ ai_gen_id }}
  class="ai-eligibility-gate-{{ ai_gen_id }}"
  data-form-id="{{ block.settings.form_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-eligibility-gate__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.subtext != blank %}
    <div class="ai-eligibility-gate__subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
  {% endif %}

  {% if customer %}
    <div class="ai-eligibility-gate__info-message-{{ ai_gen_id }}">
      {{ block.settings.logged_in_message }}
    </div>

    <div class="ai-eligibility-gate__checkbox-section-{{ ai_gen_id }} active">
      <label class="ai-eligibility-gate__checkbox-wrapper-{{ ai_gen_id }}">
        <input
          type="checkbox"
          class="ai-eligibility-gate__checkbox-{{ ai_gen_id }}"
          id="ai-eligibility-checkbox-{{ ai_gen_id }}"
          checked
        >
        <span class="ai-eligibility-gate__checkbox-label-{{ ai_gen_id }}">
          {{ block.settings.checkbox_label }}
        </span>
      </label>
    </div>

    <div class="ai-eligibility-gate__form-section-{{ ai_gen_id }}">
      {% if block.settings.form_id != blank %}
        {% form 'contact', id: block.settings.form_id %}
          <input type="hidden" name="form_id" value="{{ block.settings.form_id }}">
          <input type="hidden" name="customer_id" value="{{ customer.id }}">
          <input type="hidden" name="customer_email" value="{{ customer.email }}">
          
          <div id="shopify-form-{{ block.settings.form_id }}"></div>
          
          {% if form.posted_successfully? %}
            <div class="ai-eligibility-gate__info-message-{{ ai_gen_id }}" style="background-color: {{ block.settings.success_background }}; color: {{ block.settings.success_text_color }};">
              {{ block.settings.success_message }}
            </div>
          {% endif %}
          
          {% if form.errors %}
            <div class="ai-eligibility-gate__info-message-{{ ai_gen_id }}" style="background-color: {{ block.settings.error_background }}; color: {{ block.settings.error_text_color }};">
              {{ block.settings.error_message }}
            </div>
          {% endif %}
        {% endform %}
      {% else %}
        <div class="ai-eligibility-gate__info-message-{{ ai_gen_id }}" style="background-color: {{ block.settings.error_background }}; color: {{ block.settings.error_text_color }};">
          Please configure the form ID in the block settings.
        </div>
      {% endif %}
    </div>
  {% else %}
    <div class="ai-eligibility-gate__auth-section-{{ ai_gen_id }}">
      {% if block.settings.guest_message != blank %}
        <div class="ai-eligibility-gate__info-message-{{ ai_gen_id }}">
          {{ block.settings.guest_message }}
        </div>
      {% endif %}

      <div class="ai-eligibility-gate__auth-buttons-{{ ai_gen_id }}">
        <a
          href="{{ routes.account_login_url }}?return_url={{ request.path }}"
          class="ai-eligibility-gate__button-{{ ai_gen_id }}"
        >
          {{ block.settings.sign_in_button_text }}
        </a>
        <button
          type="button"
          class="ai-eligibility-gate__button-{{ ai_gen_id }} ai-eligibility-gate__button--secondary-{{ ai_gen_id }}"
          id="ai-continue-guest-{{ ai_gen_id }}"
        >
          {{ block.settings.guest_button_text }}
        </button>
      </div>
    </div>

    <div class="ai-eligibility-gate__form-section-{{ ai_gen_id }}">
      {% if block.settings.form_id != blank %}
        {% form 'contact', id: block.settings.form_id %}
          <input type="hidden" name="form_id" value="{{ block.settings.form_id }}">
          <input type="hidden" name="guest_checkout" value="true">
          
          <div id="shopify-form-guest-{{ block.settings.form_id }}"></div>
          
          {% if form.posted_successfully? %}
            <div class="ai-eligibility-gate__info-message-{{ ai_gen_id }}" style="background-color: {{ block.settings.success_background }}; color: {{ block.settings.success_text_color }};">
              {{ block.settings.success_message }}
            </div>
          {% endif %}
          
          {% if form.errors %}
            <div class="ai-eligibility-gate__info-message-{{ ai_gen_id }}" style="background-color: {{ block.settings.error_background }}; color: {{ block.settings.error_text_color }};">
              {{ block.settings.error_message }}
            </div>
          {% endif %}
        {% endform %}
      {% else %}
        <div class="ai-eligibility-gate__info-message-{{ ai_gen_id }}" style="background-color: {{ block.settings.error_background }}; color: {{ block.settings.error_text_color }};">
          Please configure the form ID in the block settings.
        </div>
      {% endif %}
    </div>
  {% endif %}
</eligibility-gate-{{ ai_gen_id }}>

<script>
  (function() {
    class EligibilityGate{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.isCustomer = {{ customer | json }} !== null;
        this.formId = this.dataset.formId;
      }

      connectedCallback() {
        if (this.isCustomer) {
          this.setupCustomerFlow();
        } else {
          this.setupGuestFlow();
        }
        this.loadShopifyForm();
      }

      setupCustomerFlow() {
        const checkbox = this.querySelector('#ai-eligibility-checkbox-{{ ai_gen_id }}');
        const formSection = this.querySelector('.ai-eligibility-gate__form-section-{{ ai_gen_id }}');

        if (checkbox && formSection) {
          checkbox.addEventListener('change', () => {
            if (checkbox.checked) {
              formSection.classList.remove('active');
            } else {
              formSection.classList.add('active');
            }
          });
        }
      }

      setupGuestFlow() {
        const guestButton = this.querySelector('#ai-continue-guest-{{ ai_gen_id }}');
        const authSection = this.querySelector('.ai-eligibility-gate__auth-section-{{ ai_gen_id }}');
        const formSection = this.querySelector('.ai-eligibility-gate__form-section-{{ ai_gen_id }}');

        if (guestButton && authSection && formSection) {
          guestButton.addEventListener('click', () => {
            authSection.style.display = 'none';
            formSection.classList.add('active');
          });
        }
      }

      loadShopifyForm() {
        if (!this.formId) return;

        const script = document.createElement('script');
        script.src = 'https://cdn.shopify.com/shopifycloud/customer-forms/customer-forms.min.js';
        script.async = true;
        
        script.onload = () => {
          if (window.Shopify && window.Shopify.CustomerForm) {
            const targetId = this.isCustomer 
              ? `shopify-form-${this.formId}` 
              : `shopify-form-guest-${this.formId}`;
            
            const container = document.getElementById(targetId);
            if (container) {
              window.Shopify.CustomerForm.render(container, {
                formId: this.formId
              });
            }
          }
        };

        if (!document.querySelector('script[src*="customer-forms"]')) {
          document.head.appendChild(script);
        }
      }
    }

    customElements.define('eligibility-gate-{{ ai_gen_id }}', EligibilityGate{{ ai_gen_id }});
  })();
</script>

