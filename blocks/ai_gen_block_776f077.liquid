{% doc %}
  @prompt
    A toggle button that asks the user if the provided information is still the same. Below the toggle, there will be 22 buttons: one that says "Proceed to Checkout" if the toggle button is "Yes," and another that says "Update Medical Check." if customer is sign in if not show sign in and disable the toggle  and proceed to check out button, open sign in in new tap
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-medical-check-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-medical-check-toggle-section-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-medical-check-question-{{ ai_gen_id }} {
    font-size: {{ block.settings.question_font_size }}px;
    color: {{ block.settings.text_color }};
    margin-bottom: 16px;
    font-weight: 600;
  }

  .ai-medical-check-toggle-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-medical-check-toggle-{{ ai_gen_id }} {
    position: relative;
    display: inline-block;
    width: 60px;
    height: 32px;
  }

  .ai-medical-check-toggle-{{ ai_gen_id }} input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .ai-medical-check-slider-{{ ai_gen_id }} {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: {{ block.settings.toggle_off_color }};
    transition: 0.3s;
    border-radius: 32px;
  }

  .ai-medical-check-slider-{{ ai_gen_id }}:before {
    position: absolute;
    content: "";
    height: 24px;
    width: 24px;
    left: 4px;
    bottom: 4px;
    background-color: white;
    transition: 0.3s;
    border-radius: 50%;
  }

  .ai-medical-check-toggle-{{ ai_gen_id }} input:checked + .ai-medical-check-slider-{{ ai_gen_id }} {
    background-color: {{ block.settings.toggle_on_color }};
  }

  .ai-medical-check-toggle-{{ ai_gen_id }} input:checked + .ai-medical-check-slider-{{ ai_gen_id }}:before {
    transform: translateX(28px);
  }

  .ai-medical-check-toggle-{{ ai_gen_id }} input:disabled + .ai-medical-check-slider-{{ ai_gen_id }} {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-medical-check-toggle-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-medical-check-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-medical-check-button-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding }}px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .ai-medical-check-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-medical-check-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_color }};
    color: {{ block.settings.primary_button_text_color }};
  }

  .ai-medical-check-button-primary-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.primary_button_hover_color }};
  }

  .ai-medical-check-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_color }};
    color: {{ block.settings.secondary_button_text_color }};
  }

  .ai-medical-check-button-secondary-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.secondary_button_hover_color }};
  }

  .ai-medical-check-signin-message-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.message_background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    margin-bottom: 16px;
    text-align: center;
  }

  .ai-medical-check-signin-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    color: {{ block.settings.text_color }};
    margin-bottom: 12px;
  }

  @media screen and (max-width: 749px) {
    .ai-medical-check-container-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<medical-check-toggle-{{ ai_gen_id }}
  class="ai-medical-check-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if customer %}
    <div class="ai-medical-check-toggle-section-{{ ai_gen_id }}">
      <div class="ai-medical-check-question-{{ ai_gen_id }}">
        {{ block.settings.question_text }}
      </div>
      <div class="ai-medical-check-toggle-wrapper-{{ ai_gen_id }}">
        <label class="ai-medical-check-toggle-{{ ai_gen_id }}">
          <input
            type="checkbox"
            id="medical-info-toggle-{{ ai_gen_id }}"
            aria-label="{{ block.settings.question_text }}"
          >
          <span class="ai-medical-check-slider-{{ ai_gen_id }}"></span>
        </label>
        <span class="ai-medical-check-toggle-label-{{ ai_gen_id }}" id="toggle-label-{{ ai_gen_id }}">
          {{ block.settings.toggle_no_text }}
        </span>
      </div>
    </div>

    <div class="ai-medical-check-buttons-{{ ai_gen_id }}">
      <button
        type="button"
        class="ai-medical-check-button-{{ ai_gen_id }} ai-medical-check-button-primary-{{ ai_gen_id }}"
        id="proceed-checkout-{{ ai_gen_id }}"
        disabled
        onclick="window.location.href='/checkout'"
      >
        {{ block.settings.proceed_button_text }}
      </button>
      <a
        href="{{ block.settings.update_link }}"
        class="ai-medical-check-button-{{ ai_gen_id }} ai-medical-check-button-secondary-{{ ai_gen_id }}"
      >
        {{ block.settings.update_button_text }}
      </a>
    </div>
  {% else %}
    <div class="ai-medical-check-signin-message-{{ ai_gen_id }}">
      <div class="ai-medical-check-signin-text-{{ ai_gen_id }}">
        {{ block.settings.signin_message }}
      </div>
      <a
        href="/account/login"
        target="_blank"
        rel="noopener noreferrer"
        class="ai-medical-check-button-{{ ai_gen_id }} ai-medical-check-button-primary-{{ ai_gen_id }}"
      >
        {{ block.settings.signin_button_text }}
      </a>
    </div>

    <div class="ai-medical-check-toggle-section-{{ ai_gen_id }}">
      <div class="ai-medical-check-question-{{ ai_gen_id }}">
        {{ block.settings.question_text }}
      </div>
      <div class="ai-medical-check-toggle-wrapper-{{ ai_gen_id }}">
        <label class="ai-medical-check-toggle-{{ ai_gen_id }}">
          <input
            type="checkbox"
            id="medical-info-toggle-disabled-{{ ai_gen_id }}"
            disabled
            aria-label="{{ block.settings.question_text }}"
          >
          <span class="ai-medical-check-slider-{{ ai_gen_id }}"></span>
        </label>
        <span class="ai-medical-check-toggle-label-{{ ai_gen_id }}">
          {{ block.settings.toggle_no_text }}
        </span>
      </div>
    </div>

    <div class="ai-medical-check-buttons-{{ ai_gen_id }}">
      <button
        type="button"
        class="ai-medical-check-button-{{ ai_gen_id }} ai-medical-check-button-primary-{{ ai_gen_id }}"
        disabled
      >
        {{ block.settings.proceed_button_text }}
      </button>
      <button
        type="button"
        class="ai-medical-check-button-{{ ai_gen_id }} ai-medical-check-button-secondary-{{ ai_gen_id }}"
        disabled
      >
        {{ block.settings.update_button_text }}
      </button>
    </div>
  {% endif %}
</medical-check-toggle-{{ ai_gen_id }}>

<script>
  (function() {
    class MedicalCheckToggle{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.toggle = this.querySelector('#medical-info-toggle-{{ ai_gen_id }}');
        this.proceedButton = this.querySelector('#proceed-checkout-{{ ai_gen_id }}');
        this.toggleLabel = this.querySelector('#toggle-label-{{ ai_gen_id }}');

        if (this.toggle && this.proceedButton && this.toggleLabel) {
          this.setupEventListeners();
        }
      }

      setupEventListeners() {
        this.toggle.addEventListener('change', () => {
          if (this.toggle.checked) {
            this.toggleLabel.textContent = '{{ block.settings.toggle_yes_text }}';
            this.proceedButton.disabled = false;
          } else {
            this.toggleLabel.textContent = '{{ block.settings.toggle_no_text }}';
            this.proceedButton.disabled = true;
          }
        });
      }
    }

    customElements.define('medical-check-toggle-{{ ai_gen_id }}', MedicalCheckToggle{{ ai_gen_id }});
  })();
</script>

