{% doc %}
  @prompt
    @ columns one for text and the other for media, it should be video and the media should fill the whole column, select video from library not add link. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-media-text-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-media-text__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    min-height: 400px;
  }

  .ai-media-text__text-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px;
    background-color: {{ block.settings.text_background_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-media-text__heading-{{ ai_gen_id }} {
    margin: 0 0 20px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-media-text__content-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-media-text__media-column-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
    overflow: hidden;
  }

  .ai-media-text__video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-media-text__video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-media-text__video-placeholder-{{ ai_gen_id }} svg {
    width: 100px;
    height: 100px;
    opacity: 0.3;
  }

  .ai-media-text__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-media-text__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-media-text__text-column-{{ ai_gen_id }} {
      padding: 40px 20px;
      order: {% if block.settings.mobile_layout == 'media_first' %}2{% else %}1{% endif %};
    }

    .ai-media-text__media-column-{{ ai_gen_id }} {
      order: {% if block.settings.mobile_layout == 'media_first' %}1{% else %}2{% endif %};
    }
  }
{% endstyle %}

<media-text-block-{{ ai_gen_id }}
  class="ai-media-text-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-media-text__container-{{ ai_gen_id }}">
    <div class="ai-media-text__text-column-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-media-text__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.content != blank %}
        <div class="ai-media-text__content-{{ ai_gen_id }}">{{ block.settings.content }}</div>
      {% endif %}
    </div>

    <div class="ai-media-text__media-column-{{ ai_gen_id }}">
      {% if block.settings.video != blank %}
        {{
          block.settings.video
          | video_tag:
            image_size: '1100x',
            autoplay: block.settings.autoplay,
            loop: block.settings.loop,
            controls: block.settings.show_controls,
            muted: block.settings.muted,
            class: 'ai-media-text__video-' | append: ai_gen_id
        }}
      {% else %}
        <div class="ai-media-text__video-placeholder-{{ ai_gen_id }}">
          {{ 'collection-1' | placeholder_svg_tag }}
          <div class="ai-media-text__empty-state-{{ ai_gen_id }}">
            Next, add a video from your library
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</media-text-block-{{ ai_gen_id }}>

<script>
  (function() {
    class MediaTextBlock{{ai_gen_id}} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const video = this.querySelector('.ai-media-text__video-{{ ai_gen_id }}');
        if (video) {
          video.addEventListener('loadedmetadata', function() {
            video.play().catch(function() {
              console.log('Autoplay prevented');
            });
          });
        }
      }
    }

    customElements.define('media-text-block-{{ ai_gen_id }}', MediaTextBlock{{ai_gen_id}});
  })();
</script>

{% schema %}
{
  "name": "Media and text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Tell your story</p>"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1c1c1c"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Mute",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show controls",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "text_first",
          "label": "Text first"
        },
        {
          "value": "media_first",
          "label": "Media first"
        }
      ],
      "default": "media_first"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Media and text"
    }
  ]
}
{% endschema %}
