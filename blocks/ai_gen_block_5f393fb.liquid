{% doc %}
  @prompt
    A toggle button that asks the user if the provided information is still the same. Below the toggle, there will be 2 buttons: one that says "Proceed to Checkout" if the toggle button is "Yes," and another that says "Update Medical Check." if customer is sign in if not show sign in and hide the toggle  and proceed to check out button.  If customer already signed in hide sign in button, control section alignment. Add instruction above button that states user needs to sign in to be able to check out an d make sure that the Medical check form was submitted. check customer tags if there is red flag or green flag all to add ctom message for either. If there are no tags show message " Please submit the  medical check form.  According to the tags the red flag doesn't see proceed to check out button. By default the toogle should be on. Make sure checkout button chows fpr green flag customers.
    
    Instead of link for Update Medical Info please use this <div class="upform-container" style="display: none !important;" data-id="a6e76e"></div> or have a liquid block for me to add the code, add button size controls, make buttons smaller in width size.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-medical-checkout-gate-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.alignment }};
  }

  .ai-medical-checkout-gate__instruction-{{ ai_gen_id }} {
    font-size: {{ block.settings.instruction_font_size }}px;
    color: {{ block.settings.instruction_color }};
    margin-bottom: 20px;
  }

  .ai-medical-checkout-gate__message-{{ ai_gen_id }} {
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: {{ block.settings.message_font_size }}px;
  }

  .ai-medical-checkout-gate__message--success-{{ ai_gen_id }} {
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
  }

  .ai-medical-checkout-gate__message--error-{{ ai_gen_id }} {
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
  }

  .ai-medical-checkout-gate__message--warning-{{ ai_gen_id }} {
    background-color: {{ block.settings.warning_bg_color }};
    color: {{ block.settings.warning_text_color }};
  }

  .ai-medical-checkout-gate__toggle-wrapper-{{ ai_gen_id }} {
    margin-bottom: 24px;
    display: inline-block;
  }

  .ai-medical-checkout-gate__toggle-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.toggle_label_font_size }}px;
    color: {{ block.settings.text_color }};
    margin-bottom: 12px;
    display: block;
    font-weight: 600;
  }

  .ai-medical-checkout-gate__toggle-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: {{ block.settings.alignment }};
  }

  .ai-medical-checkout-gate__toggle-option-{{ ai_gen_id }} {
    padding: 10px 20px;
    border: 2px solid {{ block.settings.toggle_border_color }};
    border-radius: {{ block.settings.toggle_border_radius }}px;
    background-color: {{ block.settings.toggle_bg_color }};
    color: {{ block.settings.toggle_text_color }};
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: {{ block.settings.toggle_font_size }}px;
  }

  .ai-medical-checkout-gate__toggle-option-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.toggle_hover_bg_color }};
  }

  .ai-medical-checkout-gate__toggle-option-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.toggle_active_bg_color }};
    color: {{ block.settings.toggle_active_text_color }};
    border-color: {{ block.settings.toggle_active_border_color }};
  }

  .ai-medical-checkout-gate__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: {{ block.settings.alignment }};
    margin-top: 24px;
  }

  .ai-medical-checkout-gate__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    display: inline-block;
    transition: all 0.3s ease;
    width: {{ block.settings.button_width }}%;
    max-width: {{ block.settings.button_max_width }}px;
  }

  .ai-medical-checkout-gate__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg_color }};
    color: {{ block.settings.primary_button_text_color }};
  }

  .ai-medical-checkout-gate__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg_color }};
  }

  .ai-medical-checkout-gate__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_bg_color }};
    color: {{ block.settings.secondary_button_text_color }};
  }

  .ai-medical-checkout-gate__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_bg_color }};
  }

  .ai-medical-checkout-gate__hidden-{{ ai_gen_id }} {
    display: none !important;
  }

  .ai-medical-checkout-gate__form-container-{{ ai_gen_id }} {
    margin-top: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-medical-checkout-gate__buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-medical-checkout-gate__button-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-medical-checkout-gate__toggle-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<medical-checkout-gate-{{ ai_gen_id }}
  class="ai-medical-checkout-gate-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-customer-logged-in="{% if customer %}true{% else %}false{% endif %}"
  data-customer-tags="{% if customer %}{{ customer.tags | join: ',' }}{% endif %}"
>
  {% if customer %}
    {% assign has_green_flag = false %}
    {% assign has_red_flag = false %}
    {% assign has_any_flag = false %}

    {% for tag in customer.tags %}
      {% assign tag_lower = tag | downcase %}
      {% if tag_lower contains 'green' and tag_lower contains 'flag' %}
        {% assign has_green_flag = true %}
        {% assign has_any_flag = true %}
      {% elsif tag_lower contains 'red' and tag_lower contains 'flag' %}
        {% assign has_red_flag = true %}
        {% assign has_any_flag = true %}
      {% endif %}
    {% endfor %}

    {% if has_any_flag == false %}
      <div class="ai-medical-checkout-gate__message-{{ ai_gen_id }} ai-medical-checkout-gate__message--warning-{{ ai_gen_id }}">
        {{ block.settings.no_tags_message }}
      </div>
    {% elsif has_green_flag %}
      <div class="ai-medical-checkout-gate__message-{{ ai_gen_id }} ai-medical-checkout-gate__message--success-{{ ai_gen_id }}">
        {{ block.settings.green_flag_message }}
      </div>

      <div class="ai-medical-checkout-gate__toggle-wrapper-{{ ai_gen_id }}">
        <label class="ai-medical-checkout-gate__toggle-label-{{ ai_gen_id }}">
          {{ block.settings.toggle_label }}
        </label>
        <div class="ai-medical-checkout-gate__toggle-{{ ai_gen_id }}">
          <button
            type="button"
            class="ai-medical-checkout-gate__toggle-option-{{ ai_gen_id }} active"
            data-value="yes"
          >
            {{ block.settings.toggle_yes_text }}
          </button>
          <button
            type="button"
            class="ai-medical-checkout-gate__toggle-option-{{ ai_gen_id }}"
            data-value="no"
          >
            {{ block.settings.toggle_no_text }}
          </button>
        </div>
      </div>

      <div class="ai-medical-checkout-gate__buttons-{{ ai_gen_id }}">
        <a
          href="/checkout"
          class="ai-medical-checkout-gate__button-{{ ai_gen_id }} ai-medical-checkout-gate__button--primary-{{ ai_gen_id }}"
          data-checkout-button
        >
          {{ block.settings.checkout_button_text }}
        </a>
        <button
          type="button"
          class="ai-medical-checkout-gate__button-{{ ai_gen_id }} ai-medical-checkout-gate__button--secondary-{{ ai_gen_id }} ai-medical-checkout-gate__hidden-{{ ai_gen_id }}"
          data-update-button
        >
          {{ block.settings.update_button_text }}
        </button>
      </div>

      {% if block.settings.enable_custom_form_container %}
        <div
          class="ai-medical-checkout-gate__form-container-{{ ai_gen_id }} ai-medical-checkout-gate__hidden-{{ ai_gen_id }}"
          data-form-container
        >
          <div class="upform-container" style="display: none !important;" data-id="a6e76e"></div>
        </div>
      {% endif %}

    {% elsif has_red_flag %}
      <div class="ai-medical-checkout-gate__message-{{ ai_gen_id }} ai-medical-checkout-gate__message--error-{{ ai_gen_id }}">
        {{ block.settings.red_flag_message }}
      </div>

      <div class="ai-medical-checkout-gate__buttons-{{ ai_gen_id }}">
        <button
          type="button"
          class="ai-medical-checkout-gate__button-{{ ai_gen_id }} ai-medical-checkout-gate__button--secondary-{{ ai_gen_id }}"
          data-update-button-red-flag
        >
          {{ block.settings.update_button_text }}
        </button>
      </div>

      {% if block.settings.enable_custom_form_container %}
        <div
          class="ai-medical-checkout-gate__form-container-{{ ai_gen_id }}"
          data-form-container-red-flag
        >
          <div class="upform-container" style="display: none !important;" data-id="a6e76e"></div>
        </div>
      {% endif %}
    {% endif %}

  {% else %}
    <div class="ai-medical-checkout-gate__instruction-{{ ai_gen_id }}">
      {{ block.settings.signin_instruction }}
    </div>

    <div class="ai-medical-checkout-gate__buttons-{{ ai_gen_id }}">
      <a
        href="/account/login"
        class="ai-medical-checkout-gate__button-{{ ai_gen_id }} ai-medical-checkout-gate__button--primary-{{ ai_gen_id }}"
      >
        {{ block.settings.signin_button_text }}
      </a>
    </div>
  {% endif %}
</medical-checkout-gate-{{ ai_gen_id }}>

<script>
  (function() {
    class MedicalCheckoutGate{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.isCustomerLoggedIn = this.dataset.customerLoggedIn === 'true';
      }

      connectedCallback() {
        if (!this.isCustomerLoggedIn) return;

        this.toggleButtons = this.querySelectorAll('.ai-medical-checkout-gate__toggle-option-{{ ai_gen_id }}');
        this.checkoutButton = this.querySelector('[data-checkout-button]');
        this.updateButton = this.querySelector('[data-update-button]');
        this.updateButtonRedFlag = this.querySelector('[data-update-button-red-flag]');
        this.formContainer = this.querySelector('[data-form-container]');
        this.formContainerRedFlag = this.querySelector('[data-form-container-red-flag]');

        this.setupToggle();
        this.setupUpdateButtons();
      }

      setupToggle() {
        if (!this.toggleButtons.length) return;

        this.toggleButtons.forEach(button => {
          button.addEventListener('click', () => {
            this.toggleButtons.forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');

            const value = button.dataset.value;

            if (value === 'yes') {
              if (this.checkoutButton) {
                this.checkoutButton.classList.remove('ai-medical-checkout-gate__hidden-{{ ai_gen_id }}');
              }
              if (this.updateButton) {
                this.updateButton.classList.add('ai-medical-checkout-gate__hidden-{{ ai_gen_id }}');
              }
              if (this.formContainer) {
                this.formContainer.classList.add('ai-medical-checkout-gate__hidden-{{ ai_gen_id }}');
              }
            } else {
              if (this.checkoutButton) {
                this.checkoutButton.classList.add('ai-medical-checkout-gate__hidden-{{ ai_gen_id }}');
              }
              if (this.updateButton) {
                this.updateButton.classList.remove('ai-medical-checkout-gate__hidden-{{ ai_gen_id }}');
              }
              if (this.formContainer) {
                this.formContainer.classList.remove('ai-medical-checkout-gate__hidden-{{ ai_gen_id }}');
              }
            }
          });
        });
      }

      setupUpdateButtons() {
        if (this.updateButton) {
          this.updateButton.addEventListener('click', () => {
            if (this.formContainer) {
              const upformDiv = this.formContainer.querySelector('.upform-container');
              if (upformDiv) {
                upformDiv.style.display = 'block';
              }
            }
          });
        }

        if (this.updateButtonRedFlag) {
          this.updateButtonRedFlag.addEventListener('click', () => {
            if (this.formContainerRedFlag) {
              const upformDiv = this.formContainerRedFlag.querySelector('.upform-container');
              if (upformDiv) {
                upformDiv.style.display = 'block';
              }
            }
          });
        }
      }
    }

    customElements.define('medical-checkout-gate-{{ ai_gen_id }}', MedicalCheckoutGate{{ ai_gen_id }});
  })();
</script>

