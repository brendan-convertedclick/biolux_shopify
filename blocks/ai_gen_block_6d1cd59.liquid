{% doc %}
  @prompt
    @ columns one for text and the other for media, it should allow video and the media should fill the whole column, select video from library not add link, all media to be only video
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-media-text-columns-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-media-text-columns__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.column_gap }}px;
    {% if block.settings.layout == 'media_left' %}
      flex-direction: row;
    {% else %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-media-text-columns__text-column-{{ ai_gen_id }},
  .ai-media-text-columns__media-column-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-media-text-columns__media-column-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.media_border_radius }}px;
  }

  .ai-media-text-columns__media-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: {{ block.settings.min_height }}px;
  }

  .ai-media-text-columns__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-media-text-columns__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: {{ block.settings.min_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-media-text-columns__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-media-text-columns__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-media-text-columns__text-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.text_vertical_alignment }};
    padding: {{ block.settings.text_padding }}px;
    background-color: {{ block.settings.text_background_color }};
    border-radius: {{ block.settings.text_border_radius }}px;
  }

  .ai-media-text-columns__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
  }

  .ai-media-text-columns__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-media-text-columns__content-{{ ai_gen_id }} p {
    margin: 0 0 16px 0;
  }

  .ai-media-text-columns__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-media-text-columns__button-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.button_spacing }}px;
  }

  .ai-media-text-columns__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
  }

  .ai-media-text-columns__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-media-text-columns__container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-media-text-columns__media-wrapper-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_min_height }}px;
    }

    .ai-media-text-columns__placeholder-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_min_height }}px;
    }

    .ai-media-text-columns__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-media-text-columns__text-column-{{ ai_gen_id }} {
      padding: {{ block.settings.text_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<media-text-columns-{{ ai_gen_id }}
  class="ai-media-text-columns-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-media-text-columns__container-{{ ai_gen_id }}">
    <div class="ai-media-text-columns__media-column-{{ ai_gen_id }}">
      <div class="ai-media-text-columns__media-wrapper-{{ ai_gen_id }}">
        {% if block.settings.video != blank %}
          {{ block.settings.video | video_tag: 
            class: 'ai-media-text-columns__video-' | append: ai_gen_id,
            autoplay: block.settings.video_autoplay,
            loop: block.settings.video_loop,
            muted: block.settings.video_muted,
            controls: block.settings.video_controls
          }}
        {% else %}
          <div class="ai-media-text-columns__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-media-text-columns__empty-state-{{ ai_gen_id }}">
              Next, add a video
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-media-text-columns__text-column-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-media-text-columns__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.content != blank %}
        <div class="ai-media-text-columns__content-{{ ai_gen_id }}">
          {{ block.settings.content }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <div class="ai-media-text-columns__button-wrapper-{{ ai_gen_id }}">
          <a
            href="{{ block.settings.button_link }}"
            class="ai-media-text-columns__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</media-text-columns-{{ ai_gen_id }}>

<script>
  (function() {
    class MediaTextColumns{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('.ai-media-text-columns__video-{{ ai_gen_id }}');
        if (this.video && this.video.hasAttribute('autoplay')) {
          this.setupVideoObserver();
        }
      }

      setupVideoObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.5
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              this.video.play();
            } else {
              this.video.pause();
            }
          });
        }, options);

        observer.observe(this.video);
      }
    }

    customElements.define('media-text-columns-{{ ai_gen_id }}', MediaTextColumns{{ ai_gen_id }});
  })();
</script>

