      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "confirmation_bg_color",
      "label": "Confirmation background",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "color",
      "id": "primary_button_color",
      "label": "Background",
      "default": "#000f9f"
    },
    {
      "type": "color",
      "id": "primary_button_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "primary_button_hover_color",
      "label": "Hover background",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "color",
      "id": "secondary_button_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_button_text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "secondary_button_border_color",
      "label": "Border",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "secondary_button_hover_color",
