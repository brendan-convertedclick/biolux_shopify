      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading spacing",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "form_background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "form_text_color",
      "label": "Text color",
      "default": "#1c1c1c"
    },
    {
      "type": "range",
      "id": "form_padding",
      "label": "Padding (desktop)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_form_padding",
      "label": "Padding (mobile)",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "field_spacing",
      "label": "Field spacing",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Form fields"
    },
    {
      "type": "inline_richtext",
