      "default": "Name"
    },
    {
      "type": "text",
      "id": "name_placeholder",
      "label": "Name placeholder"
    },
    {
      "type": "checkbox",
      "id": "name_required",
      "label": "Name required",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "email_label",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder"
    },
    {
      "type": "checkbox",
      "id": "show_phone_field",
      "label": "Show phone field",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "phone_label",
      "label": "Phone label",
      "default": "Phone"
    },
    {
      "type": "text",
      "id": "phone_placeholder",
      "label": "Phone placeholder"
    },
    {
      "type": "checkbox",
      "id": "phone_required",
      "label": "Phone required",
      "default": false
