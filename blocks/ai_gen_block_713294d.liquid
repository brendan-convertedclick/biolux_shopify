{% doc %}
  @prompt
    Image with text blocks, i want to show 3 on the first row and 2 on the second all must be center aligned. , All blocks should be the same size and the second row blocks should be in the middle, 4 between 1-2 and 5 between 2-3, allow to conrtol image width. Image should fit and not cutoff.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-image-text-grid__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.row_gap }}px;
    align-items: center;
  }

  .ai-image-text-grid__row-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.column_gap }}px;
    justify-content: center;
    width: 100%;
  }

  .ai-image-text-grid__item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.item_width }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_gap }}px;
    align-items: center;
  }

  .ai-image-text-grid__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-text-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .ai-image-text-grid__placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-text-grid__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-image-text-grid__text-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-grid__row-{{ ai_gen_id }} {
      flex-wrap: wrap;
    }

    .ai-image-text-grid__item-{{ ai_gen_id }} {
      width: calc(50% - {{ block.settings.column_gap | divided_by: 2 }}px);
    }
  }
{% endstyle %}

<image-text-grid-{{ ai_gen_id }}
  class="ai-image-text-grid-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-text-grid__container-{{ ai_gen_id }}">
    <div class="ai-image-text-grid__row-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign text_key = 'text_' | append: i
          assign image = block.settings[image_key]
          assign text = block.settings[text_key]
        %}
        <div class="ai-image-text-grid__item-{{ ai_gen_id }}">
          <div class="ai-image-text-grid__image-wrapper-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-image-text-grid__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-image-text-grid__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          {% if text != blank %}
            <div class="ai-image-text-grid__text-{{ ai_gen_id }}">{{ text }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="ai-image-text-grid__row-{{ ai_gen_id }}">
      {% for i in (4..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign text_key = 'text_' | append: i
          assign image = block.settings[image_key]
          assign text = block.settings[text_key]
        %}
        <div class="ai-image-text-grid__item-{{ ai_gen_id }}">
          <div class="ai-image-text-grid__image-wrapper-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-image-text-grid__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-image-text-grid__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          {% if text != blank %}
            <div class="ai-image-text-grid__text-{{ ai_gen_id }}">{{ text }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</image-text-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageTextGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('image-text-grid-{{ ai_gen_id }}', ImageTextGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
