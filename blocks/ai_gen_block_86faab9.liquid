{% doc %}
  @prompt
    A toggle button that asks the user if the provided information is still the same. Below the toggle, there will be 22 buttons: one that says "Proceed to Checkout" if the toggle button is "Yes," and another that says "Update Medical Check." if customer is sign in if not show sign in and hide the toggle  and proceed to check out button, open sign in in new tap.  If customer already signed in hide sign in button, control section alignment. Add instruction above button that states user needs to sign in to be able to check out an d make sure that the Medical check form was submitted. check customer tags if there is red flag or green flag all to add ctom message for either. If there are no tags show message " Please submit the  medical check form.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-checkout-gate-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    margin: 0 auto;
  }

  .ai-checkout-gate__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.alignment }};
  }

  .ai-checkout-gate__instruction-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.instruction_font_size }}px;
    margin: 0;
  }

  .ai-checkout-gate__message-{{ ai_gen_id }} {
    padding: 16px;
    border-radius: 8px;
    font-size: {{ block.settings.message_font_size }}px;
    margin: 0;
  }

  .ai-checkout-gate__message--success-{{ ai_gen_id }} {
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
  }

  .ai-checkout-gate__message--warning-{{ ai_gen_id }} {
    background-color: {{ block.settings.warning_bg_color }};
    color: {{ block.settings.warning_text_color }};
  }

  .ai-checkout-gate__message--error-{{ ai_gen_id }} {
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
  }

  .ai-checkout-gate__toggle-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: {{ block.settings.alignment }};
  }

  .ai-checkout-gate__toggle-label-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.toggle_label_font_size }}px;
    font-weight: 600;
    margin: 0;
  }

  .ai-checkout-gate__toggle-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .ai-checkout-gate__toggle-button-{{ ai_gen_id }} {
    padding: 10px 24px;
    border: 2px solid {{ block.settings.toggle_border_color }};
    background-color: {{ block.settings.toggle_bg_color }};
    color: {{ block.settings.toggle_text_color }};
    border-radius: {{ block.settings.toggle_border_radius }}px;
    cursor: pointer;
    font-size: {{ block.settings.toggle_font_size }}px;
    transition: all 0.3s ease;
  }

  .ai-checkout-gate__toggle-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.toggle_hover_bg_color }};
  }

  .ai-checkout-gate__toggle-button-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.toggle_active_bg_color }};
    color: {{ block.settings.toggle_active_text_color }};
    border-color: {{ block.settings.toggle_active_border_color }};
  }

  .ai-checkout-gate__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 400px;
  }

  .ai-checkout-gate__button-{{ ai_gen_id }} {
    padding: 16px 32px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    transition: all 0.3s ease;
  }

  .ai-checkout-gate__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg_color }};
    color: {{ block.settings.primary_button_text_color }};
  }

  .ai-checkout-gate__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg_color }};
  }

  .ai-checkout-gate__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_bg_color }};
    color: {{ block.settings.secondary_button_text_color }};
  }

  .ai-checkout-gate__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_bg_color }};
  }

  .ai-checkout-gate__hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-checkout-gate-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-checkout-gate__buttons-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }
{% endstyle %}

<checkout-gate-{{ ai_gen_id }}
  class="ai-checkout-gate-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-green-flag-tag="{{ block.settings.green_flag_tag }}"
  data-red-flag-tag="{{ block.settings.red_flag_tag }}"
>
  <div class="ai-checkout-gate__content-{{ ai_gen_id }}">
    {% if customer %}
      {% assign has_green_flag = false %}
      {% assign has_red_flag = false %}
      {% assign has_any_flag = false %}

      {% for tag in customer.tags %}
        {% if tag == block.settings.green_flag_tag %}
          {% assign has_green_flag = true %}
          {% assign has_any_flag = true %}
        {% endif %}
        {% if tag == block.settings.red_flag_tag %}
          {% assign has_red_flag = true %}
          {% assign has_any_flag = true %}
        {% endif %}
      {% endfor %}

      {% if has_any_flag == false %}
        <div class="ai-checkout-gate__message-{{ ai_gen_id }} ai-checkout-gate__message--error-{{ ai_gen_id }}">
          {{ block.settings.no_tag_message }}
        </div>
      {% elsif has_green_flag %}
        <div class="ai-checkout-gate__message-{{ ai_gen_id }} ai-checkout-gate__message--success-{{ ai_gen_id }}">
          {{ block.settings.green_flag_message }}
        </div>
      {% elsif has_red_flag %}
        <div class="ai-checkout-gate__message-{{ ai_gen_id }} ai-checkout-gate__message--warning-{{ ai_gen_id }}">
          {{ block.settings.red_flag_message }}
        </div>
      {% endif %}

      {% if has_green_flag %}
        <div class="ai-checkout-gate__toggle-wrapper-{{ ai_gen_id }}">
          <p class="ai-checkout-gate__toggle-label-{{ ai_gen_id }}">{{ block.settings.toggle_question }}</p>
          <div class="ai-checkout-gate__toggle-{{ ai_gen_id }}">
            <button
              type="button"
              class="ai-checkout-gate__toggle-button-{{ ai_gen_id }} active"
              data-toggle-value="yes"
            >
              {{ block.settings.toggle_yes_label }}
            </button>
            <button
              type="button"
              class="ai-checkout-gate__toggle-button-{{ ai_gen_id }}"
              data-toggle-value="no"
            >
              {{ block.settings.toggle_no_label }}
            </button>
          </div>
        </div>

        <div class="ai-checkout-gate__buttons-{{ ai_gen_id }}">
          <a
            href="/checkout"
            class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--primary-{{ ai_gen_id }}"
            data-checkout-button
          >
            {{ block.settings.proceed_button_label }}
          </a>
          <a
            href="{{ block.settings.update_form_url }}"
            class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--secondary-{{ ai_gen_id }} ai-checkout-gate__hidden-{{ ai_gen_id }}"
            data-update-button
          >
            {{ block.settings.update_button_label }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <p class="ai-checkout-gate__instruction-{{ ai_gen_id }}">
        {{ block.settings.signin_instruction }}
      </p>
      <div class="ai-checkout-gate__buttons-{{ ai_gen_id }}">
        <a
          href="/account/login"
          target="_blank"
          class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--primary-{{ ai_gen_id }}"
        >
          {{ block.settings.signin_button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</checkout-gate-{{ ai_gen_id }}>

<script>
  (function() {
    class CheckoutGate{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.toggleButtons = this.querySelectorAll('[data-toggle-value]');
        this.checkoutButton = this.querySelector('[data-checkout-button]');
        this.updateButton = this.querySelector('[data-update-button]');
        this.selectedToggle = 'yes';

        this.setupEventListeners();
      }

      setupEventListeners() {
        if (!this.toggleButtons.length) return;

        this.toggleButtons.forEach((button) => {
          button.addEventListener('click', () => {
            this.toggleButtons.forEach((btn) => btn.classList.remove('active'));
            button.classList.add('active');
            this.selectedToggle = button.dataset.toggleValue;
            this.updateButtonVisibility();
          });
        });
      }

      updateButtonVisibility() {
        if (!this.checkoutButton || !this.updateButton) return;

        if (this.selectedToggle === 'yes') {
          this.checkoutButton.classList.remove('ai-checkout-gate__hidden-{{ ai_gen_id }}');
          this.updateButton.classList.add('ai-checkout-gate__hidden-{{ ai_gen_id }}');
        } else {
          this.checkoutButton.classList.add('ai-checkout-gate__hidden-{{ ai_gen_id }}');
          this.updateButton.classList.remove('ai-checkout-gate__hidden-{{ ai_gen_id }}');
        }
      }
    }

    customElements.define('checkout-gate-{{ ai_gen_id }}', CheckoutGate{{ ai_gen_id }});
  })();
</script>

