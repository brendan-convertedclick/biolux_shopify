{% doc %}
  @prompt
    @ columns one for text and the other for video,  media should fill the whole column, add button after text, allow button size control
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-video-columns-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-text-video-columns__wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-text-video-columns__text-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: {{ block.settings.text_padding }}px;
    background-color: {{ block.settings.text_background_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-text-video-columns__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.spacing_between_elements }}px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-text-video-columns__content-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0 0 {{ block.settings.spacing_between_elements }}px 0;
  }

  .ai-text-video-columns__button-wrapper-{{ ai_gen_id }} {
    display: flex;
  }

  .ai-text-video-columns__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
    {% if block.settings.button_size == 'small' %}
      min-width: 120px;
    {% elsif block.settings.button_size == 'medium' %}
      min-width: 180px;
    {% elsif block.settings.button_size == 'large' %}
      min-width: 240px;
    {% elsif block.settings.button_size == 'full' %}
      width: 100%;
    {% endif %}
  }

  .ai-text-video-columns__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-text-video-columns__media-column-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: {{ block.settings.min_height }}px;
    overflow: hidden;
  }

  .ai-text-video-columns__video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-text-video-columns__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-text-video-columns__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-text-video-columns__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-text-video-columns__wrapper-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      width: 100%;
    }

    .ai-text-video-columns__text-column-{{ ai_gen_id }} {
      order: {{ block.settings.mobile_text_order }};
    }

    .ai-text-video-columns__media-column-{{ ai_gen_id }} {
      order: {{ block.settings.mobile_media_order }};
      min-height: {{ block.settings.mobile_min_height }}px;
    }
  }
{% endstyle %}

<text-video-columns-{{ ai_gen_id }}
  class="ai-text-video-columns-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-text-video-columns__wrapper-{{ ai_gen_id }}">
    <div class="ai-text-video-columns__text-column-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-text-video-columns__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-text-video-columns__content-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <div class="ai-text-video-columns__button-wrapper-{{ ai_gen_id }}">
          <a
            href="{{ block.settings.button_link }}"
            class="ai-text-video-columns__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    </div>

    <div class="ai-text-video-columns__media-column-{{ ai_gen_id }}">
      {% if block.settings.video != blank %}
        <video
          class="ai-text-video-columns__video-{{ ai_gen_id }}"
          {% if block.settings.autoplay %}autoplay{% endif %}
          {% if block.settings.loop %}loop{% endif %}
          {% if block.settings.muted %}muted{% endif %}
          {% if block.settings.controls %}controls{% endif %}
          playsinline
        >
          <source src="{{ block.settings.video }}" type="video/mp4">
        </video>
      {% else %}
        <div class="ai-text-video-columns__placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-text-video-columns__empty-state-{{ ai_gen_id }}">
            Next, add a video
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</text-video-columns-{{ ai_gen_id }}>

<script>
  (function() {
    class TextVideoColumns{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const video = this.querySelector('.ai-text-video-columns__video-{{ ai_gen_id }}');
        if (video) {
          video.addEventListener('loadedmetadata', () => {
            video.play().catch(() => {});
          });
        }
      }
    }

    customElements.define('text-video-columns-{{ ai_gen_id }}', TextVideoColumns{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Text and video columns",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Your heading here</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add your text content here. This column is perfect for describing your product, service, or sharing important information with your customers.</p>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Text padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing_between_elements",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Spacing between elements",
      "default": 20
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "full",
          "label": "Full width"
        }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Vertical padding",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 4
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Background color",
      "default": "#b29964"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background_color",
      "label": "Hover background color",
      "default": "#9a8355"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "url",
      "id": "video",
      "label": "Video URL"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Muted",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show controls",
      "default": false
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Minimum height (desktop)",
      "default": 500
    },
    {
      "type": "range",
      "id": "mobile_min_height",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "label": "Minimum height (mobile)",
      "default": 300
