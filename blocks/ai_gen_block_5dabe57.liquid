        {
          "value": "2",
          "label": "Bottom"
        }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "mobile_media_order",
      "label": "Mobile video position",
      "options": [
        {
          "value": "1",
          "label": "Top"
        },
        {
          "value": "2",
          "label": "Bottom"
        }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_background_color",
      "label": "Text background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1c1c1c"
    }
  ],
  "presets": [
    {
      "name": "Text and video columns"
    }
  ]
}
{% endschema %}
