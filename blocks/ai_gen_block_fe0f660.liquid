{% doc %}
  @prompt
    Image with text blocks, i want to show 3 on the first row and 2 on the second all must be center aligned. , All blocks should be the same size and the second row blocks should be in the middle, 4 between 1-2 and 5 between 2-3, allow to conrtol image width
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-grid-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-image-text-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    grid-column: span 2;
  }

  .ai-image-text-item-{{ ai_gen_id }}:nth-child(4) {
    grid-column: 2 / span 2;
  }

  .ai-image-text-item-{{ ai_gen_id }}:nth-child(5) {
    grid-column: 4 / span 2;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.image_width }}%;
    margin-bottom: {{ block.settings.image_text_spacing }}px;
    position: relative;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
    aspect-ratio: 1;
    object-fit: cover;
  }

  .ai-image-text-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-text-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-image-text-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_text_spacing }}px 0;
    font-weight: 600;
  }

  .ai-image-text-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-image-text-item-{{ ai_gen_id }},
    .ai-image-text-item-{{ ai_gen_id }}:nth-child(4),
    .ai-image-text-item-{{ ai_gen_id }}:nth-child(5) {
      grid-column: 1;
    }
  }
{% endstyle %}

<image-text-grid-{{ ai_gen_id }}
  class="ai-image-text-grid-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-text-container-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign title_key = 'title_' | append: i
        assign text_key = 'text_' | append: i
        
        assign item_image = block.settings[image_key]
        assign item_title = block.settings[title_key]
        assign item_text = block.settings[text_key]
      %}
      
      <div class="ai-image-text-item-{{ ai_gen_id }}">
        <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
          {% if item_image %}
            <img
              src="{{ item_image | image_url: width: 600 }}"
              alt="{{ item_image.alt | escape }}"
              loading="lazy"
              width="{{ item_image.width }}"
              height="{{ item_image.height }}"
            >
          {% else %}
            <div class="ai-image-text-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        
        <div class="ai-image-text-content-{{ ai_gen_id }}">
          {% if item_title != blank %}
            <h3 class="ai-image-text-title-{{ ai_gen_id }}">{{ item_title }}</h3>
          {% endif %}
          
          {% if item_text != blank %}
            <div class="ai-image-text-description-{{ ai_gen_id }}">{{ item_text }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</image-text-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageTextGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    
    customElements.define('image-text-grid-{{ ai_gen_id }}', ImageTextGrid{{ ai_gen_id }});
  })();
</script>

