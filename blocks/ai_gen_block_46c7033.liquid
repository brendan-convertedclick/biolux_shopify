{% doc %}
  @prompt
    Footer section that allows image backgrond and overlay. the sestion should have 4 colours one for logo, another for footer menu, one for social icons and the last should be a text field, make all columns equal in size
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
    overflow: hidden;
  }

  .ai-footer-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-footer-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-footer-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
  }

  .ai-footer-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-footer-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-footer-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-footer-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-footer-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-footer-logo-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.logo_max_width }}px;
  }

  .ai-footer-logo-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-footer-logo-placeholder-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.logo_max_width }}px;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    padding: 20px;
  }

  .ai-footer-logo-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
  }

  .ai-footer-menu-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-footer-menu-{{ ai_gen_id }} a {
    color: {{ block.settings.menu_color }};
    text-decoration: none;
    font-size: {{ block.settings.menu_font_size }}px;
    transition: opacity 0.3s ease;
  }

  .ai-footer-menu-{{ ai_gen_id }} a:hover {
    opacity: 0.7;
  }

  .ai-footer-social-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.social_icon_gap }}px;
  }

  .ai-footer-social-link-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.social_icon_size }}px;
    height: {{ block.settings.social_icon_size }}px;
    color: {{ block.settings.social_icon_color }};
    transition: opacity 0.3s ease;
  }

  .ai-footer-social-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-footer-social-link-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-footer-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_font_size }}px;
    line-height: 1.6;
  }

  @media screen and (max-width: 989px) {
    .ai-footer-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-footer-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ai-footer-content-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }
  }
{% endstyle %}

<ai-footer-{{ ai_gen_id }} class="ai-footer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-footer-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-footer-background-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-footer-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-footer-content-{{ ai_gen_id }}">
    <div class="ai-footer-grid-{{ ai_gen_id }}">
      <div class="ai-footer-column-{{ ai_gen_id }}">
        {% if block.settings.logo %}
          <div class="ai-footer-logo-{{ ai_gen_id }}">
            <img
              src="{{ block.settings.logo | image_url: width: 400 }}"
              alt="{{ block.settings.logo.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.logo.width }}"
              height="{{ block.settings.logo.height }}"
            >
          </div>
        {% else %}
          <div class="ai-footer-logo-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-footer-column-{{ ai_gen_id }}">
        {% if block.settings.footer_menu != blank %}
          <ul class="ai-footer-menu-{{ ai_gen_id }}">
            {% for link in block.settings.footer_menu.links %}
              <li>
                <a href="{{ link.url }}">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        {% else %}
          <ul class="ai-footer-menu-{{ ai_gen_id }}">
            <li><a href="#">Menu link 1</a></li>
            <li><a href="#">Menu link 2</a></li>
            <li><a href="#">Menu link 3</a></li>
            <li><a href="#">Menu link 4</a></li>
          </ul>
        {% endif %}
      </div>

      <div class="ai-footer-column-{{ ai_gen_id }}">
        <div class="ai-footer-social-{{ ai_gen_id }}">
          {% if settings.social_facebook != blank %}
            <a
              href="{{ settings.social_facebook }}"
              class="ai-footer-social-link-{{ ai_gen_id }}"
              target="_blank"
              rel="noopener"
              aria-label="Facebook"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          {% endif %}

          {% if settings.social_instagram != blank %}
            <a
              href="{{ settings.social_instagram }}"
              class="ai-footer-social-link-{{ ai_gen_id }}"
              target="_blank"
              rel="noopener"
              aria-label="Instagram"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          {% endif %}

          {% if settings.social_twitter != blank %}
            <a
              href="{{ settings.social_twitter }}"
              class="ai-footer-social-link-{{ ai_gen_id }}"
              target="_blank"
              rel="noopener"
              aria-label="X (Twitter)"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          {% endif %}

          {% if settings.social_youtube != blank %}
            <a
              href="{{ settings.social_youtube }}"
              class="ai-footer-social-link-{{ ai_gen_id }}"
              target="_blank"
              rel="noopener"
              aria-label="YouTube"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </a>
          {% endif %}

          {% if settings.social_tiktok != blank %}
            <a
              href="{{ settings.social_tiktok }}"
              class="ai-footer-social-link-{{ ai_gen_id }}"
              target="_blank"
              rel="noopener"
              aria-label="TikTok"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
              </svg>
            </a>
          {% endif %}

          {% if settings.social_linkedin != blank %}
            <a
              href="{{ settings.social_linkedin }}"
              class="ai-footer-social-link-{{ ai_gen_id }}"
              target="_blank"
              rel="noopener"
              aria-label="LinkedIn"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>

      <div class="ai-footer-column-{{ ai_gen_id }}">
        {% if block.settings.footer_text != blank %}
          <div class="ai-footer-text-{{ ai_gen_id }}">
            {{ block.settings.footer_text }}
          </div>
        {% else %}
          <div class="ai-footer-text-{{ ai_gen_id }}">
            <p>Add your custom footer text here. This could include contact information, business hours, or any other important details.</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</ai-footer-{{ ai_gen_id }}>

<script>
  (function() {
    class AiFooter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('ai-footer-{{ ai_gen_id }}', AiFooter{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Footer with background",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Overlay opacity",
      "default": 0.5
    },
    {
      "type": "header",
      "content": "Logo column"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "color",
      "id": "logo_color",
      "label": "Logo color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo max width",
      "default": 150
    },
    {
      "type": "header",
      "content": "Menu column"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer menu"
    },
    {
      "type": "color",
      "id": "menu_color",
      "label": "Menu color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "menu_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Menu font size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Social icons column"
    },
    {
      "type": "paragraph",
      "content": "Social links are managed in theme settings under Social media"
    },
    {
      "type": "color",
      "id": "social_icon_color",
      "label": "Social icon color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "social_icon_size",
      "min": 20,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Social icon size",
      "default": 32
    },
    {
      "type": "range",
      "id": "social_icon_gap",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Gap between icons",
      "default": 16
    },
    {
      "type": "header",
      "content": "Text column"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer text",
      "default": "<p>Add your custom footer text here.</p>"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "text_font_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Text font size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Gap between columns",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Footer with background"
    }
  ]
}
{% endschema %}
