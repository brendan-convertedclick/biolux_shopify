{% doc %}
  @prompt
    Generate an icon text section show 4 on a row, allow background to be an image, allow custom icons, full width on border
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-text-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
  }

  .ai-icon-text-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-icon-text-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-icon-text-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-icon-text-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.1;
  }

  .ai-icon-text-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.overlay_color }};
  }

  .ai-icon-text-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.item_spacing }}px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-icon-text-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.icon_text_gap }}px;
  }

  .ai-icon-text-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-icon-text-icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-icon-text-icon-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: {{ block.settings.icon_stroke_width }};
  }

  .ai-icon-text-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.4;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-icon-text-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-icon-text-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-icon-text-content-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 16px;
    }
  }
{% endstyle %}

<div class="ai-icon-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-text-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-icon-text-background-placeholder-{{ ai_gen_id }}">
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-icon-text-content-{{ ai_gen_id }}">
    <div class="ai-icon-text-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign icon_key = 'icon_' | append: i
          assign text_key = 'text_' | append: i
          assign icon = block.settings[icon_key]
          assign text = block.settings[text_key]
        %}

        <div class="ai-icon-text-item-{{ ai_gen_id }}">
          <div class="ai-icon-text-icon-wrapper-{{ ai_gen_id }}">
            {% if icon %}
              <img
                src="{{ icon | image_url: width: 200 }}"
                alt="{{ icon.alt | escape }}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 16v-4"></path>
                <path d="M12 8h.01"></path>
              </svg>
            {% endif %}
          </div>

          {% if text != blank %}
            <p class="ai-icon-text-text-{{ ai_gen_id }}">{{ text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Icon text row",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Space between items",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Icon to text spacing",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 30,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#1c1c1c"
    },
    {
      "type": "range",
      "id": "icon_stroke_width",
      "label": "Icon stroke width",
      "min": 1,
      "max": 3,
      "step": 0.5,
      "unit": "px",
      "default": 2
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1c1c1c"
    },
    {
      "type": "header",
      "content": "Item 1"
    },
    {
      "type": "image_picker",
      "id": "icon_1",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Text",
      "default": "Free shipping"
    },
    {
      "type": "header",
      "content": "Item 2"
    },
    {
      "type": "image_picker",
      "id": "icon_2",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Text",
      "default": "Easy returns"
    },
    {
      "type": "header",
      "content": "Item 3"
    },
    {
      "type": "image_picker",
      "id": "icon_3",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Text",
      "default": "Secure checkout"
    },
    {
      "type": "header",
      "content": "Item 4"
    },
    {
      "type": "image_picker",
      "id": "icon_4",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_4",
      "label": "Text",
      "default": "24/7 support"
    }
  ],
  "presets": [
    {
      "name": "Icon text row"
    }
  ]
}
{% endschema %}
