{% doc %}
  @prompt
    Generate an icon text section show 3 on a row, allow background to be an image, allow custom icons, full width on border
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-text-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    overflow: hidden;
  }

  .ai-icon-text-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-icon-text-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-icon-text-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-icon-text-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.1;
  }

  .ai-icon-text-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-icon-text-container-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-icon-text-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    text-transform: {{ block.settings.heading_text_transform }};
  }

  .ai-icon-text-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-icon-text-item-{{ ai_gen_id }} {
    text-align: {{ block.settings.item_alignment }};
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background }};
    border-radius: {{ block.settings.item_border_radius }}px;
  }

  .ai-icon-text-icon-wrapper-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    background-color: {{ block.settings.icon_background }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
  }

  .ai-icon-text-icon-wrapper-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.6);
    height: calc({{ block.settings.icon_size }}px * 0.6);
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: 1.5px;
  }

  .ai-icon-text-custom-icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.icon_size }}px * 0.7);
    height: calc({{ block.settings.icon_size }}px * 0.7);
    object-fit: contain;
  }

  .ai-icon-text-item-title-{{ ai_gen_id }} {
    color: {{ block.settings.item_title_color }};
    font-size: {{ block.settings.item_title_size }}px;
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 600;
  }

  .ai-icon-text-item-description-{{ ai_gen_id }} {
    color: {{ block.settings.item_text_color }};
    font-size: {{ block.settings.item_text_size }}px;
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-text-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-icon-text-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ai-icon-text-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstyle %}

<icon-text-section-{{ ai_gen_id }}
  class="ai-icon-text-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-icon-text-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-icon-text-background-placeholder-{{ ai_gen_id }}">
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  {% if block.settings.show_overlay %}
    <div class="ai-icon-text-overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-icon-text-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-icon-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-icon-text-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign title_key = 'item_' | append: i | append: '_title'
          assign description_key = 'item_' | append: i | append: '_description'
          assign icon_key = 'item_' | append: i | append: '_icon'
          assign custom_icon_key = 'item_' | append: i | append: '_custom_icon'

          assign item_title = block.settings[title_key]
          assign item_description = block.settings[description_key]
          assign item_icon = block.settings[icon_key]
          assign custom_icon = block.settings[custom_icon_key]
        %}

        <div class="ai-icon-text-item-{{ ai_gen_id }}">
          <div class="ai-icon-text-icon-wrapper-{{ ai_gen_id }}">
            {% if custom_icon %}
              <img
                src="{{ custom_icon | image_url: width: 200 }}"
                alt="{{ custom_icon.alt | escape }}"
                class="ai-icon-text-custom-icon-{{ ai_gen_id }}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% elsif item_icon == 'check' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            {% elsif item_icon == 'star' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            {% elsif item_icon == 'heart' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
              </svg>
            {% elsif item_icon == 'shield' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
            {% elsif item_icon == 'truck' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"></rect>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                <circle cx="5.5" cy="18.5" r="2.5"></circle>
                <circle cx="18.5" cy="18.5" r="2.5"></circle>
              </svg>
            {% elsif item_icon == 'gift' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 12 20 22 4 22 4 12"></polyline>
                <rect x="2" y="7" width="20" height="5"></rect>
                <line x1="12" y1="22" x2="12" y2="7"></line>
                <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
              </svg>
            {% elsif item_icon == 'clock' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            {% elsif item_icon == 'award' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="7"></circle>
                <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
              </svg>
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            {% endif %}
          </div>

          {% if item_title != blank %}
            <h3 class="ai-icon-text-item-title-{{ ai_gen_id }}">{{ item_title }}</h3>
          {% endif %}

          {% if item_description != blank %}
            <div class="ai-icon-text-item-description-{{ ai_gen_id }}">{{ item_description }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</icon-text-section-{{ ai_gen_id }}>

<script>
  (function() {
    class IconTextSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('icon-text-section-{{ ai_gen_id }}', IconTextSection{{ ai_gen_id }});
  })();
</script>

