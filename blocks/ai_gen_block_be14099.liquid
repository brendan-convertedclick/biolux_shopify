{% doc %}
  @prompt
    A toggle button that asks the user if the provided information is still the same. Below the toggle, there will be 2 buttons: one that says "Proceed to Checkout" if the toggle button is "Yes," and another that says "Update Medical Check." if customer is sign in if not show sign in and hide the toggle  and proceed to check out button.  If customer already signed in hide sign in button, control section alignment. Add instruction above button that states user needs to sign in to be able to check out an d make sure that the Medical check form was submitted. check customer tags if there is red flag or green flag all to add ctom message for either. If there are no tags show message " Please submit the  medical check form.  According to the tags the red flag doesn't see proceed to check out button
    
    Instead of link for Update Medical Info please use this <div class="upform-container" style="display: none !important;" data-id="a6e76e"></div> or have a liquid block for me to add the code
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-checkout-gate-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.alignment }};
  }

  .ai-checkout-gate__instruction-{{ ai_gen_id }} {
    font-size: {{ block.settings.instruction_font_size }}px;
    color: {{ block.settings.instruction_color }};
    margin-bottom: 20px;
  }

  .ai-checkout-gate__message-{{ ai_gen_id }} {
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: {{ block.settings.message_font_size }}px;
  }

  .ai-checkout-gate__message--success-{{ ai_gen_id }} {
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
  }

  .ai-checkout-gate__message--warning-{{ ai_gen_id }} {
    background-color: {{ block.settings.warning_bg_color }};
    color: {{ block.settings.warning_text_color }};
  }

  .ai-checkout-gate__message--error-{{ ai_gen_id }} {
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
  }

  .ai-checkout-gate__toggle-wrapper-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-checkout-gate__toggle-label-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.alignment }};
    gap: 12px;
    cursor: pointer;
    font-size: {{ block.settings.toggle_font_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-checkout-gate__toggle-switch-{{ ai_gen_id }} {
    position: relative;
    width: 60px;
    height: 30px;
    background-color: {{ block.settings.toggle_off_color }};
    border-radius: 15px;
    transition: background-color 0.3s ease;
  }

  .ai-checkout-gate__toggle-switch-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    width: 24px;
    height: 24px;
    background-color: #ffffff;
    border-radius: 50%;
    transition: transform 0.3s ease;
  }

  .ai-checkout-gate__toggle-input-{{ ai_gen_id }}:checked + .ai-checkout-gate__toggle-label-{{ ai_gen_id }} .ai-checkout-gate__toggle-switch-{{ ai_gen_id }} {
    background-color: {{ block.settings.toggle_on_color }};
  }

  .ai-checkout-gate__toggle-input-{{ ai_gen_id }}:checked + .ai-checkout-gate__toggle-label-{{ ai_gen_id }} .ai-checkout-gate__toggle-switch-{{ ai_gen_id }}::after {
    transform: translateX(30px);
  }

  .ai-checkout-gate__toggle-input-{{ ai_gen_id }} {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .ai-checkout-gate__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: {{ block.settings.alignment }};
  }

  .ai-checkout-gate__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    text-transform: {{ block.settings.button_text_transform }};
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    text-decoration: none;
    display: inline-block;
  }

  .ai-checkout-gate__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text }};
  }

  .ai-checkout-gate__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
  }

  .ai-checkout-gate__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_text }};
  }

  .ai-checkout-gate__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
  }

  .ai-checkout-gate__hidden-{{ ai_gen_id }} {
    display: none;
  }

  .ai-checkout-gate__upform-container-{{ ai_gen_id }} {
    margin-top: 12px;
  }

  @media screen and (max-width: 749px) {
    .ai-checkout-gate-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<checkout-gate-{{ ai_gen_id }}
  class="ai-checkout-gate-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-customer-logged-in="{% if customer %}true{% else %}false{% endif %}"
  data-customer-tags="{{ customer.tags | join: ',' }}"
>
  {% if customer %}
    {% assign has_green_flag = false %}
    {% assign has_red_flag = false %}
    {% assign has_any_flag = false %}

    {% for tag in customer.tags %}
      {% assign tag_lower = tag | downcase %}
      {% if tag_lower contains 'green' and tag_lower contains 'flag' %}
        {% assign has_green_flag = true %}
        {% assign has_any_flag = true %}
      {% endif %}
      {% if tag_lower contains 'red' and tag_lower contains 'flag' %}
        {% assign has_red_flag = true %}
        {% assign has_any_flag = true %}
      {% endif %}
    {% endfor %}

    {% if has_any_flag == false %}
      <div class="ai-checkout-gate__message-{{ ai_gen_id }} ai-checkout-gate__message--warning-{{ ai_gen_id }}">
        {{ block.settings.no_tags_message }}
      </div>
    {% elsif has_green_flag %}
      <div class="ai-checkout-gate__message-{{ ai_gen_id }} ai-checkout-gate__message--success-{{ ai_gen_id }}">
        {{ block.settings.green_flag_message }}
      </div>

      <div class="ai-checkout-gate__toggle-wrapper-{{ ai_gen_id }}">
        <input
          type="checkbox"
          id="ai-checkout-gate-toggle-{{ ai_gen_id }}"
          class="ai-checkout-gate__toggle-input-{{ ai_gen_id }}"
        >
        <label
          for="ai-checkout-gate-toggle-{{ ai_gen_id }}"
          class="ai-checkout-gate__toggle-label-{{ ai_gen_id }}"
        >
          <span>{{ block.settings.toggle_question }}</span>
          <span class="ai-checkout-gate__toggle-switch-{{ ai_gen_id }}"></span>
        </label>
      </div>

      <div class="ai-checkout-gate__buttons-{{ ai_gen_id }}">
        <a
          href="/checkout"
          class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--primary-{{ ai_gen_id }} ai-checkout-gate__checkout-btn-{{ ai_gen_id }} ai-checkout-gate__hidden-{{ ai_gen_id }}"
        >
          {{ block.settings.proceed_button_text }}
        </a>

        <button
          type="button"
          class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--secondary-{{ ai_gen_id }} ai-checkout-gate__update-btn-{{ ai_gen_id }}"
        >
          {{ block.settings.update_button_text }}
        </button>

        {% if block.settings.upform_code != blank %}
          <div class="ai-checkout-gate__upform-container-{{ ai_gen_id }} ai-checkout-gate__hidden-{{ ai_gen_id }}">
            {{ block.settings.upform_code }}
          </div>
        {% endif %}
      </div>
    {% elsif has_red_flag %}
      <div class="ai-checkout-gate__message-{{ ai_gen_id }} ai-checkout-gate__message--error-{{ ai_gen_id }}">
        {{ block.settings.red_flag_message }}
      </div>

      <div class="ai-checkout-gate__buttons-{{ ai_gen_id }}">
        <button
          type="button"
          class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--secondary-{{ ai_gen_id }} ai-checkout-gate__update-btn-{{ ai_gen_id }}"
        >
          {{ block.settings.update_button_text }}
        </button>

        {% if block.settings.upform_code != blank %}
          <div class="ai-checkout-gate__upform-container-{{ ai_gen_id }} ai-checkout-gate__hidden-{{ ai_gen_id }}">
            {{ block.settings.upform_code }}
          </div>
        {% endif %}
      </div>
    {% endif %}
  {% else %}
    <div class="ai-checkout-gate__instruction-{{ ai_gen_id }}">
      {{ block.settings.signin_instruction }}
    </div>

    <div class="ai-checkout-gate__buttons-{{ ai_gen_id }}">
      <a
        href="/account/login"
        class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--primary-{{ ai_gen_id }}"
      >
        {{ block.settings.signin_button_text }}
      </a>
    </div>
  {% endif %}
</checkout-gate-{{ ai_gen_id }}>

<script>
  (function() {
    class CheckoutGate{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.toggle = this.querySelector('.ai-checkout-gate__toggle-input-{{ ai_gen_id }}');
        this.checkoutBtn = this.querySelector('.ai-checkout-gate__checkout-btn-{{ ai_gen_id }}');
        this.updateBtn = this.querySelector('.ai-checkout-gate__update-btn-{{ ai_gen_id }}');
        this.upformContainer = this.querySelector('.ai-checkout-gate__upform-container-{{ ai_gen_id }}');

        if (this.toggle) {
          this.toggle.addEventListener('change', this.handleToggleChange.bind(this));
        }

        if (this.updateBtn) {
          this.updateBtn.addEventListener('click', this.handleUpdateClick.bind(this));
        }
      }

      handleToggleChange() {
        if (this.toggle.checked && this.checkoutBtn) {
          this.checkoutBtn.classList.remove('ai-checkout-gate__hidden-{{ ai_gen_id }}');
        } else if (this.checkoutBtn) {
          this.checkoutBtn.classList.add('ai-checkout-gate__hidden-{{ ai_gen_id }}');
        }
      }

      handleUpdateClick() {
        if (this.upformContainer) {
          this.upformContainer.classList.toggle('ai-checkout-gate__hidden-{{ ai_gen_id }}');
        }
      }
    }

    customElements.define('checkout-gate-{{ ai_gen_id }}', CheckoutGate{{ ai_gen_id }});
  })();
</script>

