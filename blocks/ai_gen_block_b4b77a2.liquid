{% doc %}
  @prompt
    A toggle button that asks the user if the provided information is still the same. Below the toggle, there will be 2 buttons: one that says "Proceed to Checkout" if the toggle button is "Yes," and another that says "Update Medical Check." if customer is sign in if not show sign in and hide the toggle  and proceed to check out button.  If customer already signed in hide sign in button, control section alignment. Add instruction above button that states user needs to sign in to be able to check out an d make sure that the Medical check form was submitted. check customer tags if there is red flag or green flag all to add ctom message for either. If there are no tags show message " Please submit the  medical check form.  According to the tags the red flag doesn't see proceed to check out button. By default the toogle should be on
    
    Instead of link for Update Medical Info please use this <div class="upform-container" style="display: none !important;" data-id="a6e76e"></div> or have a liquid block for me to add the code, add button size controls, make buttons smaller in width size. Add a link text that says checkout as quest and that will show the medical check form whn clicked.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-medical-checkout-gate-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.alignment }};
  }

  .ai-medical-checkout-gate__instruction-{{ ai_gen_id }} {
    color: {{ block.settings.instruction_color }};
    font-size: {{ block.settings.instruction_font_size }}px;
    margin-bottom: 20px;
  }

  .ai-medical-checkout-gate__message-{{ ai_gen_id }} {
    padding: 16px;
    border-radius: 6px;
    margin-bottom: 20px;
    font-size: {{ block.settings.message_font_size }}px;
  }

  .ai-medical-checkout-gate__message--success-{{ ai_gen_id }} {
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
  }

  .ai-medical-checkout-gate__message--error-{{ ai_gen_id }} {
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
  }

  .ai-medical-checkout-gate__message--warning-{{ ai_gen_id }} {
    background-color: {{ block.settings.warning_bg_color }};
    color: {{ block.settings.warning_text_color }};
  }

  .ai-medical-checkout-gate__toggle-wrapper-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-medical-checkout-gate__toggle-label-{{ ai_gen_id }} {
    display: block;
    font-size: {{ block.settings.toggle_label_size }}px;
    color: {{ block.settings.text_color }};
    margin-bottom: 12px;
    font-weight: 600;
  }

  .ai-medical-checkout-gate__toggle-container-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .ai-medical-checkout-gate__toggle-switch-{{ ai_gen_id }} {
    position: relative;
    width: 60px;
    height: 32px;
    background-color: {{ block.settings.toggle_off_color }};
    border-radius: 16px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-medical-checkout-gate__toggle-switch-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.toggle_on_color }};
  }

  .ai-medical-checkout-gate__toggle-knob-{{ ai_gen_id }} {
    position: absolute;
    top: 4px;
    left: 4px;
    width: 24px;
    height: 24px;
    background-color: #ffffff;
    border-radius: 50%;
    transition: transform 0.3s ease;
  }

  .ai-medical-checkout-gate__toggle-switch-{{ ai_gen_id }}.active .ai-medical-checkout-gate__toggle-knob-{{ ai_gen_id }} {
    transform: translateX(28px);
  }

  .ai-medical-checkout-gate__toggle-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.toggle_text_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-medical-checkout-gate__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: {{ block.settings.alignment }};
  }

  .ai-medical-checkout-gate__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    width: {{ block.settings.button_width }}%;
    max-width: 100%;
    text-align: center;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-medical-checkout-gate__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text }};
  }

  .ai-medical-checkout-gate__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
  }

  .ai-medical-checkout-gate__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_text }};
  }

  .ai-medical-checkout-gate__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
  }

  .ai-medical-checkout-gate__button--signin-{{ ai_gen_id }} {
    background-color: {{ block.settings.signin_button_bg }};
    color: {{ block.settings.signin_button_color }};
  }

  .ai-medical-checkout-gate__button--signin-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.signin_button_hover_bg }};
  }

  .ai-medical-checkout-gate__link-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: 16px;
    color: {{ block.settings.link_color }};
    font-size: {{ block.settings.link_font_size }}px;
    text-decoration: underline;
    cursor: pointer;
  }

  .ai-medical-checkout-gate__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-medical-checkout-gate__hidden-{{ ai_gen_id }} {
    display: none !important;
  }

  @media screen and (max-width: 749px) {
    .ai-medical-checkout-gate-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-medical-checkout-gate__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<medical-checkout-gate-{{ ai_gen_id }}
  class="ai-medical-checkout-gate-{{ ai_gen_id }}"
  data-customer-logged-in="{{ customer }}"
  {{ block.shopify_attributes }}
>
  {% if customer %}
    {% liquid
      assign has_green_flag = false
      assign has_red_flag = false
      
      for tag in customer.tags
        if tag contains 'green-flag' or tag contains 'green_flag' or tag contains 'auto-clear' or tag contains 'auto_clear'
          assign has_green_flag = true
        endif
        if tag contains 'red-flag' or tag contains 'red_flag'
          assign has_red_flag = true
        endif
      endfor
    %}

    {% if has_green_flag == false and has_red_flag == false %}
      <div class="ai-medical-checkout-gate__message-{{ ai_gen_id }} ai-medical-checkout-gate__message--warning-{{ ai_gen_id }}">
        {{ block.settings.no_tags_message }}
      </div>
    {% endif %}

    {% if has_green_flag %}
      <div class="ai-medical-checkout-gate__message-{{ ai_gen_id }} ai-medical-checkout-gate__message--success-{{ ai_gen_id }}">
        {{ block.settings.green_flag_message }}
      </div>

      <div class="ai-medical-checkout-gate__toggle-wrapper-{{ ai_gen_id }}">
        <label class="ai-medical-checkout-gate__toggle-label-{{ ai_gen_id }}">
          {{ block.settings.toggle_question }}
        </label>
        <div class="ai-medical-checkout-gate__toggle-container-{{ ai_gen_id }}">
          <div class="ai-medical-checkout-gate__toggle-switch-{{ ai_gen_id }} active" data-toggle>
            <div class="ai-medical-checkout-gate__toggle-knob-{{ ai_gen_id }}"></div>
          </div>
          <span class="ai-medical-checkout-gate__toggle-text-{{ ai_gen_id }}" data-toggle-text>Yes</span>
        </div>
      </div>

      <div class="ai-medical-checkout-gate__buttons-{{ ai_gen_id }}">
        <a
          href="/checkout"
          class="ai-medical-checkout-gate__button-{{ ai_gen_id }} ai-medical-checkout-gate__button--primary-{{ ai_gen_id }}"
          data-checkout-button
        >
          {{ block.settings.proceed_button_text }}
        </a>

        <button
          type="button"
          class="ai-medical-checkout-gate__button-{{ ai_gen_id }} ai-medical-checkout-gate__button--secondary-{{ ai_gen_id }} ai-medical-checkout-gate__hidden-{{ ai_gen_id }}"
          data-update-button
        >
          {{ block.settings.update_button_text }}
        </button>
      </div>
    {% endif %}

    {% if has_red_flag %}
      <div class="ai-medical-checkout-gate__message-{{ ai_gen_id }} ai-medical-checkout-gate__message--error-{{ ai_gen_id }}">
        {{ block.settings.red_flag_message }}
      </div>

      <div class="ai-medical-checkout-gate__buttons-{{ ai_gen_id }}">
        <button
          type="button"
          class="ai-medical-checkout-gate__button-{{ ai_gen_id }} ai-medical-checkout-gate__button--secondary-{{ ai_gen_id }}"
          data-update-button
        >
          {{ block.settings.update_button_text }}
        </button>
      </div>
    {% endif %}

    {% if block.settings.show_guest_checkout_link %}
      <a
        href="#"
        class="ai-medical-checkout-gate__link-{{ ai_gen_id }}"
        data-guest-link
      >
        {{ block.settings.guest_checkout_text }}
      </a>
    {% endif %}

  {% else %}
    <div class="ai-medical-checkout-gate__instruction-{{ ai_gen_id }}">
      {{ block.settings.signin_instruction }}
    </div>

    <div class="ai-medical-checkout-gate__buttons-{{ ai_gen_id }}">
      <a
        href="/account/login"
        class="ai-medical-checkout-gate__button-{{ ai_gen_id }} ai-medical-checkout-gate__button--signin-{{ ai_gen_id }}"
      >
        {{ block.settings.signin_label }}
      </a>
    </div>

    {% if block.settings.show_guest_checkout_link %}
      <a
        href="#"
        class="ai-medical-checkout-gate__link-{{ ai_gen_id }}"
        data-guest-link
      >
        {{ block.settings.guest_checkout_text }}
      </a>
    {% endif %}
  {% endif %}

  {% if block.settings.enable_custom_form %}
    <div class="upform-container" style="display: none !important;" data-id="a6e76e"></div>
  {% endif %}

  {% if block.settings.custom_liquid != blank %}
    {{ block.settings.custom_liquid }}
  {% endif %}
</medical-checkout-gate-{{ ai_gen_id }}>

<script>
  (function() {
    class MedicalCheckoutGate{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.toggleSwitch = this.querySelector('[data-toggle]');
        this.toggleText = this.querySelector('[data-toggle-text]');
        this.checkoutButton = this.querySelector('[data-checkout-button]');
        this.updateButton = this.querySelector('[data-update-button]');
        this.guestLink = this.querySelector('[data-guest-link]');
        this.isInfoSame = true;
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        if (this.toggleSwitch) {
          this.toggleSwitch.addEventListener('click', () => {
            this.handleToggle();
          });
        }

        if (this.updateButton) {
          this.updateButton.addEventListener('click', () => {
            this.showMedicalForm();
          });
        }

        if (this.guestLink) {
          this.guestLink.addEventListener('click', (e) => {
            e.preventDefault();
            this.showMedicalForm();
          });
        }
      }

      handleToggle() {
        this.isInfoSame = !this.isInfoSame;
        this.toggleSwitch.classList.toggle('active');

        if (this.isInfoSame) {
          this.toggleText.textContent = 'Yes';
          this.checkoutButton.classList.remove('ai-medical-checkout-gate__hidden-{{ ai_gen_id }}');
          this.updateButton.classList.add('ai-medical-checkout-gate__hidden-{{ ai_gen_id }}');
        } else {
          this.toggleText.textContent = 'No';
          this.checkoutButton.classList.add('ai-medical-checkout-gate__hidden-{{ ai_gen_id }}');
          this.updateButton.classList.remove('ai-medical-checkout-gate__hidden-{{ ai_gen_id }}');
        }
      }

      showMedicalForm() {
        const formContainer = document.querySelector('.upform-container[data-id="a6e76e"]');
        if (formContainer) {
          formContainer.style.display = 'block';
          formContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    }

    customElements.define('medical-checkout-gate-{{ ai_gen_id }}', MedicalCheckoutGate{{ ai_gen_id }});
  })();
</script>

