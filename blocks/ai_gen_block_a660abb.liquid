{% doc %}
  @prompt
    A toggle button that asks the user if the provided information is still the same. Below the toggle, there will be 2 buttons: one that says "Proceed to Checkout" if the toggle button is "Yes," and another that says "Update Medical Check." if customer is sign in if not show sign in and hide the toggle  and proceed to check out button, open sign in in new tap.  If customer already signed in hide sign in button, control section alignment. Add instruction above button that states user needs to sign in to be able to check out an d make sure that the Medical check form was submitted. check customer tags if there is red flag or green flag all to add ctom message for either. If there are no tags show message " Please submit the  medical check form.  According to the tags the red flag doesn't see proceed to check out button
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-medical-check-toggle-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-medical-check-container-{{ ai_gen_id }} {
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.alignment }};
  }

  .ai-medical-check-instruction-{{ ai_gen_id }} {
    font-size: {{ block.settings.instruction_font_size }}px;
    color: {{ block.settings.instruction_color }};
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .ai-medical-check-message-{{ ai_gen_id }} {
    padding: 16px;
    border-radius: {{ block.settings.message_border_radius }}px;
    margin-bottom: 20px;
    font-size: {{ block.settings.message_font_size }}px;
    line-height: 1.5;
  }

  .ai-medical-check-message-{{ ai_gen_id }}--success {
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
    border: 1px solid {{ block.settings.success_border_color }};
  }

  .ai-medical-check-message-{{ ai_gen_id }}--warning {
    background-color: {{ block.settings.warning_bg_color }};
    color: {{ block.settings.warning_text_color }};
    border: 1px solid {{ block.settings.warning_border_color }};
  }

  .ai-medical-check-message-{{ ai_gen_id }}--error {
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
    border: 1px solid {{ block.settings.error_border_color }};
  }

  .ai-medical-check-toggle-wrapper-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-medical-check-toggle-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.toggle_label_size }}px;
    color: {{ block.settings.text_color }};
    margin-bottom: 12px;
    display: block;
    font-weight: 600;
  }

  .ai-medical-check-toggle-buttons-{{ ai_gen_id }} {
    display: inline-flex;
    gap: 8px;
    border: 2px solid {{ block.settings.toggle_border_color }};
    border-radius: {{ block.settings.toggle_border_radius }}px;
    overflow: hidden;
  }

  .ai-medical-check-toggle-btn-{{ ai_gen_id }} {
    padding: 12px 32px;
    background-color: {{ block.settings.toggle_inactive_bg }};
    color: {{ block.settings.toggle_inactive_text }};
    border: none;
    cursor: pointer;
    font-size: {{ block.settings.toggle_button_font_size }}px;
    transition: all 0.3s ease;
    font-weight: 500;
  }

  .ai-medical-check-toggle-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.toggle_hover_bg }};
  }

  .ai-medical-check-toggle-btn-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.toggle_active_bg }};
    color: {{ block.settings.toggle_active_text }};
  }

  .ai-medical-check-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    justify-content: {{ block.settings.alignment }};
    flex-wrap: wrap;
  }

  .ai-medical-check-btn-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    display: inline-block;
    text-transform: {{ block.settings.button_text_transform }};
  }

  .ai-medical-check-btn-{{ ai_gen_id }}--primary {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text }};
  }

  .ai-medical-check-btn-{{ ai_gen_id }}--primary:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
  }

  .ai-medical-check-btn-{{ ai_gen_id }}--secondary {
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_text }};
  }

  .ai-medical-check-btn-{{ ai_gen_id }}--secondary:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
  }

  .ai-medical-check-hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-medical-check-buttons-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-medical-check-btn-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }
  }
{% endstyle %}

<medical-check-toggle-{{ ai_gen_id }}
  class="ai-medical-check-toggle-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-medical-check-container-{{ ai_gen_id }}">
    {% liquid
      assign is_signed_in = false
      assign has_green_flag = false
      assign has_red_flag = false
      
      if customer
        assign is_signed_in = true
        for tag in customer.tags
          if tag == block.settings.green_flag_tag
            assign has_green_flag = true
          endif
          if tag == block.settings.red_flag_tag
            assign has_red_flag = true
          endif
        endfor
      endif
      
      assign has_any_flag = false
      if has_green_flag or has_red_flag
        assign has_any_flag = true
      endif
    %}

    {% unless is_signed_in %}
      <div class="ai-medical-check-instruction-{{ ai_gen_id }}">
        {{ block.settings.signin_instruction }}
      </div>

      <div class="ai-medical-check-buttons-{{ ai_gen_id }}">
        <a
          href="{{ routes.account_login_url }}"
          target="_blank"
          class="ai-medical-check-btn-{{ ai_gen_id }} ai-medical-check-btn-{{ ai_gen_id }}--primary"
        >
          {{ block.settings.signin_button_text }}
        </a>
      </div>
    {% else %}
      {% if has_green_flag %}
        <div class="ai-medical-check-message-{{ ai_gen_id }} ai-medical-check-message-{{ ai_gen_id }}--success">
          {{ block.settings.green_flag_message }}
        </div>
      {% elsif has_red_flag %}
        <div class="ai-medical-check-message-{{ ai_gen_id }} ai-medical-check-message-{{ ai_gen_id }}--error">
          {{ block.settings.red_flag_message }}
        </div>
      {% else %}
        <div class="ai-medical-check-message-{{ ai_gen_id }} ai-medical-check-message-{{ ai_gen_id }}--warning">
          {{ block.settings.no_tag_message }}
        </div>
      {% endif %}

      {% if has_any_flag %}
        <div class="ai-medical-check-toggle-wrapper-{{ ai_gen_id }}">
          <label class="ai-medical-check-toggle-label-{{ ai_gen_id }}">
            {{ block.settings.toggle_question }}
          </label>
          <div class="ai-medical-check-toggle-buttons-{{ ai_gen_id }}">
            <button
              type="button"
              class="ai-medical-check-toggle-btn-{{ ai_gen_id }} active"
              data-value="yes"
            >
              {{ block.settings.toggle_yes_text }}
            </button>
            <button
              type="button"
              class="ai-medical-check-toggle-btn-{{ ai_gen_id }}"
              data-value="no"
            >
              {{ block.settings.toggle_no_text }}
            </button>
          </div>
        </div>

        <div class="ai-medical-check-buttons-{{ ai_gen_id }}">
          {% unless has_red_flag %}
            <a
              href="/checkout"
              class="ai-medical-check-btn-{{ ai_gen_id }} ai-medical-check-btn-{{ ai_gen_id }}--primary ai-medical-check-checkout-btn-{{ ai_gen_id }}"
            >
              {{ block.settings.checkout_button_text }}
            </a>
          {% endunless %}

          <a
            href="{{ block.settings.medical_form_url }}"
            class="ai-medical-check-btn-{{ ai_gen_id }} ai-medical-check-btn-{{ ai_gen_id }}--secondary ai-medical-check-update-btn-{{ ai_gen_id }} ai-medical-check-hidden-{{ ai_gen_id }}"
          >
            {{ block.settings.update_button_text }}
          </a>
        </div>
      {% endif %}
    {% endunless %}
  </div>
</medical-check-toggle-{{ ai_gen_id }}>

<script>
  (function() {
    class MedicalCheckToggle{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.toggleButtons = this.querySelectorAll('.ai-medical-check-toggle-btn-{{ ai_gen_id }}');
        this.checkoutBtn = this.querySelector('.ai-medical-check-checkout-btn-{{ ai_gen_id }}');
        this.updateBtn = this.querySelector('.ai-medical-check-update-btn-{{ ai_gen_id }}');
        
        if (this.toggleButtons.length > 0) {
          this.setupToggle();
        }
      }

      setupToggle() {
        this.toggleButtons.forEach((button) => {
          button.addEventListener('click', () => {
            this.toggleButtons.forEach((btn) => btn.classList.remove('active'));
            button.classList.add('active');
            
            const value = button.getAttribute('data-value');
            this.updateButtonVisibility(value);
          });
        });
      }

      updateButtonVisibility(value) {
        if (value === 'yes') {
          if (this.checkoutBtn) {
            this.checkoutBtn.classList.remove('ai-medical-check-hidden-{{ ai_gen_id }}');
          }
          if (this.updateBtn) {
            this.updateBtn.classList.add('ai-medical-check-hidden-{{ ai_gen_id }}');
          }
        } else {
          if (this.checkoutBtn) {
            this.checkoutBtn.classList.add('ai-medical-check-hidden-{{ ai_gen_id }}');
          }
          if (this.updateBtn) {
            this.updateBtn.classList.remove('ai-medical-check-hidden-{{ ai_gen_id }}');
          }
        }
      }
    }

    customElements.define('medical-check-toggle-{{ ai_gen_id }}', MedicalCheckToggle{{ ai_gen_id }});
  })();
</script>

