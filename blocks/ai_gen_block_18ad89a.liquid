{% doc %}
  @prompt
    Ask user to sign in or continue as quest checkout. If or after signing in show a check box asking if the medical form answer are still the same. By defualt it should be checked if user unchecks show the form. For guest users always show the form
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-auth-form-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    display: block;
  }

  .ai-auth-section-{{ ai_gen_id }} {
    margin-bottom: 32px;
  }

  .ai-auth-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px 0;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
  }

  .ai-auth-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px 0;
    font-weight: 600;
  }

  .ai-auth-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px 0;
    line-height: 1.5;
  }

  .ai-auth-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .ai-auth-button-{{ ai_gen_id }} {
    padding: 14px 28px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: {{ block.settings.button_text_size }}px;
    text-decoration: none;
    display: inline-block;
    transition: background-color 0.3s ease;
  }

  .ai-auth-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-auth-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_color }};
    color: {{ block.settings.secondary_button_text_color }};
  }

  .ai-auth-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_color }};
  }

  .ai-auth-checkbox-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 20px;
    background-color: {{ block.settings.checkbox_bg_color }};
    border-radius: {{ block.settings.checkbox_border_radius }}px;
    margin-bottom: 24px;
    border: 2px solid {{ block.settings.checkbox_border_color }};
  }

  .ai-auth-checkbox-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    cursor: pointer;
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: {{ block.settings.button_color }};
  }

  .ai-auth-checkbox-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    cursor: pointer;
    line-height: 1.5;
  }

  .ai-auth-form-section-{{ ai_gen_id }} {
    padding: 24px;
    background-color: {{ block.settings.form_bg_color }};
    border-radius: {{ block.settings.form_border_radius }}px;
    border: 1px solid {{ block.settings.form_border_color }};
  }

  .ai-auth-form-section-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-auth-form-group-{{ ai_gen_id }} {
    margin-bottom: 20px;
  }

  .ai-auth-form-label-{{ ai_gen_id }} {
    display: block;
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.text_color }};
    margin-bottom: 8px;
    font-weight: 600;
  }

  .ai-auth-form-input-{{ ai_gen_id }},
  .ai-auth-form-textarea-{{ ai_gen_id }},
  .ai-auth-form-select-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.text_size }}px;
    background-color: {{ block.settings.input_bg_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-auth-form-textarea-{{ ai_gen_id }} {
    min-height: 100px;
    resize: vertical;
  }

  .ai-auth-form-input-{{ ai_gen_id }}:focus,
  .ai-auth-form-textarea-{{ ai_gen_id }}:focus,
  .ai-auth-form-select-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_color }};
    outline-offset: 2px;
  }

  .ai-auth-required-{{ ai_gen_id }} {
    color: {{ block.settings.required_color }};
  }

  .ai-auth-divider-{{ ai_gen_id }} {
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    margin: 24px 0;
  }

  .ai-auth-status-message-{{ ai_gen_id }} {
    padding: 16px;
    border-radius: {{ block.settings.border_radius }}px;
    margin-bottom: 20px;
    font-size: {{ block.settings.text_size }}px;
  }

  .ai-auth-status-message-{{ ai_gen_id }}.success {
    background-color: #e8f5e9;
    color: #2e7d32;
    border: 1px solid #4caf50;
  }

  .ai-auth-status-message-{{ ai_gen_id }}.info {
    background-color: #e3f2fd;
    color: #1565c0;
    border: 1px solid #2196f3;
  }

  @media screen and (max-width: 749px) {
    .ai-auth-form-container-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.container_padding | times: 0.7 }}px;
    }

    .ai-auth-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-auth-buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-auth-button-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }
  }
{% endstyle %}

<medical-auth-form-{{ ai_gen_id }}
  class="ai-auth-form-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-customer-logged-in="{% if customer %}true{% else %}false{% endif %}"
>
  {% if customer %}
    <div class="ai-auth-section-{{ ai_gen_id }}">
      <h2 class="ai-auth-heading-{{ ai_gen_id }}">{{ block.settings.welcome_heading }}</h2>
      <p class="ai-auth-text-{{ ai_gen_id }}">{{ block.settings.welcome_message }}</p>
      
      <div class="ai-auth-checkbox-wrapper-{{ ai_gen_id }}">
        <input
          type="checkbox"
          id="ai-auth-confirm-checkbox-{{ ai_gen_id }}"
          class="ai-auth-checkbox-{{ ai_gen_id }}"
          checked
        >
        <label
          for="ai-auth-confirm-checkbox-{{ ai_gen_id }}"
          class="ai-auth-checkbox-label-{{ ai_gen_id }}"
        >
          {{ block.settings.checkbox_label }}
        </label>
      </div>
    </div>

    <div class="ai-auth-form-section-{{ ai_gen_id }} hidden" id="ai-auth-medical-form-{{ ai_gen_id }}">
      <h3 class="ai-auth-subheading-{{ ai_gen_id }}">{{ block.settings.form_heading }}</h3>
      {%- form 'contact' -%}
        <input type="hidden" name="contact[customer_id]" value="{{ customer.id }}">
        <input type="hidden" name="contact[form_type]" value="medical_eligibility">

        <div class="ai-auth-form-group-{{ ai_gen_id }}">
          <label for="ai-auth-full-name-{{ ai_gen_id }}" class="ai-auth-form-label-{{ ai_gen_id }}">
            {{ block.settings.name_label }} <span class="ai-auth-required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="text"
            id="ai-auth-full-name-{{ ai_gen_id }}"
            name="contact[full_name]"
            class="ai-auth-form-input-{{ ai_gen_id }}"
            value="{{ customer.name }}"
            required
          >
        </div>

        <div class="ai-auth-form-group-{{ ai_gen_id }}">
          <label for="ai-auth-email-{{ ai_gen_id }}" class="ai-auth-form-label-{{ ai_gen_id }}">
            {{ block.settings.email_label }} <span class="ai-auth-required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="email"
            id="ai-auth-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-auth-form-input-{{ ai_gen_id }}"
            value="{{ customer.email }}"
            required
          >
        </div>

        <div class="ai-auth-form-group-{{ ai_gen_id }}">
          <label for="ai-auth-phone-{{ ai_gen_id }}" class="ai-auth-form-label-{{ ai_gen_id }}">
            {{ block.settings.phone_label }}
          </label>
          <input
            type="tel"
            id="ai-auth-phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-auth-form-input-{{ ai_gen_id }}"
            value="{{ customer.phone }}"
          >
        </div>

        <div class="ai-auth-form-group-{{ ai_gen_id }}">
          <label for="ai-auth-medical-conditions-{{ ai_gen_id }}" class="ai-auth-form-label-{{ ai_gen_id }}">
            {{ block.settings.conditions_label }} <span class="ai-auth-required-{{ ai_gen_id }}">*</span>
          </label>
          <textarea
            id="ai-auth-medical-conditions-{{ ai_gen_id }}"
            name="contact[medical_conditions]"
            class="ai-auth-form-textarea-{{ ai_gen_id }}"
            required
          ></textarea>
        </div>

        <div class="ai-auth-form-group-{{ ai_gen_id }}">
          <label for="ai-auth-medications-{{ ai_gen_id }}" class="ai-auth-form-label-{{ ai_gen_id }}">
            {{ block.settings.medications_label }}
          </label>
          <textarea
            id="ai-auth-medications-{{ ai_gen_id }}"
            name="contact[current_medications]"
            class="ai-auth-form-textarea-{{ ai_gen_id }}"
          ></textarea>
        </div>

        <div class="ai-auth-form-group-{{ ai_gen_id }}">
          <label for="ai-auth-allergies-{{ ai_gen_id }}" class="ai-auth-form-label-{{ ai_gen_id }}">
            {{ block.settings.allergies_label }}
          </label>
          <textarea
            id="ai-auth-allergies-{{ ai_gen_id }}"
            name="contact[allergies]"
            class="ai-auth-form-textarea-{{ ai_gen_id }}"
          ></textarea>
        </div>

        {%- if form.posted_successfully? -%}
          <div class="ai-auth-status-message-{{ ai_gen_id }} success">
            {{ block.settings.success_message }}
          </div>
        {%- endif -%}

        <button type="submit" class="ai-auth-button-{{ ai_gen_id }}">
          {{ block.settings.submit_button_label }}
        </button>
      {%- endform -%}
    </div>

  {% else %}
    <div class="ai-auth-section-{{ ai_gen_id }}">
      <h2 class="ai-auth-heading-{{ ai_gen_id }}">{{ block.settings.guest_heading }}</h2>
      <p class="ai-auth-text-{{ ai_gen_id }}">{{ block.settings.guest_message }}</p>

      <div class="ai-auth-buttons-{{ ai_gen_id }}">
        <a href="/account/login" class="ai-auth-button-{{ ai_gen_id }}">
          {{ block.settings.sign_in_button_label }}
        </a>
        <button
          type="button"
          class="ai-auth-button-{{ ai_gen_id }} ai-auth-button-secondary-{{ ai_gen_id }}"
          id="ai-auth-guest-continue-{{ ai_gen_id }}"
        >
          {{ block.settings.guest_button_label }}
        </button>
      </div>
    </div>

    <div class="ai-auth-form-section-{{ ai_gen_id }} hidden" id="ai-auth-guest-form-{{ ai_gen_id }}">
      <h3 class="ai-auth-subheading-{{ ai_gen_id }}">{{ block.settings.form_heading }}</h3>
      <p class="ai-auth-text-{{ ai_gen_id }}">{{ block.settings.guest_form_message }}</p>

      {%- form 'contact' -%}
        <input type="hidden" name="contact[form_type]" value="medical_eligibility_guest">

        <div class="ai-auth-form-group-{{ ai_gen_id }}">
          <label for="ai-auth-guest-name-{{ ai_gen_id }}" class="ai-auth-form-label-{{ ai_gen_id }}">
            {{ block.settings.name_label }} <span class="ai-auth-required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="text"
            id="ai-auth-guest-name-{{ ai_gen_id }}"
            name="contact[full_name]"
            class="ai-auth-form-input-{{ ai_gen_id }}"
            required
          >
        </div>

        <div class="ai-auth-form-group-{{ ai_gen_id }}">
          <label for="ai-auth-guest-email-{{ ai_gen_id }}" class="ai-auth-form-label-{{ ai_gen_id }}">
            {{ block.settings.email_label }} <span class="ai-auth-required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="email"
            id="ai-auth-guest-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-auth-form-input-{{ ai_gen_id }}"
            required
          >
        </div>

        <div class="ai-auth-form-group-{{ ai_gen_id }}">
          <label for="ai-auth-guest-phone-{{ ai_gen_id }}" class="ai-auth-form-label-{{ ai_gen_id }}">
            {{ block.settings.phone_label }}
          </label>
          <input
            type="tel"
            id="ai-auth-guest-phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-auth-form-input-{{ ai_gen_id }}"
          >
        </div>

        <div class="ai-auth-form-group-{{ ai_gen_id }}">
          <label for="ai-auth-guest-conditions-{{ ai_gen_id }}" class="ai-auth-form-label-{{ ai_gen_id }}">
            {{ block.settings.conditions_label }} <span class="ai-auth-required-{{ ai_gen_id }}">*</span>
          </label>
          <textarea
            id="ai-auth-guest-conditions-{{ ai_gen_id }}"
            name="contact[medical_conditions]"
            class="ai-auth-form-textarea-{{ ai_gen_id }}"
            required
          ></textarea>
        </div>

        <div class="ai-auth-form-group-{{ ai_gen_id }}">
          <label for="ai-auth-guest-medications-{{ ai_gen_id }}" class="ai-auth-form-label-{{ ai_gen_id }}">
            {{ block.settings.medications_label }}
          </label>
          <textarea
            id="ai-auth-guest-medications-{{ ai_gen_id }}"
            name="contact[current_medications]"
            class="ai-auth-form-textarea-{{ ai_gen_id }}"
          ></textarea>
        </div>

        <div class="ai-auth-form-group-{{ ai_gen_id }}">
          <label for="ai-auth-guest-allergies-{{ ai_gen_id }}" class="ai-auth-form-label-{{ ai_gen_id }}">
            {{ block.settings.allergies_label }}
          </label>
          <textarea
            id="ai-auth-guest-allergies-{{ ai_gen_id }}"
            name="contact[allergies]"
            class="ai-auth-form-textarea-{{ ai_gen_id }}"
          ></textarea>
        </div>

        {%- if form.posted_successfully? -%}
          <div class="ai-auth-status-message-{{ ai_gen_id }} success">
            {{ block.settings.success_message }}
          </div>
        {%- endif -%}

        <button type="submit" class="ai-auth-button-{{ ai_gen_id }}">
          {{ block.settings.submit_button_label }}
        </button>
      {%- endform -%}
    </div>
  {% endif %}
</medical-auth-form-{{ ai_gen_id }}>

<script>
  (function() {
    class MedicalAuthForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.isCustomerLoggedIn = this.dataset.customerLoggedIn === 'true';
        this.setupEventListeners();
      }

      setupEventListeners() {
        if (this.isCustomerLoggedIn) {
          this.setupCustomerFlow();
        } else {
          this.setupGuestFlow();
        }
      }

      setupCustomerFlow() {
        const checkbox = this.querySelector('#ai-auth-confirm-checkbox-{{ ai_gen_id }}');
        const medicalForm = this.querySelector('#ai-auth-medical-form-{{ ai_gen_id }}');

        if (checkbox && medicalForm) {
          checkbox.addEventListener('change', function() {
            if (!checkbox.checked) {
              medicalForm.classList.remove('hidden');
            } else {
              medicalForm.classList.add('hidden');
            }
          });
        }
      }

      setupGuestFlow() {
        const guestButton = this.querySelector('#ai-auth-guest-continue-{{ ai_gen_id }}');
        const guestForm = this.querySelector('#ai-auth-guest-form-{{ ai_gen_id }}');

        if (guestButton && guestForm) {
          guestButton.addEventListener('click', function() {
            guestForm.classList.remove('hidden');
            guestButton.style.display = 'none';
          });
        }
      }
    }

    customElements.define('medical-auth-form-{{ ai_gen_id }}', MedicalAuthForm{{ ai_gen_id }});
  })();
</script>

