<script>
(function() {
  class EligibilityForm{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.currentStep = 1;
      this.totalSteps = 8;
      this.formData = {};
      this.config = {
        minAge: {{ block.settings.min_age }},
        maxAge: {{ block.settings.max_age }},
        preferredHealthStatuses: {{ block.settings.preferred_health_statuses | json }},
        redFlagConditions: {{ block.settings.red_flag_conditions | json }},
        redFlagMedications: {{ block.settings.red_flag_medications | json }},
        approvedTitle: {{ block.settings.approved_title | json }},
        approvedMessage: {{ block.settings.approved_message | json }},
        reviewTitle: {{ block.settings.review_title | json }},
        reviewMessage: {{ block.settings.review_message | json }}
      };
    }

    connectedCallback() {
      this.form = this.querySelector('[data-eligibility-form]');
      this.steps = this.querySelectorAll('[data-step]');
      this.prevButton = this.querySelector('[data-prev-button]');
      this.nextButton = this.querySelector('[data-next-button]');
      this.progressFill = this.querySelector('[data-progress-fill]');
      this.progressText = this.querySelector('[data-progress-text]');
      this.resultSection = this.querySelector('[data-result]');
      this.resultIcon = this.querySelector('[data-result-icon]');
      this.resultTitle = this.querySelector('[data-result-title]');
      this.resultMessage = this.querySelector('[data-result-message]');
      this.checkoutButton = this.querySelector('[data-checkout-button]');
      this.approvedIcon = this.querySelector('[data-approved-icon]');
      this.reviewIcon = this.querySelector('[data-review-icon]');

      this.setupEventListeners();
      this.updateProgress();
    }

    setupEventListeners() {
      this.prevButton.addEventListener('click', () => this.goToPreviousStep());
      this.nextButton.addEventListener('click', () => this.goToNextStep());

      this.querySelectorAll('[data-radio-wrapper]').forEach(wrapper => {
        const radio = wrapper.querySelector('input[type="radio"]');
        radio.addEventListener('change', () => {
          this.querySelectorAll(`input[name="${radio.name}"]`).forEach(r => {
            r.closest('[data-radio-wrapper]').classList.remove('selected');
          });
          wrapper.classList.add('selected');
        });
      });

      this.querySelectorAll('[data-checkbox-wrapper]').forEach(wrapper => {
        const checkbox = wrapper.querySelector('input[type="checkbox"]');
        checkbox.addEventListener('change', () => {
          if (checkbox.checked) {
            wrapper.classList.add('selected');
          } else {
            wrapper.classList.remove('selected');
          }

          if (checkbox.hasAttribute('data-none-option')) {
            this.handleNoneOption(checkbox);
          } else if (checkbox.name === 'medical_conditions') {
            this.handleConditionChange();
          }
        });
      });

      const otherTrigger = this.querySelector('[data-other-trigger]');
      if (otherTrigger) {
        otherTrigger.addEventListener('change', () => {
          const otherInput = this.querySelector('[data-other-input]');
          if (otherTrigger.checked) {
            otherInput.classList.add('visible');
          } else {
            otherInput.classList.remove('visible');
            otherInput.querySelector('input').value = '';
          }
        });
      }
    }

    handleNoneOption(noneCheckbox) {
      const allCheckboxes = this.querySelectorAll('input[name="medical_conditions"]');
      if (noneCheckbox.checked) {
        allCheckboxes.forEach(cb => {
          if (cb !== noneCheckbox) {
            cb.checked = false;
            cb.closest('[data-checkbox-wrapper]').classList.remove('selected');
          }
        });
        const otherInput = this.querySelector('[data-other-input]');
        if (otherInput) {
          otherInput.classList.remove('visible');
          otherInput.querySelector('input').value = '';
        }
      }
    }

    handleConditionChange() {
      const noneCheckbox = this.querySelector('[data-none-option]');
      const otherCheckboxes = this.querySelectorAll('input[name="medical_conditions"]:not([data-none-option])');
      const anyOtherChecked = Array.from(otherCheckboxes).some(cb => cb.checked);
      
      if (anyOtherChecked && noneCheckbox) {
        noneCheckbox.checked = false;
        noneCheckbox.closest('[data-checkbox-wrapper]').classList.remove('selected');
      }
    }

    goToPreviousStep() {
      if (this.currentStep > 1) {
        this.currentStep--;
        this.updateStepDisplay();
        this.updateProgress();
      }
    }

    goToNextStep() {
      if (this.validateCurrentStep()) {
        this.saveCurrentStepData();
        
        if (this.currentStep < this.totalSteps) {
          this.currentStep++;
          this.updateStepDisplay();
          this.updateProgress();
        } else {
          this.submitForm();
        }
      }
    }

    validateCurrentStep() {
      const currentStepElement = this.querySelector(`[data-step="${this.currentStep}"]`);
      const errorElement = currentStepElement.querySelector('[data-error]');
      errorElement.classList.remove('visible');

      const requiredInputs = currentStepElement.querySelectorAll('input[required], select[required], textarea[required]');
      for (let input of requiredInputs) {
        if (!input.value || input.value.trim() === '') {
          errorElement.classList.add('visible');
          return false;
        }
      }

      const radioGroups = currentStepElement.querySelectorAll('input[type="radio"]');
      if (radioGroups.length > 0) {
        const radioName = radioGroups[0].name;
        const isChecked = currentStepElement.querySelector(`input[name="${radioName}"]:checked`);
        if (!isChecked) {
          errorElement.classList.add('visible');
          return false;
        }
      }

      const checkboxGroups = currentStepElement.querySelectorAll('input[type="checkbox"]:not([name="consent"])');
      if (checkboxGroups.length > 0 && this.currentStep === 3) {
        const isAnyChecked = Array.from(checkboxGroups).some(cb => cb.checked);
        if (!isAnyChecked) {
          errorElement.classList.add('visible');
          return false;
        }
      }

      return true;
    }

    saveCurrentStepData() {
      const currentStepElement = this.querySelector(`[data-step="${this.currentStep}"]`);
      const fields = currentStepElement.querySelectorAll('[data-field]');
      
      fields.forEach(field => {
        if (field.type === 'checkbox' && field.name === 'medical_conditions') {
          if (!this.formData.medical_conditions) {
            this.formData.medical_conditions = [];
          }
          if (field.checked && !this.formData.medical_conditions.includes(field.value)) {
            this.formData.medical_conditions.push(field.value);
          }
        } else if (field.type === 'radio') {
          if (field.checked) {
            this.formData[field.name] = field.value;
          }
        } else if (field.type === 'checkbox') {
          this.formData[field.name] = field.checked;
        } else {
          this.formData[field.name] = field.value;
        }
      });

      if (this.currentStep === 3) {
        this.formData.medical_conditions = [];
        const checkedConditions = currentStepElement.querySelectorAll('input[name="medical_conditions"]:checked');
        checkedConditions.forEach(cb => {
          this.formData.medical_conditions.push(cb.value);
        });
        const otherText = currentStepElement.querySelector('[name="medical_conditions_other"]');
        if (otherText && otherText.value) {
          this.formData.medical_conditions_other = otherText.value;
        }
      }
    }

    updateStepDisplay() {
      this.steps.forEach((step, index) => {
        if (index + 1 === this.currentStep) {
          step.classList.add('active');
        } else {
          step.classList.remove('active');
        }
      });

      this.prevButton.disabled = this.currentStep === 1;
      
      if (this.currentStep === this.totalSteps) {
        this.nextButton.textContent = 'Submit';
      } else {
        this.nextButton.textContent = 'Next';
      }
    }

    updateProgress() {
      const progress = (this.currentStep / this.totalSteps) * 100;
      this.progressFill.style.width = progress + '%';
      this.progressText.textContent = `Step ${this.currentStep} of ${this.totalSteps}`;
    }

    calculateAge(day, month, year) {
      const today = new Date();
      const birthDate = new Date(year, month - 1, day);
      let age = today.getFullYear() - birthDate.getFullYear();
      const monthDiff = today.getMonth() - birthDate.getMonth();
      if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
        age--;
      }
      return age;
    }

    evaluateEligibility() {
      const age = this.calculateAge(
        parseInt(this.formData.dob_day),
        parseInt(this.formData.dob_month),
        parseInt(this.formData.dob_year)
      );

      const redFlags = [];

      if (age < this.config.minAge || age > this.config.maxAge) {
        redFlags.push('age_out_of_range');
      }

      if (this.formData.health_status && !this.config.preferredHealthStatuses.includes(this.formData.health_status)) {
        redFlags.push('health_status');
      }

      if (this.formData.medical_conditions && Array.isArray(this.formData.medical_conditions)) {
        const hasRedFlagCondition = this.formData.medical_conditions.some(condition => 
          this.config.redFlagConditions.includes(condition)
        );
        if (hasRedFlagCondition || this.formData.medical_conditions.includes('Other')) {
          redFlags.push('medical_condition');
        }
      }

      if (this.formData.medications_allergies) {
        const medsLower = this.formData.medications_allergies.toLowerCase();
        const hasRedFlagMed = this.config.redFlagMedications.some(med => 
          medsLower.includes(med.toLowerCase())
        );
        if (hasRedFlagMed && medsLower !== 'none') {
          redFlags.push('medications');
        }
      }

      if (this.formData.pregnancy_breastfeeding === 'Yes') {
        redFlags.push('pregnancy');
      }

      if (this.formData.serious_reaction === 'Yes') {
        redFlags.push('serious_reaction');
      }

      return {
        approved: redFlags.length === 0,
        redFlags: redFlags,
        status: redFlags.length === 0 ? 'Auto-clear – Awaiting doctor signature' : 'Red flag – Doctor review required'
      };
    }

    submitForm() {
      const evaluation = this.evaluateEligibility();
      
      console.log('Form Data:', this.formData);
      console.log('Evaluation:', evaluation);

      this.form.style.display = 'none';
      this.querySelector('[data-progress]')?.remove();
      this.resultSection.classList.add('visible');

      if (evaluation.approved) {
        this.resultIcon.classList.add('approved');
        this.approvedIcon.style.display = 'block';
        this.reviewIcon.style.display = 'none';
        this.resultTitle.textContent = this.config.approvedTitle;
        this.resultMessage.textContent = this.config.approvedMessage;
        this.checkoutButton.style.display = 'inline-block';
      } else {
        this.resultIcon.classList.add('review');
        this.approvedIcon.style.display = 'none';
        this.reviewIcon.style.display = 'block';
        this.resultTitle.textContent = this.config.reviewTitle;
        this.resultMessage.textContent = this.config.reviewMessage;
        this.checkoutButton.style.display = 'none';
      }
    }
  }

  customElements.define('eligibility-form-{{ ai_gen_id }}', EligibilityForm{{ ai_gen_id }});
})();
</script>

