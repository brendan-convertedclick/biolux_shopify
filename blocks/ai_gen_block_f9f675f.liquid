{% doc %}
  @prompt
    A toggle button that asks the user if the provided information is still the same. Below the toggle, there will be 2 buttons: one that says "Proceed to Checkout" if the toggle button is "Yes," and another that says "Update Medical Check." if customer is sign in if not show sign in and hide the toggle  and proceed to check out button, open sign in in new tap.  If customer already signed in hide sign in button, control section alignment. Add instruction above button that states user needs to sign in to be able to check out an d make sure that the Medical check form was submitted. check customer tags if there is red flag or green flag all to add ctom message for either. If there are no tags show message " Please submit the  medical check form. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-checkout-gate-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.alignment }};
  }

  .ai-checkout-gate__instruction-{{ ai_gen_id }} {
    font-size: {{ block.settings.instruction_font_size }}px;
    color: {{ block.settings.text_color }};
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .ai-checkout-gate__message-{{ ai_gen_id }} {
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: {{ block.settings.message_font_size }}px;
    line-height: 1.5;
  }

  .ai-checkout-gate__message--success-{{ ai_gen_id }} {
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
  }

  .ai-checkout-gate__message--warning-{{ ai_gen_id }} {
    background-color: {{ block.settings.warning_bg_color }};
    color: {{ block.settings.warning_text_color }};
  }

  .ai-checkout-gate__message--error-{{ ai_gen_id }} {
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
  }

  .ai-checkout-gate__toggle-wrapper-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-checkout-gate__toggle-label-{{ ai_gen_id }} {
    display: block;
    font-size: {{ block.settings.toggle_label_size }}px;
    color: {{ block.settings.text_color }};
    margin-bottom: 12px;
    font-weight: 600;
  }

  .ai-checkout-gate__toggle-options-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    justify-content: {{ block.settings.alignment }};
  }

  .ai-checkout-gate__toggle-button-{{ ai_gen_id }} {
    padding: 12px 32px;
    border: 2px solid {{ block.settings.toggle_border_color }};
    background-color: {{ block.settings.toggle_bg_color }};
    color: {{ block.settings.toggle_text_color }};
    border-radius: {{ block.settings.toggle_border_radius }}px;
    cursor: pointer;
    font-size: {{ block.settings.toggle_font_size }}px;
    transition: all 0.3s ease;
  }

  .ai-checkout-gate__toggle-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.toggle_hover_bg_color }};
    border-color: {{ block.settings.toggle_hover_border_color }};
  }

  .ai-checkout-gate__toggle-button-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.toggle_active_bg_color }};
    border-color: {{ block.settings.toggle_active_border_color }};
    color: {{ block.settings.toggle_active_text_color }};
  }

  .ai-checkout-gate__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: {{ block.settings.alignment }};
  }

  .ai-checkout-gate__button-{{ ai_gen_id }} {
    padding: 16px 40px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: all 0.3s ease;
    text-align: center;
  }

  .ai-checkout-gate__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg_color }};
    color: {{ block.settings.primary_button_text_color }};
  }

  .ai-checkout-gate__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg_color }};
  }

  .ai-checkout-gate__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_bg_color }};
    color: {{ block.settings.secondary_button_text_color }};
  }

  .ai-checkout-gate__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_bg_color }};
  }

  .ai-checkout-gate__button--signin-{{ ai_gen_id }} {
    background-color: {{ block.settings.signin_button_bg_color }};
    color: {{ block.settings.signin_button_text_color }};
  }

  .ai-checkout-gate__button--signin-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.signin_button_hover_bg_color }};
  }

  .ai-checkout-gate__hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-checkout-gate__toggle-options-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-checkout-gate__buttons-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-checkout-gate__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<checkout-gate-{{ ai_gen_id }}
  class="ai-checkout-gate-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-customer-logged-in="{% if customer %}true{% else %}false{% endif %}"
  data-customer-tags="{{ customer.tags | join: ',' }}"
>
  {% if customer %}
    {% assign has_green_flag = false %}
    {% assign has_red_flag = false %}
    {% assign has_any_tag = false %}

    {% for tag in customer.tags %}
      {% if tag contains 'green' or tag contains 'Green' or tag contains 'auto-clear' or tag contains 'Auto-Clear' %}
        {% assign has_green_flag = true %}
        {% assign has_any_tag = true %}
      {% endif %}
      {% if tag contains 'red' or tag contains 'Red' or tag contains 'flag' or tag contains 'Flag' %}
        {% assign has_red_flag = true %}
        {% assign has_any_tag = true %}
      {% endif %}
    {% endfor %}

    {% if has_green_flag %}
      <div class="ai-checkout-gate__message-{{ ai_gen_id }} ai-checkout-gate__message--success-{{ ai_gen_id }}">
        {{ block.settings.green_flag_message }}
      </div>
    {% elsif has_red_flag %}
      <div class="ai-checkout-gate__message-{{ ai_gen_id }} ai-checkout-gate__message--warning-{{ ai_gen_id }}">
        {{ block.settings.red_flag_message }}
      </div>
    {% elsif has_any_tag == false %}
      <div class="ai-checkout-gate__message-{{ ai_gen_id }} ai-checkout-gate__message--error-{{ ai_gen_id }}">
        {{ block.settings.no_tag_message }}
      </div>
    {% endif %}

    {% if has_green_flag or has_red_flag %}
      <div class="ai-checkout-gate__toggle-wrapper-{{ ai_gen_id }}">
        <label class="ai-checkout-gate__toggle-label-{{ ai_gen_id }}">
          {{ block.settings.toggle_question }}
        </label>
        <div class="ai-checkout-gate__toggle-options-{{ ai_gen_id }}">
          <button
            type="button"
            class="ai-checkout-gate__toggle-button-{{ ai_gen_id }}"
            data-toggle-value="yes"
          >
            {{ block.settings.toggle_yes_text }}
          </button>
          <button
            type="button"
            class="ai-checkout-gate__toggle-button-{{ ai_gen_id }}"
            data-toggle-value="no"
          >
            {{ block.settings.toggle_no_text }}
          </button>
        </div>
      </div>

      <div class="ai-checkout-gate__buttons-{{ ai_gen_id }}">
        <a
          href="/checkout"
          class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--primary-{{ ai_gen_id }} ai-checkout-gate__hidden-{{ ai_gen_id }}"
          data-checkout-button
        >
          {{ block.settings.proceed_button_text }}
        </a>
        <a
          href="{{ block.settings.update_form_url }}"
          class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--secondary-{{ ai_gen_id }}"
        >
          {{ block.settings.update_button_text }}
        </a>
      </div>
    {% endif %}
  {% else %}
    <div class="ai-checkout-gate__instruction-{{ ai_gen_id }}">
      {{ block.settings.signin_instruction }}
    </div>
    <div class="ai-checkout-gate__buttons-{{ ai_gen_id }}">
      <a
        href="/account/login"
        target="_blank"
        class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--signin-{{ ai_gen_id }}"
      >
        {{ block.settings.signin_button_text }}
      </a>
    </div>
  {% endif %}
</checkout-gate-{{ ai_gen_id }}>

<script>
  (function() {
    class CheckoutGate{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.toggleButtons = this.querySelectorAll('.ai-checkout-gate__toggle-button-{{ ai_gen_id }}');
        this.checkoutButton = this.querySelector('[data-checkout-button]');
        this.selectedValue = null;
      }

      connectedCallback() {
        this.setupToggle();
      }

      setupToggle() {
        this.toggleButtons.forEach((button) => {
          button.addEventListener('click', () => {
            this.toggleButtons.forEach((btn) => btn.classList.remove('active'));
            button.classList.add('active');
            this.selectedValue = button.getAttribute('data-toggle-value');

            if (this.selectedValue === 'yes' && this.checkoutButton) {
              this.checkoutButton.classList.remove('ai-checkout-gate__hidden-{{ ai_gen_id }}');
            } else if (this.checkoutButton) {
              this.checkoutButton.classList.add('ai-checkout-gate__hidden-{{ ai_gen_id }}');
            }
          });
        });
      }
    }

    customElements.define('checkout-gate-{{ ai_gen_id }}', CheckoutGate{{ ai_gen_id }});
  })();
</script>

