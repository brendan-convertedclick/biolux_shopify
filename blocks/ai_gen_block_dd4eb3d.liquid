{% doc %}
  @prompt
    collection carousel,  allow selection of collections and a custom image for each view and show 3-5 per view. , I have total of 9 collections add autoplay and pause on hover 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-carousel-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    position: relative;
    overflow: hidden;
    display: block;
  }

  .ai-collection-carousel__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-collection-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-collection-carousel__slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.items_per_view_desktop | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.items_per_view_desktop }});
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-collection-carousel__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
  }

  .ai-collection-carousel__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-collection-carousel__slide-{{ ai_gen_id }}:hover .ai-collection-carousel__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-collection-carousel__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-carousel__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collection-carousel__overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.overlay_padding }}px;
    background: {{ block.settings.overlay_background }};
    color: {{ block.settings.overlay_text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-collection-carousel__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0 0 4px;
    text-transform: {{ block.settings.title_transform }};
  }

  .ai-collection-carousel__count-{{ ai_gen_id }} {
    font-size: {{ block.settings.count_size }}px;
    margin: 0;
    opacity: 0.9;
  }

  .ai-collection-carousel__link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-collection-carousel__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: {{ block.settings.controls_spacing }}px;
  }

  .ai-collection-carousel__button-{{ ai_gen_id }} {
    width: {{ block.settings.button_size }}px;
    height: {{ block.settings.button_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-collection-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_color }};
  }

  .ai-collection-carousel__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-collection-carousel__button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-collection-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-collection-carousel__dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-collection-carousel__dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-carousel__slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.items_per_view_mobile | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.items_per_view_mobile }});
    }

    .ai-collection-carousel__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-collection-carousel__count-{{ ai_gen_id }} {
      font-size: {{ block.settings.count_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<collection-carousel-{{ ai_gen_id }}
  class="ai-collection-carousel-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  data-items-desktop="{{ block.settings.items_per_view_desktop }}"
  data-items-mobile="{{ block.settings.items_per_view_mobile }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collection-carousel__wrapper-{{ ai_gen_id }}">
    <div class="ai-collection-carousel__track-{{ ai_gen_id }}">
      {% for i in (1..9) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign image_key = 'collection_image_' | append: i
          assign collection = block.settings[collection_key]
          assign custom_image = block.settings[image_key]
        %}

        {% if collection != blank %}
          <div class="ai-collection-carousel__slide-{{ ai_gen_id }}">
            <div class="ai-collection-carousel__image-wrapper-{{ ai_gen_id }}">
              {% if custom_image != blank %}
                <img
                  src="{{ custom_image | image_url: width: 800 }}"
                  alt="{{ custom_image.alt | default: collection.title | escape }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                  class="ai-collection-carousel__image-{{ ai_gen_id }}"
                >
              {% elsif collection.image %}
                <img
                  src="{{ collection.image | image_url: width: 800 }}"
                  alt="{{ collection.image.alt | default: collection.title | escape }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                  class="ai-collection-carousel__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-collection-carousel__placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if block.settings.show_overlay %}
                <div class="ai-collection-carousel__overlay-{{ ai_gen_id }}">
                  <h3 class="ai-collection-carousel__title-{{ ai_gen_id }}">{{ collection.title }}</h3>
                  {% if block.settings.show_product_count %}
                    <p class="ai-collection-carousel__count-{{ ai_gen_id }}">
                      {{ collection.products_count }}
                      {% if collection.products_count == 1 %}
                        {{ block.settings.product_label }}
                      {% else %}
                        {{ block.settings.products_label }}
                      {% endif %}
                    </p>
                  {% endif %}
                </div>
              {% endif %}

              <a
                href="{{ collection.url }}"
                class="ai-collection-carousel__link-{{ ai_gen_id }}"
                aria-label="{{ collection.title }}"
              ></a>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="ai-collection-carousel__controls-{{ ai_gen_id }}">
    <button
      class="ai-collection-carousel__button-{{ ai_gen_id }} ai-collection-carousel__prev-{{ ai_gen_id }}"
      aria-label="Previous slide"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <div class="ai-collection-carousel__dots-{{ ai_gen_id }}"></div>

    <button
      class="ai-collection-carousel__button-{{ ai_gen_id }} ai-collection-carousel__next-{{ ai_gen_id }}"
      aria-label="Next slide"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</collection-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayInterval = null;
        this.isPaused = false;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-collection-carousel__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-collection-carousel__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-collection-carousel__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-collection-carousel__next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-collection-carousel__dots-{{ ai_gen_id }}');

        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) || 3000;
        this.itemsDesktop = parseInt(this.dataset.itemsDesktop) || 3;
        this.itemsMobile = parseInt(this.dataset.itemsMobile) || 1;

        this.totalSlides = this.slides.length;
        this.itemsPerView = window.innerWidth > 749 ? this.itemsDesktop : this.itemsMobile;
        this.totalPages = Math.ceil(this.totalSlides / this.itemsPerView);

        this.init();
      }

      init() {
        this.createDots();
        this.updateCarousel();
        this.setupEventListeners();

        if (this.autoplay) {
          this.startAutoplay();
        }
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        for (let i = 0; i < this.totalPages; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-collection-carousel__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          if (i === 0) dot.classList.add('active');
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());

        this.addEventListener('mouseenter', () => {
          if (this.autoplay) {
            this.pauseAutoplay();
          }
        });

        this.addEventListener('mouseleave', () => {
          if (this.autoplay && this.isPaused) {
            this.startAutoplay();
          }
        });

        window.addEventListener('resize', () => {
          const newItemsPerView = window.innerWidth > 749 ? this.itemsDesktop : this.itemsMobile;
          if (newItemsPerView !== this.itemsPerView) {
            this.itemsPerView = newItemsPerView;
            this.totalPages = Math.ceil(this.totalSlides / this.itemsPerView);
            this.currentIndex = 0;
            this.createDots();
            this.updateCarousel();
          }
        });
      }

      updateCarousel() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        const offset = -(this.currentIndex * this.itemsPerView * (slideWidth + gap));

        this.track.style.transform = `translateX(${offset}px)`;

        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= this.totalPages - 1;

        const dots = this.dotsContainer.querySelectorAll('.ai-collection-carousel__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === this.currentIndex);
        });
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateCarousel();
        }
      }

      next() {
        if (this.currentIndex < this.totalPages - 1) {
          this.currentIndex++;
          this.updateCarousel();
        } else if (this.autoplay) {
          this.currentIndex = 0;
          this.updateCarousel();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateCarousel();
      }

      startAutoplay() {
        this.isPaused = false;
        this.autoplayInterval = setInterval(() => {
          this.next();
        }, this.autoplaySpeed);
      }

      pauseAutoplay() {
        this.isPaused = true;
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('collection-carousel-{{ ai_gen_id }}', CollectionCarousel{{ ai_gen_id }});
  })();
</script>

