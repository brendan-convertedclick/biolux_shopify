{% doc %}
  @prompt
    a carousel view of collection show the title on the image and it show be clickable to the collection page, the carousel view should have 3-5 cards per view, add auto play and pause on hover
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-collection-carousel__wrapper-{{ ai_gen_id }} {
    position: relative;
    padding: 0 50px;
  }

  .ai-collection-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-collection-carousel__track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-collection-carousel__card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.cards_per_view_desktop | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_view_desktop }});
    position: relative;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    aspect-ratio: {{ block.settings.card_aspect_ratio }};
  }

  .ai-collection-carousel__link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-carousel__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    position: relative;
    background-color: #f4f4f4;
  }

  .ai-collection-carousel__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-collection-carousel__link-{{ ai_gen_id }}:hover .ai-collection-carousel__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-collection-carousel__image-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-carousel__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    transition: opacity 0.3s ease;
  }

  .ai-collection-carousel__link-{{ ai_gen_id }}:hover .ai-collection-carousel__overlay-{{ ai_gen_id }} {
    opacity: {{ block.settings.overlay_opacity_hover }};
  }

  .ai-collection-carousel__content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: {{ block.settings.content_padding }}px;
    z-index: 2;
  }

  .ai-collection-carousel__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0;
    text-transform: {{ block.settings.title_transform }};
    letter-spacing: 0.05em;
  }

  .ai-collection-carousel__count-{{ ai_gen_id }} {
    color: {{ block.settings.count_color }};
    font-size: {{ block.settings.count_size }}px;
    margin-top: 4px;
  }

  .ai-collection-carousel__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    background-color: {{ block.settings.nav_button_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: background-color 0.3s ease;
  }

  .ai-collection-carousel__nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_color }};
  }

  .ai-collection-carousel__nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: {{ block.settings.nav_icon_color }};
  }

  .ai-collection-carousel__nav--prev-{{ ai_gen_id }} {
    left: 0;
  }

  .ai-collection-carousel__nav--next-{{ ai_gen_id }} {
    right: 0;
  }

  .ai-collection-carousel__nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-collection-carousel__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #666;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-carousel__wrapper-{{ ai_gen_id }} {
      padding: 0 40px;
    }

    .ai-collection-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.cards_per_view_mobile | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_view_mobile }});
    }

    .ai-collection-carousel__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-collection-carousel__count-{{ ai_gen_id }} {
      font-size: {{ block.settings.count_size | times: 0.85 }}px;
    }

    .ai-collection-carousel__nav-{{ ai_gen_id }} {
      width: 32px;
      height: 32px;
    }

    .ai-collection-carousel__nav-{{ ai_gen_id }} svg {
      width: 16px;
      height: 16px;
    }
  }
{% endstyle %}

<collection-carousel-{{ ai_gen_id }} class="ai-collection-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.collections != blank %}
    <div class="ai-collection-carousel__wrapper-{{ ai_gen_id }}">
      <button
        class="ai-collection-carousel__nav-{{ ai_gen_id }} ai-collection-carousel__nav--prev-{{ ai_gen_id }}"
        aria-label="Previous"
        data-direction="prev"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <div class="ai-collection-carousel__track-{{ ai_gen_id }}">
        {% for collection in block.settings.collections %}
          <div class="ai-collection-carousel__card-{{ ai_gen_id }}">
            <a href="{{ collection.url }}" class="ai-collection-carousel__link-{{ ai_gen_id }}">
              <div class="ai-collection-carousel__image-wrapper-{{ ai_gen_id }}">
                {% if collection.featured_image %}
                  <img
                    src="{{ collection.featured_image | image_url: width: 800 }}"
                    alt="{{ collection.featured_image.alt | escape }}"
                    class="ai-collection-carousel__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="800"
                    height="800"
                  >
                {% else %}
                  {{ 'collection-1' | placeholder_svg_tag }}
                {% endif %}
                <div class="ai-collection-carousel__overlay-{{ ai_gen_id }}"></div>
              </div>
              <div class="ai-collection-carousel__content-{{ ai_gen_id }}">
                <h3 class="ai-collection-carousel__title-{{ ai_gen_id }}">{{ collection.title }}</h3>
                {% if block.settings.show_product_count %}
                  <div class="ai-collection-carousel__count-{{ ai_gen_id }}">
                    {{ collection.products_count }}
                    {% if collection.products_count == 1 %}
                      product
                    {% else %}
                      products
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      <button
        class="ai-collection-carousel__nav-{{ ai_gen_id }} ai-collection-carousel__nav--next-{{ ai_gen_id }}"
        aria-label="Next"
        data-direction="next"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  {% else %}
    <div class="ai-collection-carousel__empty-{{ ai_gen_id }}">
      Next, select collections to display in the carousel
    </div>
  {% endif %}
</collection-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = null;
        this.prevButton = null;
        this.nextButton = null;
        this.cardWidth = 0;
        this.scrollAmount = 0;
        this.autoplayInterval = null;
        this.isHovered = false;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-collection-carousel__track-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-collection-carousel__nav--prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-collection-carousel__nav--next-{{ ai_gen_id }}');

        if (!this.track || !this.prevButton || !this.nextButton) return;

        this.setupEventListeners();
        this.updateButtonStates();
        this.calculateScrollAmount();

        {% if block.settings.enable_autoplay %}
          this.startAutoplay();
        {% endif %}

        window.addEventListener('resize', () => {
          this.calculateScrollAmount();
          this.updateButtonStates();
        });
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }

      calculateScrollAmount() {
        const card = this.track.querySelector('.ai-collection-carousel__card-{{ ai_gen_id }}');
        if (card) {
          const gap = {{ block.settings.card_gap }};
          this.cardWidth = card.offsetWidth;
          this.scrollAmount = this.cardWidth + gap;
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => {
          this.scroll('prev');
          this.resetAutoplay();
        });

        this.nextButton.addEventListener('click', () => {
          this.scroll('next');
          this.resetAutoplay();
        });

        this.track.addEventListener('scroll', () => this.updateButtonStates());

        this.addEventListener('mouseenter', () => {
          this.isHovered = true;
          {% if block.settings.pause_on_hover %}
            this.stopAutoplay();
          {% endif %}
        });

        this.addEventListener('mouseleave', () => {
          this.isHovered = false;
          {% if block.settings.pause_on_hover and block.settings.enable_autoplay %}
            this.startAutoplay();
          {% endif %}
        });
      }

      scroll(direction) {
        const scrollLeft = this.track.scrollLeft;
        const maxScroll = this.track.scrollWidth - this.track.clientWidth;

        let newScrollLeft;

        if (direction === 'next') {
          if (scrollLeft >= maxScroll - 1) {
            newScrollLeft = 0;
          } else {
            newScrollLeft = scrollLeft + this.scrollAmount;
          }
        } else {
          if (scrollLeft <= 0) {
            newScrollLeft = maxScroll;
          } else {
            newScrollLeft = scrollLeft - this.scrollAmount;
          }
        }

        this.track.scrollTo({
          left: newScrollLeft,
          behavior: 'smooth'
        });
      }

      updateButtonStates() {
        const scrollLeft = this.track.scrollLeft;
        const maxScroll = this.track.scrollWidth - this.track.clientWidth;

        this.prevButton.disabled = scrollLeft <= 0;
        this.nextButton.disabled = scrollLeft >= maxScroll - 1;
      }

      startAutoplay() {
        if (this.autoplayInterval) return;

        this.autoplayInterval = setInterval(() => {
          if (!this.isHovered) {
            this.scroll('next');
          }
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        {% if block.settings.enable_autoplay %}
          this.stopAutoplay();
          if (!this.isHovered) {
            this.startAutoplay();
          }
        {% endif %}
      }
    }

    customElements.define('collection-carousel-{{ ai_gen_id }}', CollectionCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Collection carousel",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "collection_list",
      "id": "collections",
      "label": "Collections",
      "limit": 12
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "cards_per_view_desktop",
      "label": "Cards per view (desktop)",
      "min": 3,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "cards_per_view_mobile",
      "label": "Cards per view (mobile)",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "card_aspect_ratio",
      "label": "Card aspect ratio",
      "options": [
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "16/9",
          "label": "Wide (16:9)"
        }
      ],
      "default": "4/3"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "range",
      "id": "overlay_opacity_hover",
      "label": "Overlay opacity (hover)",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.5
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "title_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
