{% doc %}
  @prompt
    add the product metafields
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-metafields-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-product-metafields__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing }}px 0;
    text-transform: {{ block.settings.title_transform }};
  }

  .ai-product-metafields__list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ai-product-metafields__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout }};
    gap: {{ block.settings.item_gap }}px;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background }};
    border-radius: {{ block.settings.item_border_radius }}px;
    border: 1px solid {{ block.settings.item_border_color }};
  }

  .ai-product-metafields__label-{{ ai_gen_id }} {
    font-weight: {{ block.settings.label_weight }};
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    {% if block.settings.layout == 'row' %}
      min-width: {{ block.settings.label_width }}px;
    {% endif %}
  }

  .ai-product-metafields__value-{{ ai_gen_id }} {
    color: {{ block.settings.value_color }};
    font-size: {{ block.settings.value_size }}px;
    flex: 1;
  }

  .ai-product-metafields__empty-{{ ai_gen_id }} {
    color: {{ block.settings.label_color }};
    opacity: 0.6;
    font-style: italic;
    padding: {{ block.settings.padding }}px;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .ai-product-metafields-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-product-metafields__item-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-product-metafields__label-{{ ai_gen_id }} {
      min-width: auto;
    }
  }
{% endstyle %}

<product-metafields-{{ ai_gen_id }}
  class="ai-product-metafields-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% liquid
    assign has_metafields = false
    assign metafield_1 = product.metafields[block.settings.metafield_1_namespace][block.settings.metafield_1_key]
    assign metafield_2 = product.metafields[block.settings.metafield_2_namespace][block.settings.metafield_2_key]
    assign metafield_3 = product.metafields[block.settings.metafield_3_namespace][block.settings.metafield_3_key]
    assign metafield_4 = product.metafields[block.settings.metafield_4_namespace][block.settings.metafield_4_key]
    assign metafield_5 = product.metafields[block.settings.metafield_5_namespace][block.settings.metafield_5_key]

    if metafield_1 != blank or metafield_2 != blank or metafield_3 != blank or metafield_4 != blank or metafield_5 != blank
      assign has_metafields = true
    endif
  %}

  {% if has_metafields %}
    {% if block.settings.title != blank %}
      <h3 class="ai-product-metafields__title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
    {% endif %}

    <ul class="ai-product-metafields__list-{{ ai_gen_id }}">
      {% if metafield_1 != blank and block.settings.metafield_1_label != blank %}
        <li class="ai-product-metafields__item-{{ ai_gen_id }}">
          <span class="ai-product-metafields__label-{{ ai_gen_id }}">{{ block.settings.metafield_1_label }}</span>
          <span class="ai-product-metafields__value-{{ ai_gen_id }}">{{ metafield_1 }}</span>
        </li>
      {% endif %}

      {% if metafield_2 != blank and block.settings.metafield_2_label != blank %}
        <li class="ai-product-metafields__item-{{ ai_gen_id }}">
          <span class="ai-product-metafields__label-{{ ai_gen_id }}">{{ block.settings.metafield_2_label }}</span>
          <span class="ai-product-metafields__value-{{ ai_gen_id }}">{{ metafield_2 }}</span>
        </li>
      {% endif %}

      {% if metafield_3 != blank and block.settings.metafield_3_label != blank %}
        <li class="ai-product-metafields__item-{{ ai_gen_id }}">
          <span class="ai-product-metafields__label-{{ ai_gen_id }}">{{ block.settings.metafield_3_label }}</span>
          <span class="ai-product-metafields__value-{{ ai_gen_id }}">{{ metafield_3 }}</span>
        </li>
      {% endif %}

      {% if metafield_4 != blank and block.settings.metafield_4_label != blank %}
        <li class="ai-product-metafields__item-{{ ai_gen_id }}">
          <span class="ai-product-metafields__label-{{ ai_gen_id }}">{{ block.settings.metafield_4_label }}</span>
          <span class="ai-product-metafields__value-{{ ai_gen_id }}">{{ metafield_4 }}</span>
        </li>
      {% endif %}

      {% if metafield_5 != blank and block.settings.metafield_5_label != blank %}
        <li class="ai-product-metafields__item-{{ ai_gen_id }}">
          <span class="ai-product-metafields__label-{{ ai_gen_id }}">{{ block.settings.metafield_5_label }}</span>
          <span class="ai-product-metafields__value-{{ ai_gen_id }}">{{ metafield_5 }}</span>
        </li>
      {% endif %}
    </ul>
  {% else %}
    <div class="ai-product-metafields__empty-{{ ai_gen_id }}">
      Configure metafields in the block settings
    </div>
  {% endif %}
</product-metafields-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductMetafields{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('product-metafields-{{ ai_gen_id }}', ProductMetafields{{ ai_gen_id }});
  })();
</script>

