{% doc %}
  @prompt
    A toggle button that asks the user if the provided information is still the same. Below the toggle, there will be 22 buttons: one that says "Proceed to Checkout" if the toggle button is "Yes," and another that says "Update Medical Check." if customer is sign in if not show sign in and hide the toggle  and proceed to check out button, open sign in in new tap.  If customer already signed in hide sign in button, control section alignment. Add instruction above button that states user needs to sign in to be able to check out an d make sure that the Medical check form was submitted
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-checkout-gate-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.alignment }};
  }

  .ai-checkout-gate__instruction-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.instruction_font_size }}px;
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .ai-checkout-gate__toggle-section-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-checkout-gate__toggle-label-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.label_font_size }}px;
    margin-bottom: 12px;
    font-weight: 600;
  }

  .ai-checkout-gate__toggle-wrapper-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: {{ block.settings.toggle_background }};
    padding: 8px 16px;
    border-radius: {{ block.settings.toggle_border_radius }}px;
    border: 1px solid {{ block.settings.toggle_border_color }};
  }

  .ai-checkout-gate__toggle-option-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
  }

  .ai-checkout-gate__toggle-input-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    cursor: pointer;
    accent-color: {{ block.settings.toggle_active_color }};
  }

  .ai-checkout-gate__toggle-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.toggle_font_size }}px;
    cursor: pointer;
  }

  .ai-checkout-gate__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: {{ block.settings.alignment }};
  }

  .ai-checkout-gate__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    cursor: pointer;
    transition: background-color 0.3s ease;
    text-transform: {{ block.settings.button_text_transform }};
    font-weight: 600;
  }

  .ai-checkout-gate__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-checkout-gate__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_background }};
    color: {{ block.settings.secondary_button_text_color }};
  }

  .ai-checkout-gate__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_background }};
  }

  .ai-checkout-gate__hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-checkout-gate-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<checkout-gate-{{ ai_gen_id }}
  class="ai-checkout-gate-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-signed-in="{% if customer %}true{% else %}false{% endif %}"
>
  <div class="ai-checkout-gate__instruction-{{ ai_gen_id }}">
    {{ block.settings.instruction_text }}
  </div>

  {% if customer %}
    <div class="ai-checkout-gate__toggle-section-{{ ai_gen_id }}" data-toggle-section>
      <label class="ai-checkout-gate__toggle-label-{{ ai_gen_id }}">
        {{ block.settings.toggle_question }}
      </label>
      <div class="ai-checkout-gate__toggle-wrapper-{{ ai_gen_id }}">
        <label class="ai-checkout-gate__toggle-option-{{ ai_gen_id }}">
          <input
            type="radio"
            name="info-same-{{ ai_gen_id }}"
            value="yes"
            class="ai-checkout-gate__toggle-input-{{ ai_gen_id }}"
            checked
          >
          <span class="ai-checkout-gate__toggle-text-{{ ai_gen_id }}">{{ block.settings.toggle_yes_text }}</span>
        </label>
        <label class="ai-checkout-gate__toggle-option-{{ ai_gen_id }}">
          <input
            type="radio"
            name="info-same-{{ ai_gen_id }}"
            value="no"
            class="ai-checkout-gate__toggle-input-{{ ai_gen_id }}"
          >
          <span class="ai-checkout-gate__toggle-text-{{ ai_gen_id }}">{{ block.settings.toggle_no_text }}</span>
        </label>
      </div>
    </div>
  {% endif %}

  <div class="ai-checkout-gate__buttons-{{ ai_gen_id }}">
    {% unless customer %}
      <a
        href="{{ routes.account_login_url }}"
        target="_blank"
        class="ai-checkout-gate__button-{{ ai_gen_id }}"
        data-signin-button
      >
        {{ block.settings.signin_button_text }}
      </a>
    {% endunless %}

    {% if customer %}
      <a
        href="/checkout"
        class="ai-checkout-gate__button-{{ ai_gen_id }}"
        data-checkout-button
      >
        {{ block.settings.checkout_button_text }}
      </a>

      <a
        href="{{ block.settings.update_form_url }}"
        class="ai-checkout-gate__button-{{ ai_gen_id }} ai-checkout-gate__button--secondary-{{ ai_gen_id }} ai-checkout-gate__hidden-{{ ai_gen_id }}"
        data-update-button
      >
        {{ block.settings.update_button_text }}
      </a>
    {% endif %}
  </div>
</checkout-gate-{{ ai_gen_id }}>

<script>
  (function() {
    class CheckoutGate{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.isSignedIn = this.dataset.signedIn === 'true';
        
        if (this.isSignedIn) {
          this.toggleInputs = this.querySelectorAll('input[name="info-same-{{ ai_gen_id }}"]');
          this.checkoutButton = this.querySelector('[data-checkout-button]');
          this.updateButton = this.querySelector('[data-update-button]');
          
          this.setupEventListeners();
        }
      }

      setupEventListeners() {
        this.toggleInputs.forEach((input) => {
          input.addEventListener('change', () => {
            this.handleToggleChange();
          });
        });
      }

      handleToggleChange() {
        const selectedValue = this.querySelector('input[name="info-same-{{ ai_gen_id }}"]:checked').value;
        
        if (selectedValue === 'yes') {
          this.checkoutButton.classList.remove('ai-checkout-gate__hidden-{{ ai_gen_id }}');
          this.updateButton.classList.add('ai-checkout-gate__hidden-{{ ai_gen_id }}');
        } else {
          this.checkoutButton.classList.add('ai-checkout-gate__hidden-{{ ai_gen_id }}');
          this.updateButton.classList.remove('ai-checkout-gate__hidden-{{ ai_gen_id }}');
        }
      }
    }

    customElements.define('checkout-gate-{{ ai_gen_id }}', CheckoutGate{{ ai_gen_id }});
  })();
</script>

