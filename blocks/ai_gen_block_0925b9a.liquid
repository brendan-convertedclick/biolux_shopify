        {{ block.settings.q7_serious_reaction }}
        <span class="ai-eligibility-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <div class="ai-eligibility-form__radio-group-{{ ai_gen_id }}">
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="serious_reaction" value="Yes" data-field="serious_reaction" required>
          <span>{{ block.settings.q7_option_1 }}</span>
        </label>
