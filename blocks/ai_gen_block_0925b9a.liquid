<script>
  (function() {
    class EligibilityForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentStep = 'auth';
        this.totalSteps = 8;
        this.formData = {};
        this.isCustomer = {{ customer | json }} !== null;
      }

      connectedCallback() {
        this.progressFill = this.querySelector('[data-progress-fill]');
        this.progressText = this.querySelector('[data-progress-text]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.navigation = this.querySelector('[data-navigation]');
        this.guestButton = this.querySelector('[data-guest-continue]');
        this.sameAnswersCheckbox = this.querySelector('[data-same-answers]');

        this.setupEventListeners();
        this.updateProgress();
      }

      setupEventListeners() {
        if (this.guestButton) {
          this.guestButton.addEventListener('click', () => this.handleGuestContinue());
        }

        if (this.sameAnswersCheckbox) {
          this.sameAnswersCheckbox.addEventListener('change', (e) => {
            if (!e.target.checked) {
              this.goToStep(1);
            }
          });
        }

        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousStep());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextStep());
        }

        this.querySelectorAll('[data-field="medical_conditions"]').forEach(checkbox => {
          checkbox.addEventListener('change', (e) => this.handleMedicalConditions(e));
        });

        this.querySelectorAll('input[type="radio"]').forEach(radio => {
          radio.addEventListener('change', (e) => {
            const parent = e.target.closest('.ai-eligibility-form__radio-option-{{ ai_gen_id }}');
            if (parent) {
              parent.parentElement.querySelectorAll('.ai-eligibility-form__radio-option-{{ ai_gen_id }}').forEach(opt => {
                opt.classList.remove('selected');
              });
              parent.classList.add('selected');
            }
          });
        });

        this.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
          checkbox.addEventListener('change', (e) => {
            const parent = e.target.closest('.ai-eligibility-form__checkbox-option-{{ ai_gen_id }}');
            if (parent) {
              if (e.target.checked) {
                parent.classList.add('selected');
              } else {
                parent.classList.remove('selected');
              }
            }
          });
        });
      }

      handleGuestContinue() {
        this.goToStep(1);
      }

      handleMedicalConditions(e) {
        const isExclusive = e.target.hasAttribute('data-exclusive');
        const showsOther = e.target.hasAttribute('data-show-other');
        const otherField = this.querySelector('[data-other-field]');

        if (isExclusive && e.target.checked) {
          this.querySelectorAll('[data-field="medical_conditions"]').forEach(cb => {
            if (cb !== e.target) {
              cb.checked = false;
              cb.closest('.ai-eligibility-form__checkbox-option-{{ ai_gen_id }}').classList.remove('selected');
            }
          });
          if (otherField) otherField.style.display = 'none';
        } else if (e.target.checked) {
          const exclusiveCheckbox = this.querySelector('[data-field="medical_conditions"][data-exclusive]');
          if (exclusiveCheckbox) {
            exclusiveCheckbox.checked = false;
            exclusiveCheckbox.closest('.ai-eligibility-form__checkbox-option-{{ ai_gen_id }}').classList.remove('selected');
          }
        }

        if (showsOther && otherField) {
          otherField.style.display = e.target.checked ? 'block' : 'none';
          if (!e.target.checked) {
            otherField.querySelector('input').value = '';
          }
        }
      }

      goToStep(stepNumber) {
        this.querySelectorAll('[data-step]').forEach(step => {
          step.classList.remove('active');
        });

        const targetStep = this.querySelector(`[data-step="${stepNumber}"]`);
        if (targetStep) {
          targetStep.classList.add('active');
          this.currentStep = stepNumber;
          this.updateProgress();
          this.updateNavigationButtons();
        }
      }

      previousStep() {
        if (this.currentStep === 1) {
          this.currentStep = 'auth';
          this.goToStep('auth');
        } else if (typeof this.currentStep === 'number' && this.currentStep > 1) {
          this.goToStep(this.currentStep - 1);
        }
      }

      nextStep() {
        if (this.currentStep === 'auth') {
          if (this.isCustomer && this.sameAnswersCheckbox && this.sameAnswersCheckbox.checked) {
            this.submitForm(true);
          } else {
            this.goToStep(1);
          }
          return;
        }

        if (!this.validateCurrentStep()) {
          return;
        }

        this.collectStepData();

        if (this.currentStep < this.totalSteps) {
          this.goToStep(this.currentStep + 1);
        } else {
          this.submitForm();
        }
      }

      validateCurrentStep() {
        const currentStepElement = this.querySelector(`[data-step="${this.currentStep}"]`);
        if (!currentStepElement) return true;

        let isValid = true;

        currentStepElement.querySelectorAll('[data-error]').forEach(error => {
          error.classList.remove('visible');
        });

        const requiredInputs = currentStepElement.querySelectorAll('input[required]:not([type="radio"]):not([type="checkbox"])');
        requiredInputs.forEach(input => {
          if (!input.value.trim()) {
            const errorElement = currentStepElement.querySelector(`[data-error="${input.dataset.field}"]`);
            if (errorElement) errorElement.classList.add('visible');
            isValid = false;
          }
        });

        const radioGroups = {};
        currentStepElement.querySelectorAll('input[type="radio"][required]').forEach(radio => {
          if (!radioGroups[radio.name]) {
            radioGroups[radio.name] = [];
          }
          radioGroups[radio.name].push(radio);
        });

        Object.keys(radioGroups).forEach(groupName => {
          const isChecked = radioGroups[groupName].some(radio => radio.checked);
          if (!isChecked) {
            const fieldName = radioGroups[groupName][0].dataset.field;
            const errorElement = currentStepElement.querySelector(`[data-error="${fieldName}"]`);
            if (errorElement) errorElement.classList.add('visible');
            isValid = false;
          }
        });

        const checkboxGroups = {};
        currentStepElement.querySelectorAll('input[type="checkbox"][data-field]:not([data-field="consent"])').forEach(checkbox => {
          const fieldName = checkbox.dataset.field;
          if (!checkboxGroups[fieldName]) {
            checkboxGroups[fieldName] = [];
          }
          checkboxGroups[fieldName].push(checkbox);
        });

        Object.keys(checkboxGroups).forEach(fieldName => {
          const isChecked = checkboxGroups[fieldName].some(cb => cb.checked);
          if (!isChecked && checkboxGroups[fieldName].length > 0) {
            const errorElement = currentStepElement.querySelector(`[data-error="${fieldName}"]`);
            if (errorElement) errorElement.classList.add('visible');
            isValid = false;
          }
        });

        const consentCheckbox = currentStepElement.querySelector('[data-field="consent"]');
        if (consentCheckbox && !consentCheckbox.checked) {
          const errorElement = currentStepElement.querySelector('[data-error="consent"]');
          if (errorElement) errorElement.classList.add('visible');
          isValid = false;
        }

        const otherCheckbox = currentStepElement.querySelector('[data-show-other]');
        if (otherCheckbox && otherCheckbox.checked) {
          const otherInput = currentStepElement.querySelector('[data-field="medical_conditions_other"]');
          if (otherInput && !otherInput.value.trim()) {
            const errorElement = currentStepElement.querySelector('[data-error="medical_conditions_other"]');
            if (errorElement) errorElement.classList.add('visible');
            isValid = false;
          }
        }

        return isValid;
      }

      collectStepData() {
        const currentStepElement = this.querySelector(`[data-step="${this.currentStep}"]`);
        if (!currentStepElement) return;

        currentStepElement.querySelectorAll('[data-field]').forEach(field => {
          const fieldName = field.dataset.field;

          if (field.type === 'radio') {
            if (field.checked) {
              this.formData[fieldName] = field.value;
            }
          } else if (field.type === 'checkbox') {
            if (fieldName === 'consent') {
              this.formData[fieldName] = field.checked;
            } else {
              if (!this.formData[fieldName]) {
                this.formData[fieldName] = [];
              }
              if (field.checked) {
                this.formData[fieldName].push(field.value);
              }
            }
          } else {
            this.formData[fieldName] = field.value;
          }
        });
      }

      checkEligibility() {
        const healthStatus = this.formData.health_status;
        const medicalConditions = this.formData.medical_conditions;
        const pregnancy = this.formData.pregnancy;
        const seriousReaction = this.formData.serious_reaction;

        const isEligible = 
          (healthStatus === 'Great' || healthStatus === 'Generally Okay') &&
          (Array.isArray(medicalConditions) && medicalConditions.length === 1 && medicalConditions[0] === 'None') &&
          pregnancy === 'No' &&
          seriousReaction === 'No';

        return isEligible;
      }

      async submitForm(skipToResult = false) {
        if (!skipToResult) {
          this.collectStepData();
        }

        const isEligible = skipToResult ? true : this.checkEligibility();
        this.formData.eligible = isEligible;
        this.formData.timestamp = new Date().toISOString();
        this.formData.form_id = this.dataset.formId;

        {% if customer %}
          this.formData.customer_id = {{ customer.id | json }};
          this.formData.customer_email = {{ customer.email | json }};
        {% endif %}

        console.log('Form submission data:', this.formData);

        this.navigation.style.display = 'none';

        const resultElement = this.querySelector(`[data-result="${isEligible ? 'eligible' : 'ineligible'}"]`);
        if (resultElement) {
          resultElement.classList.add('active');
        }
      }

      updateProgress() {
        let stepNumber = 0;
        if (this.currentStep === 'auth') {
          stepNumber = 0;
        } else {
          stepNumber = this.currentStep;
        }

        const progress = (stepNumber / this.totalSteps) * 100;
        if (this.progressFill) {
          this.progressFill.style.width = progress + '%';
        }

        if (this.progressText) {
          if (this.currentStep === 'auth') {
            this.progressText.textContent = 'Getting started';
          } else {
            this.progressText.textContent = `Step ${stepNumber} of ${this.totalSteps}`;
          }
        }
      }

      updateNavigationButtons() {
        if (this.currentStep === 'auth') {
          this.navigation.style.display = 'none';
        } else {
          this.navigation.style.display = 'flex';
          this.prevButton.disabled = false;

          if (this.currentStep === this.totalSteps) {
            this.nextButton.textContent = '{{ block.settings.submit_button_text }}';
          } else {
            this.nextButton.textContent = '{{ block.settings.next_button_text }}';
          }
        }
      }
    }

    customElements.define('eligibility-form-{{ ai_gen_id }}', EligibilityForm{{ ai_gen_id }});
  })();
</script>

