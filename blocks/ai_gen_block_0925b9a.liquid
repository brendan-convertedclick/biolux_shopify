    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: 40px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .ai-eligibility-form__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .ai-eligibility-form__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-eligibility-form__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0;
  }

  .ai-eligibility-form__progress-{{ ai_gen_id }} {
    margin-bottom: 32px;
  }

  .ai-eligibility-form__progress-bar-{{ ai_gen_id }} {
    width: 100%;
    height: 8px;
    background-color: {{ block.settings.progress_bg_color }};
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 8px;
  }

  .ai-eligibility-form__progress-fill-{{ ai_gen_id }} {
    height: 100%;
    background-color: {{ block.settings.progress_color }};
    transition: width 0.3s ease;
    border-radius: 4px;
  }

  .ai-eligibility-form__progress-text-{{ ai_gen_id }} {
    text-align: center;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
  }

  .ai-eligibility-form__auth-step-{{ ai_gen_id }} {
    display: none;
    text-align: center;
  }

  .ai-eligibility-form__auth-step-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-eligibility-form__auth-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 400px;
    margin: 24px auto;
  }

  .ai-eligibility-form__auth-button-{{ ai_gen_id }} {
    padding: 16px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    display: block;
    text-align: center;
    transition: background-color 0.3s ease;
  }

  .ai-eligibility-form__auth-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-eligibility-form__auth-button--secondary-{{ ai_gen_id }} {
    background-color: transparent;
    color: {{ block.settings.button_color }};
    border: 2px solid {{ block.settings.button_color }};
  }

  .ai-eligibility-form__auth-button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
  }

  .ai-eligibility-form__checkbox-wrapper-{{ ai_gen_id }} {
    margin-top: 24px;
    padding: 16px;
    background-color: {{ block.settings.field_bg_color }};
    border-radius: 8px;
  }

  .ai-eligibility-form__checkbox-label-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    font-size: 15px;
    color: {{ block.settings.text_color }};
  }

  .ai-eligibility-form__checkbox-label-{{ ai_gen_id }} input[type="checkbox"] {
    width: 20px;
    height: 20px;
    cursor: pointer;
  }

  .ai-eligibility-form__step-{{ ai_gen_id }} {
    display: none;
  }

  .ai-eligibility-form__step-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-eligibility-form__field-group-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-eligibility-form__label-{{ ai_gen_id }} {
    display: block;
    font-size: 15px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin-bottom: 8px;
  }

  .ai-eligibility-form__required-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-left: 4px;
  }

  .ai-eligibility-form__input-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 15px;
    background-color: {{ block.settings.field_bg_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-eligibility-form__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.button_color }};
  }

  .ai-eligibility-form__radio-group-{{ ai_gen_id }},
  .ai-eligibility-form__checkbox-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-eligibility-form__radio-option-{{ ai_gen_id }},
  .ai-eligibility-form__checkbox-option-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    background-color: {{ block.settings.field_bg_color }};
    border: 2px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .ai-eligibility-form__radio-option-{{ ai_gen_id }}:hover,
  .ai-eligibility-form__checkbox-option-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.button_color }};
  }

  .ai-eligibility-form__radio-option-{{ ai_gen_id }}.selected,
  .ai-eligibility-form__checkbox-option-{{ ai_gen_id }}.selected {
    border-color: {{ block.settings.button_color }};
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
  }

  .ai-eligibility-form__radio-option-{{ ai_gen_id }} input[type="radio"],
  .ai-eligibility-form__checkbox-option-{{ ai_gen_id }} input[type="checkbox"] {
    margin-right: 12px;
    width: 18px;
    height: 18px;
    cursor: pointer;
  }

  .ai-eligibility-form__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    font-size: 13px;
    margin-top: 4px;
    display: none;
  }

  .ai-eligibility-form__error-{{ ai_gen_id }}.visible {
    display: block;
  }

  .ai-eligibility-form__navigation-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    margin-top: 32px;
  }

  .ai-eligibility-form__nav-button-{{ ai_gen_id }} {
    flex: 1;
    padding: 14px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-eligibility-form__nav-button-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-eligibility-form__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-eligibility-form__nav-button--secondary-{{ ai_gen_id }} {
    background-color: transparent;
    color: {{ block.settings.button_color }};
    border: 2px solid {{ block.settings.button_color }};
  }

  .ai-eligibility-form__nav-button--secondary-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
  }

  .ai-eligibility-form__result-{{ ai_gen_id }} {
    display: none;
    text-align: center;
    padding: 32px;
  }

  .ai-eligibility-form__result-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-eligibility-form__result-icon-{{ ai_gen_id }} {
    width: 64px;
    height: 64px;
    margin: 0 auto 16px;
  }

  .ai-eligibility-form__result-title-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
  }

  .ai-eligibility-form__result-message-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin-bottom: 24px;
  }

  .ai-eligibility-form__checkout-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 48px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 18px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.3s ease;
  }

  .ai-eligibility-form__checkout-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-eligibility-form__disclaimer-{{ ai_gen_id }} {
    background-color: #fff3cd;
    border: 1px solid #ffc107;
    border-radius: 8px;
    padding: 16px;
    margin-top: 16px;
    color: #856404;
    font-size: 14px;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-eligibility-form-{{ ai_gen_id }} {
      padding: 24px;
      width: 100%;
    }

    .ai-eligibility-form__navigation-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<eligibility-form-{{ ai_gen_id }}
  class="ai-eligibility-form-{{ ai_gen_id }}"
  data-form-id="882437"
  {{ block.shopify_attributes }}
>
  <div class="ai-eligibility-form__header-{{ ai_gen_id }}">
    <h2 class="ai-eligibility-form__title-{{ ai_gen_id }}">{{ block.settings.form_title }}</h2>
    <p class="ai-eligibility-form__subtitle-{{ ai_gen_id }}">{{ block.settings.form_subtitle }}</p>
  </div>

  <div class="ai-eligibility-form__progress-{{ ai_gen_id }}">
    <div class="ai-eligibility-form__progress-bar-{{ ai_gen_id }}">
      <div class="ai-eligibility-form__progress-fill-{{ ai_gen_id }}" data-progress-fill></div>
    </div>
    <div class="ai-eligibility-form__progress-text-{{ ai_gen_id }}" data-progress-text>Step 1 of 9</div>
  </div>

  <div class="ai-eligibility-form__auth-step-{{ ai_gen_id }} active" data-step="auth">
    <p style="font-size: 16px; margin-bottom: 24px; color: {{ block.settings.text_color }};">
      {{ block.settings.auth_message }}
    </p>
    <div class="ai-eligibility-form__auth-buttons-{{ ai_gen_id }}">
      <a href="/account/login" class="ai-eligibility-form__auth-button-{{ ai_gen_id }}">
        {{ block.settings.sign_in_text }}
      </a>
      <button
        type="button"
        class="ai-eligibility-form__auth-button-{{ ai_gen_id }} ai-eligibility-form__auth-button--secondary-{{ ai_gen_id }}"
        data-guest-continue
      >
        {{ block.settings.guest_text }}
      </button>
    </div>
    {% if customer %}
      <div class="ai-eligibility-form__checkbox-wrapper-{{ ai_gen_id }}">
        <label class="ai-eligibility-form__checkbox-label-{{ ai_gen_id }}">
          <input type="checkbox" checked data-same-answers>
          <span>{{ block.settings.same_answers_text }}</span>
        </label>
      </div>
    {% endif %}
  </div>

  <div class="ai-eligibility-form__step-{{ ai_gen_id }}" data-step="1">
    <div class="ai-eligibility-form__field-group-{{ ai_gen_id }}">
      <label class="ai-eligibility-form__label-{{ ai_gen_id }}">
        {{ block.settings.q1_full_name }}
        <span class="ai-eligibility-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <input
        type="text"
        class="ai-eligibility-form__input-{{ ai_gen_id }}"
        data-field="full_name"
        required
      >
      <div class="ai-eligibility-form__error-{{ ai_gen_id }}" data-error="full_name">This field is required</div>
    </div>

    <div class="ai-eligibility-form__field-group-{{ ai_gen_id }}">
      <label class="ai-eligibility-form__label-{{ ai_gen_id }}">
        {{ block.settings.q1_dob }}
        <span class="ai-eligibility-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <input
        type="date"
        class="ai-eligibility-form__input-{{ ai_gen_id }}"
        data-field="dob"
        required
      >
      <div class="ai-eligibility-form__error-{{ ai_gen_id }}" data-error="dob">This field is required</div>
    </div>

    <div class="ai-eligibility-form__field-group-{{ ai_gen_id }}">
      <label class="ai-eligibility-form__label-{{ ai_gen_id }}">
        {{ block.settings.q1_id_passport }}
        <span class="ai-eligibility-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <input
        type="text"
        class="ai-eligibility-form__input-{{ ai_gen_id }}"
        data-field="id_passport"
        required
      >
      <div class="ai-eligibility-form__error-{{ ai_gen_id }}" data-error="id_passport">This field is required</div>
    </div>
  </div>

  <div class="ai-eligibility-form__step-{{ ai_gen_id }}" data-step="2">
    <div class="ai-eligibility-form__field-group-{{ ai_gen_id }}">
      <label class="ai-eligibility-form__label-{{ ai_gen_id }}">
        {{ block.settings.q2_health_status }}
        <span class="ai-eligibility-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <div class="ai-eligibility-form__radio-group-{{ ai_gen_id }}">
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="health_status" value="Great" data-field="health_status" required>
          <span>{{ block.settings.q2_option_1 }}</span>
        </label>
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="health_status" value="Generally Okay" data-field="health_status">
          <span>{{ block.settings.q2_option_2 }}</span>
        </label>
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="health_status" value="Not good" data-field="health_status">
          <span>{{ block.settings.q2_option_3 }}</span>
        </label>
      </div>
      <div class="ai-eligibility-form__error-{{ ai_gen_id }}" data-error="health_status">Please select an option</div>
    </div>
  </div>

  <div class="ai-eligibility-form__step-{{ ai_gen_id }}" data-step="3">
    <div class="ai-eligibility-form__field-group-{{ ai_gen_id }}">
      <label class="ai-eligibility-form__label-{{ ai_gen_id }}">
        {{ block.settings.q3_medical_conditions }}
        <span class="ai-eligibility-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <div class="ai-eligibility-form__checkbox-group-{{ ai_gen_id }}">
        <label class="ai-eligibility-form__checkbox-option-{{ ai_gen_id }}">
          <input type="checkbox" value="None" data-field="medical_conditions" data-exclusive>
          <span>{{ block.settings.q3_option_1 }}</span>
        </label>
        <label class="ai-eligibility-form__checkbox-option-{{ ai_gen_id }}">
          <input type="checkbox" value="Heart Disease" data-field="medical_conditions">
          <span>{{ block.settings.q3_option_2 }}</span>
        </label>
        <label class="ai-eligibility-form__checkbox-option-{{ ai_gen_id }}">
          <input type="checkbox" value="Diabetes" data-field="medical_conditions">
          <span>{{ block.settings.q3_option_3 }}</span>
        </label>
        <label class="ai-eligibility-form__checkbox-option-{{ ai_gen_id }}">
          <input type="checkbox" value="Hypertension" data-field="medical_conditions">
          <span>{{ block.settings.q3_option_4 }}</span>
        </label>
        <label class="ai-eligibility-form__checkbox-option-{{ ai_gen_id }}">
          <input type="checkbox" value="Other" data-field="medical_conditions" data-show-other>
          <span>{{ block.settings.q3_option_5 }}</span>
        </label>
      </div>
      <div class="ai-eligibility-form__error-{{ ai_gen_id }}" data-error="medical_conditions">Please select at least one option</div>
    </div>
    <div class="ai-eligibility-form__field-group-{{ ai_gen_id }}" data-other-field style="display: none;">
      <label class="ai-eligibility-form__label-{{ ai_gen_id }}">
        {{ block.settings.q3_other_label }}
        <span class="ai-eligibility-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <input
        type="text"
        class="ai-eligibility-form__input-{{ ai_gen_id }}"
        data-field="medical_conditions_other"
      >
      <div class="ai-eligibility-form__error-{{ ai_gen_id }}" data-error="medical_conditions_other">Please specify</div>
    </div>
  </div>

  <div class="ai-eligibility-form__step-{{ ai_gen_id }}" data-step="4">
    <div class="ai-eligibility-form__field-group-{{ ai_gen_id }}">
      <label class="ai-eligibility-form__label-{{ ai_gen_id }}">
        {{ block.settings.q4_medications }}
      </label>
      <input
        type="text"
        class="ai-eligibility-form__input-{{ ai_gen_id }}"
        data-field="medications_allergies"
        placeholder="{{ block.settings.q4_placeholder }}"
      >
    </div>
  </div>

  <div class="ai-eligibility-form__step-{{ ai_gen_id }}" data-step="5">
    <div class="ai-eligibility-form__field-group-{{ ai_gen_id }}">
      <label class="ai-eligibility-form__label-{{ ai_gen_id }}">
        {{ block.settings.q5_main_goal }}
        <span class="ai-eligibility-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <div class="ai-eligibility-form__radio-group-{{ ai_gen_id }}">
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="main_goal" value="Weight" data-field="main_goal" required>
          <span>{{ block.settings.q5_option_1 }}</span>
        </label>
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="main_goal" value="Anti-aging" data-field="main_goal">
          <span>{{ block.settings.q5_option_2 }}</span>
        </label>
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="main_goal" value="Gut" data-field="main_goal">
          <span>{{ block.settings.q5_option_3 }}</span>
        </label>
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="main_goal" value="Energy" data-field="main_goal">
          <span>{{ block.settings.q5_option_4 }}</span>
        </label>
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="main_goal" value="Injury" data-field="main_goal">
          <span>{{ block.settings.q5_option_5 }}</span>
        </label>
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="main_goal" value="Immune" data-field="main_goal">
          <span>{{ block.settings.q5_option_6 }}</span>
        </label>
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="main_goal" value="Other" data-field="main_goal">
          <span>{{ block.settings.q5_option_7 }}</span>
        </label>
      </div>
      <div class="ai-eligibility-form__error-{{ ai_gen_id }}" data-error="main_goal">Please select an option</div>
    </div>
  </div>

  <div class="ai-eligibility-form__step-{{ ai_gen_id }}" data-step="6">
    <div class="ai-eligibility-form__field-group-{{ ai_gen_id }}">
      <label class="ai-eligibility-form__label-{{ ai_gen_id }}">
        {{ block.settings.q6_pregnancy }}
        <span class="ai-eligibility-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <div class="ai-eligibility-form__radio-group-{{ ai_gen_id }}">
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="pregnancy" value="Yes" data-field="pregnancy" required>
          <span>{{ block.settings.q6_option_1 }}</span>
        </label>
        <label class="ai-eligibility-form__radio-option-{{ ai_gen_id }}">
          <input type="radio" name="pregnancy" value="No" data-field="pregnancy">
          <span>{{ block.settings.q6_option_2 }}</span>
        </label>
      </div>
      <div class="ai-eligibility-form__error-{{ ai_gen_id }}" data-error="pregnancy">Please select an option</div>
    </div>
