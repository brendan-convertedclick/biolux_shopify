{% doc %}
  @prompt
    A toggle button that asks the user if the provided information is still the same. Below the toggle, there will be 22 buttons: one that says "Proceed to Checkout" if the toggle button is "Yes," and another that says "Update Medical Check."
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-info-toggle-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-info-toggle-question-{{ ai_gen_id }} {
    font-size: {{ block.settings.question_font_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing_below_question }}px;
    font-weight: 600;
  }

  .ai-info-toggle-switch-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: {{ block.settings.spacing_below_toggle }}px;
  }

  .ai-info-toggle-switch-{{ ai_gen_id }} {
    position: relative;
    display: inline-block;
    width: {{ block.settings.toggle_width }}px;
    height: {{ block.settings.toggle_height }}px;
  }

  .ai-info-toggle-switch-{{ ai_gen_id }} input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .ai-info-toggle-slider-{{ ai_gen_id }} {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: {{ block.settings.toggle_off_color }};
    transition: 0.3s;
    border-radius: {{ block.settings.toggle_height }}px;
  }

  .ai-info-toggle-slider-{{ ai_gen_id }}:before {
    position: absolute;
    content: "";
    height: calc({{ block.settings.toggle_height }}px - 8px);
    width: calc({{ block.settings.toggle_height }}px - 8px);
    left: 4px;
    bottom: 4px;
    background-color: white;
    transition: 0.3s;
    border-radius: 50%;
  }

  .ai-info-toggle-switch-{{ ai_gen_id }} input:checked + .ai-info-toggle-slider-{{ ai_gen_id }} {
    background-color: {{ block.settings.toggle_on_color }};
  }

  .ai-info-toggle-switch-{{ ai_gen_id }} input:checked + .ai-info-toggle-slider-{{ ai_gen_id }}:before {
    transform: translateX(calc({{ block.settings.toggle_width }}px - {{ block.settings.toggle_height }}px));
  }

  .ai-info-toggle-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-info-toggle-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .ai-info-toggle-button-{{ ai_gen_id }} {
    flex: 1;
    min-width: 200px;
    padding: {{ block.settings.button_padding }}px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ai-info-toggle-button-{{ ai_gen_id }}--proceed {
    background-color: {{ block.settings.proceed_button_color }};
    color: {{ block.settings.proceed_button_text_color }};
  }

  .ai-info-toggle-button-{{ ai_gen_id }}--proceed:hover {
    background-color: {{ block.settings.proceed_button_hover_color }};
  }

  .ai-info-toggle-button-{{ ai_gen_id }}--update {
    background-color: {{ block.settings.update_button_color }};
    color: {{ block.settings.update_button_text_color }};
  }

  .ai-info-toggle-button-{{ ai_gen_id }}--update:hover {
    background-color: {{ block.settings.update_button_hover_color }};
  }

  .ai-info-toggle-button-{{ ai_gen_id }}.hidden {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-info-toggle-buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-info-toggle-button-{{ ai_gen_id }} {
      min-width: 100%;
    }
  }
{% endstyle %}

<info-toggle-{{ ai_gen_id }} class="ai-info-toggle-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <h3 class="ai-info-toggle-question-{{ ai_gen_id }}">{{ block.settings.question_text }}</h3>

  <div class="ai-info-toggle-switch-wrapper-{{ ai_gen_id }}">
    <label class="ai-info-toggle-switch-{{ ai_gen_id }}">
      <input type="checkbox" id="info-toggle-{{ ai_gen_id }}" checked>
      <span class="ai-info-toggle-slider-{{ ai_gen_id }}"></span>
    </label>
    <span class="ai-info-toggle-label-{{ ai_gen_id }}" id="toggle-label-{{ ai_gen_id }}">{{ block.settings.yes_label }}</span>
  </div>

  <div class="ai-info-toggle-buttons-{{ ai_gen_id }}">
    <a
      href="{{ block.settings.proceed_link }}"
      class="ai-info-toggle-button-{{ ai_gen_id }} ai-info-toggle-button-{{ ai_gen_id }}--proceed"
      id="proceed-button-{{ ai_gen_id }}"
    >
      {{ block.settings.proceed_button_text }}
    </a>
    <a
      href="{{ block.settings.update_link }}"
      class="ai-info-toggle-button-{{ ai_gen_id }} ai-info-toggle-button-{{ ai_gen_id }}--update hidden"
      id="update-button-{{ ai_gen_id }}"
    >
      {{ block.settings.update_button_text }}
    </a>
  </div>
</info-toggle-{{ ai_gen_id }}>

<script>
  (function() {
    class InfoToggle{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.toggle = this.querySelector('#info-toggle-{{ ai_gen_id }}');
        this.label = this.querySelector('#toggle-label-{{ ai_gen_id }}');
        this.proceedButton = this.querySelector('#proceed-button-{{ ai_gen_id }}');
        this.updateButton = this.querySelector('#update-button-{{ ai_gen_id }}');

        this.yesLabel = '{{ block.settings.yes_label }}';
        this.noLabel = '{{ block.settings.no_label }}';

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.toggle.addEventListener('change', () => {
          this.handleToggleChange();
        });
      }

      handleToggleChange() {
        if (this.toggle.checked) {
          this.label.textContent = this.yesLabel;
          this.proceedButton.classList.remove('hidden');
          this.updateButton.classList.add('hidden');
        } else {
          this.label.textContent = this.noLabel;
          this.proceedButton.classList.add('hidden');
          this.updateButton.classList.remove('hidden');
        }
      }
    }

    customElements.define('info-toggle-{{ ai_gen_id }}', InfoToggle{{ ai_gen_id }});
  })();
</script>

