{% doc %}
  @prompt
    A testimonial section that shows a carousel of reviews on at a time allow up to 6 reviews standard image for all , allow dynamic source for the text part and control layout, whether image is at top or bottom, Quote to accept dynamic source and remove rating, allow font selection on the name.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-carousel-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-testimonial-carousel__container-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
    overflow: hidden;
  }

  .ai-testimonial-carousel__track-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-testimonial-carousel__slide-{{ ai_gen_id }} {
    display: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .ai-testimonial-carousel__slide-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
  }

  .ai-testimonial-carousel__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout }};
    align-items: center;
    gap: {{ block.settings.content_gap }}px;
    text-align: center;
  }

  .ai-testimonial-carousel__image-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
  }

  .ai-testimonial-carousel__image-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-testimonial-carousel__image-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-carousel__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-testimonial-carousel__text-content-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-testimonial-carousel__quote-{{ ai_gen_id }} {
    color: {{ block.settings.quote_color }};
    font-size: {{ block.settings.quote_size }}px;
    line-height: 1.5;
    margin: 0 0 {{ block.settings.quote_margin }}px;
  }

  .ai-testimonial-carousel__name-{{ ai_gen_id }} {
    color: {{ block.settings.name_color }};
    font-size: {{ block.settings.name_size }}px;
    font-family: {{ block.settings.name_font.family }}, {{ block.settings.name_font.fallback_families }};
    font-weight: {{ block.settings.name_font.weight }};
    font-style: {{ block.settings.name_font.style }};
    margin: 0;
  }

  .ai-testimonial-carousel__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: {{ block.settings.controls_margin }}px;
  }

  .ai-testimonial-carousel__button-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_icon_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-testimonial-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-testimonial-carousel__button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-testimonial-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-testimonial-carousel__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease;
  }

  .ai-testimonial-carousel__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-carousel__content-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<testimonial-carousel-{{ ai_gen_id }}
  class="ai-testimonial-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonial-carousel__container-{{ ai_gen_id }}">
    <div class="ai-testimonial-carousel__track-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign quote_key = 'review_' | append: i | append: '_quote'
          assign name_key = 'review_' | append: i | append: '_name'
          assign quote = block.settings[quote_key]
          assign name = block.settings[name_key]
        %}

        {% if quote != blank or name != blank %}
          <div
            class="ai-testimonial-carousel__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-slide="{{ forloop.index0 }}"
          >
            <div class="ai-testimonial-carousel__content-{{ ai_gen_id }}">
              <div class="ai-testimonial-carousel__image-wrapper-{{ ai_gen_id }}">
                {% if block.settings.testimonial_image %}
                  <img
                    src="{{ block.settings.testimonial_image | image_url: width: 400 }}"
                    alt="{{ name | escape }}"
                    class="ai-testimonial-carousel__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="{{ block.settings.image_size }}"
                    height="{{ block.settings.image_size }}"
                  >
                {% else %}
                  <div class="ai-testimonial-carousel__image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-testimonial-carousel__text-content-{{ ai_gen_id }}">
                {% if quote != blank %}
                  <div class="ai-testimonial-carousel__quote-{{ ai_gen_id }}">
                    {{ quote }}
                  </div>
                {% endif %}

                {% if name != blank %}
                  <p class="ai-testimonial-carousel__name-{{ ai_gen_id }}">{{ name }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-testimonial-carousel__controls-{{ ai_gen_id }}">
      <button
        class="ai-testimonial-carousel__button-{{ ai_gen_id }} ai-testimonial-carousel__prev-{{ ai_gen_id }}"
        aria-label="Previous testimonial"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-testimonial-carousel__dots-{{ ai_gen_id }}"></div>

      <button
        class="ai-testimonial-carousel__button-{{ ai_gen_id }} ai-testimonial-carousel__next-{{ ai_gen_id }}"
        aria-label="Next testimonial"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>
</testimonial-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = this.querySelectorAll('.ai-testimonial-carousel__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-testimonial-carousel__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-testimonial-carousel__next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-testimonial-carousel__dots-{{ ai_gen_id }}');

        if (this.slides.length === 0) return;

        this.createDots();
        this.setupEventListeners();
        this.startAutoplay();
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }

      createDots() {
        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-testimonial-carousel__dot-{{ ai_gen_id }}');
          if (index === 0) dot.classList.add('active');
          dot.setAttribute('aria-label', `Go to testimonial ${index + 1}`);
          dot.addEventListener('click', () => this.goToSlide(index));
          this.dotsContainer.appendChild(dot);
        });
        this.dots = this.querySelectorAll('.ai-testimonial-carousel__dot-{{ ai_gen_id }}');
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => {
          this.stopAutoplay();
          this.previousSlide();
          this.startAutoplay();
        });

        this.nextButton.addEventListener('click', () => {
          this.stopAutoplay();
          this.nextSlide();
          this.startAutoplay();
        });
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        this.dots[this.currentSlide].classList.remove('active');

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        this.dots[this.currentSlide].classList.add('active');
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        const autoplayEnabled = {{ block.settings.enable_autoplay | json }};
        const autoplaySpeed = {{ block.settings.autoplay_speed | times: 1000 }};

        if (autoplayEnabled && this.slides.length > 1) {
          this.autoplayInterval = setInterval(() => {
            this.nextSlide();
          }, autoplaySpeed);
        }
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }
    }

    customElements.define('testimonial-carousel-{{ ai_gen_id }}', TestimonialCarousel{{ ai_gen_id }});
  })();
</script>

