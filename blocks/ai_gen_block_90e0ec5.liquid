{% doc %}
  @prompt
    A toggle button that asks the user if the provided information is still the same. Below the toggle, there will be 2 buttons: one that says "Proceed to Checkout" if the toggle button is "Yes," and another that says "Update Medical Check." if customer is sign in if not show sign in and hide the toggle  and proceed to check out button, open sign in in new tap.  If customer already signed in hide sign in button, control section alignment. Add instruction above button that states user needs to sign in to be able to check out an d make sure that the Medical check form was submitted. check customer tags if there is red flag or green flag all to add ctom message for either. If there are no tags show message " Please submit the  medical check form.  According to the tags the red flag doesn't see proceed to check out button
    
    Instead of link for Update Medical Info please use this <div class="upform-container" style="display: none !important;" data-id="a6e76e"></div> or have a liquid block for me to add the code
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-medical-check-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    text-align: {{ block.settings.alignment }};
  }

  .ai-medical-check-container-{{ ai_gen_id }}--left {
    align-items: flex-start;
  }

  .ai-medical-check-container-{{ ai_gen_id }}--center {
    align-items: center;
  }

  .ai-medical-check-container-{{ ai_gen_id }}--right {
    align-items: flex-end;
  }

  .ai-medical-check-instruction-{{ ai_gen_id }} {
    color: {{ block.settings.instruction_color }};
    font-size: {{ block.settings.instruction_font_size }}px;
    margin: 0;
  }

  .ai-medical-check-message-{{ ai_gen_id }} {
    padding: 16px;
    border-radius: {{ block.settings.message_border_radius }}px;
    font-size: {{ block.settings.message_font_size }}px;
    margin: 0;
    width: 100%;
  }

  .ai-medical-check-message-{{ ai_gen_id }}--green {
    background-color: {{ block.settings.green_flag_bg }};
    color: {{ block.settings.green_flag_text }};
  }

  .ai-medical-check-message-{{ ai_gen_id }}--red {
    background-color: {{ block.settings.red_flag_bg }};
    color: {{ block.settings.red_flag_text }};
  }

  .ai-medical-check-message-{{ ai_gen_id }}--warning {
    background-color: {{ block.settings.warning_bg }};
    color: {{ block.settings.warning_text }};
  }

  .ai-medical-check-toggle-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
  }

  .ai-medical-check-toggle-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.toggle_label_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-medical-check-toggle-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
  }

  .ai-medical-check-toggle-buttons-{{ ai_gen_id }}--left {
    justify-content: flex-start;
  }

  .ai-medical-check-toggle-buttons-{{ ai_gen_id }}--center {
    justify-content: center;
  }

  .ai-medical-check-toggle-buttons-{{ ai_gen_id }}--right {
    justify-content: flex-end;
  }

  .ai-medical-check-toggle-btn-{{ ai_gen_id }} {
    padding: 12px 24px;
    border: 2px solid {{ block.settings.toggle_border_color }};
    background-color: {{ block.settings.toggle_bg_inactive }};
    color: {{ block.settings.toggle_text_inactive }};
    border-radius: {{ block.settings.toggle_border_radius }}px;
    cursor: pointer;
    font-size: {{ block.settings.toggle_font_size }}px;
    transition: all 0.3s ease;
  }

  .ai-medical-check-toggle-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.toggle_bg_hover }};
  }

  .ai-medical-check-toggle-btn-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.toggle_bg_active }};
    color: {{ block.settings.toggle_text_active }};
    border-color: {{ block.settings.toggle_bg_active }};
  }

  .ai-medical-check-actions-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
  }

  .ai-medical-check-button-{{ ai_gen_id }} {
    padding: 16px 32px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    transition: all 0.3s ease;
  }

  .ai-medical-check-button-{{ ai_gen_id }}--primary {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text }};
  }

  .ai-medical-check-button-{{ ai_gen_id }}--primary:hover {
    background-color: {{ block.settings.primary_button_hover }};
  }

  .ai-medical-check-button-{{ ai_gen_id }}--secondary {
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_text }};
  }

  .ai-medical-check-button-{{ ai_gen_id }}--secondary:hover {
    background-color: {{ block.settings.secondary_button_hover }};
  }

  .ai-medical-check-button-{{ ai_gen_id }}--signin {
    background-color: {{ block.settings.signin_button_bg }};
    color: {{ block.settings.signin_button_text }};
  }

  .ai-medical-check-button-{{ ai_gen_id }}--signin:hover {
    background-color: {{ block.settings.signin_button_hover }};
  }

  .ai-medical-check-hidden-{{ ai_gen_id }} {
    display: none !important;
  }

  .ai-medical-check-upform-{{ ai_gen_id }} {
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-medical-check-container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-medical-check-toggle-buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-medical-check-toggle-btn-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<medical-check-toggle-{{ ai_gen_id }}
  class="ai-medical-check-container-{{ ai_gen_id }} ai-medical-check-container-{{ ai_gen_id }}--{{ block.settings.alignment }}"
  {{ block.shopify_attributes }}
  data-customer-logged-in="{{ customer }}"
  data-customer-tags="{{ customer.tags | join: ',' }}"
>
  {% if customer %}
    {% assign has_green_flag = false %}
    {% assign has_red_flag = false %}
    
    {% for tag in customer.tags %}
      {% assign tag_lower = tag | downcase %}
      {% if tag_lower contains 'green' and tag_lower contains 'flag' %}
        {% assign has_green_flag = true %}
      {% endif %}
      {% if tag_lower contains 'red' and tag_lower contains 'flag' %}
        {% assign has_red_flag = true %}
      {% endif %}
    {% endfor %}

    {% if has_green_flag %}
      <div class="ai-medical-check-message-{{ ai_gen_id }} ai-medical-check-message-{{ ai_gen_id }}--green">
        {{ block.settings.green_flag_message }}
      </div>
    {% elsif has_red_flag %}
      <div class="ai-medical-check-message-{{ ai_gen_id }} ai-medical-check-message-{{ ai_gen_id }}--red">
        {{ block.settings.red_flag_message }}
      </div>
    {% else %}
      <div class="ai-medical-check-message-{{ ai_gen_id }} ai-medical-check-message-{{ ai_gen_id }}--warning">
        {{ block.settings.no_tag_message }}
      </div>
    {% endif %}

    {% if has_green_flag or has_red_flag %}
      <div class="ai-medical-check-toggle-{{ ai_gen_id }}">
        <p class="ai-medical-check-toggle-label-{{ ai_gen_id }}">{{ block.settings.toggle_question }}</p>
        <div class="ai-medical-check-toggle-buttons-{{ ai_gen_id }} ai-medical-check-toggle-buttons-{{ ai_gen_id }}--{{ block.settings.alignment }}">
          <button
            class="ai-medical-check-toggle-btn-{{ ai_gen_id }} ai-medical-check-toggle-yes-{{ ai_gen_id }} active"
            data-value="yes"
          >
            {{ block.settings.toggle_yes_text }}
          </button>
          <button
            class="ai-medical-check-toggle-btn-{{ ai_gen_id }} ai-medical-check-toggle-no-{{ ai_gen_id }}"
            data-value="no"
          >
            {{ block.settings.toggle_no_text }}
          </button>
        </div>
      </div>

      <div class="ai-medical-check-actions-{{ ai_gen_id }}">
        {% unless has_red_flag %}
          <a
            href="/checkout"
            class="ai-medical-check-button-{{ ai_gen_id }} ai-medical-check-button-{{ ai_gen_id }}--primary ai-medical-check-checkout-btn-{{ ai_gen_id }}"
          >
            {{ block.settings.checkout_button_text }}
          </a>
        {% endunless %}

        <div class="ai-medical-check-update-container-{{ ai_gen_id }} ai-medical-check-hidden-{{ ai_gen_id }}">
          {% if block.settings.upform_code != blank %}
            {{ block.settings.upform_code }}
          {% else %}
            <button
              class="ai-medical-check-button-{{ ai_gen_id }} ai-medical-check-button-{{ ai_gen_id }}--secondary"
            >
              {{ block.settings.update_button_text }}
            </button>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% else %}
    <div class="ai-medical-check-instruction-{{ ai_gen_id }}">
      {{ block.settings.signin_instruction }}
    </div>
    <a
      href="/account/login"
      target="_blank"
      class="ai-medical-check-button-{{ ai_gen_id }} ai-medical-check-button-{{ ai_gen_id }}--signin"
    >
      {{ block.settings.signin_button_text_label }}
    </a>
  {% endif %}
</medical-check-toggle-{{ ai_gen_id }}>

<script>
  (function() {
    class MedicalCheckToggle{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.isLoggedIn = this.dataset.customerLoggedIn !== '';
      }

      connectedCallback() {
        if (!this.isLoggedIn) return;

        this.yesButton = this.querySelector('.ai-medical-check-toggle-yes-{{ ai_gen_id }}');
        this.noButton = this.querySelector('.ai-medical-check-toggle-no-{{ ai_gen_id }}');
        this.checkoutButton = this.querySelector('.ai-medical-check-checkout-btn-{{ ai_gen_id }}');
        this.updateContainer = this.querySelector('.ai-medical-check-update-container-{{ ai_gen_id }}');

        if (this.yesButton && this.noButton) {
          this.setupToggle();
        }
      }

      setupToggle() {
        this.yesButton.addEventListener('click', () => this.handleToggle('yes'));
        this.noButton.addEventListener('click', () => this.handleToggle('no'));
      }

      handleToggle(value) {
        this.yesButton.classList.remove('active');
        this.noButton.classList.remove('active');

        if (value === 'yes') {
          this.yesButton.classList.add('active');
          if (this.checkoutButton) {
            this.checkoutButton.classList.remove('ai-medical-check-hidden-{{ ai_gen_id }}');
          }
          if (this.updateContainer) {
            this.updateContainer.classList.add('ai-medical-check-hidden-{{ ai_gen_id }}');
          }
        } else {
          this.noButton.classList.add('active');
          if (this.checkoutButton) {
            this.checkoutButton.classList.add('ai-medical-check-hidden-{{ ai_gen_id }}');
          }
          if (this.updateContainer) {
            this.updateContainer.classList.remove('ai-medical-check-hidden-{{ ai_gen_id }}');
          }
        }
      }
    }

    customElements.define('medical-check-toggle-{{ ai_gen_id }}', MedicalCheckToggle{{ ai_gen_id }});
  })();
</script>

