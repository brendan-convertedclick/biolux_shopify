{% doc %}
  @prompt
    Generate an icon text section show 4 on a row, allow background to be an image, allow custom icons, full width on border. The text should have header and content.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-text-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
  }

  .ai-icon-text-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-icon-text-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-icon-text-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-icon-text-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.1;
  }

  .ai-icon-text-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-icon-text-container-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    padding: {{ block.settings.section_padding_mobile }}px 20px;
  }

  @media screen and (min-width: 750px) {
    .ai-icon-text-container-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 40px;
    }
  }

  .ai-icon-text-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.gap_mobile }}px;
    max-width: 1400px;
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .ai-icon-text-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, 1fr);
      gap: {{ block.settings.gap_desktop }}px;
    }
  }

  .ai-icon-text-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-icon-text-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-icon-text-icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-icon-text-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-text-icon-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    color: {{ block.settings.icon_color }};
  }

  .ai-icon-text-content-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-icon-text-header-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size_mobile }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    text-transform: {{ block.settings.heading_transform }};
  }

  @media screen and (min-width: 750px) {
    .ai-icon-text-header-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_desktop }}px;
    }
  }

  .ai-icon-text-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.text_size_mobile }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (min-width: 750px) {
    .ai-icon-text-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_desktop }}px;
    }
  }

  .ai-icon-text-empty-state-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.text_color }};
    font-style: italic;
    opacity: 0.6;
  }
{% endstyle %}

<div class="ai-icon-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-text-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-icon-text-background-placeholder-{{ ai_gen_id }}" style="background-color: {{ block.settings.background_color }};">
      </div>
    {% endif %}
  </div>

  {% if block.settings.show_overlay %}
    <div class="ai-icon-text-overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-icon-text-container-{{ ai_gen_id }}">
    <div class="ai-icon-text-grid-{{ ai_gen_id }}">
      {% assign has_content = false %}
      {% for i in (1..4) %}
        {% liquid
          assign icon_key = 'icon_' | append: i
          assign header_key = 'header_' | append: i
          assign text_key = 'text_' | append: i

          assign icon = block.settings[icon_key]
          assign header = block.settings[header_key]
          assign text = block.settings[text_key]
        %}

        {% if header != blank or text != blank %}
          {% assign has_content = true %}
          <div class="ai-icon-text-item-{{ ai_gen_id }}">
            <div class="ai-icon-text-icon-wrapper-{{ ai_gen_id }}">
              {% if icon %}
                <img
                  src="{{ icon | image_url: width: 200 }}"
                  alt="{{ header | escape }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <div class="ai-icon-text-icon-placeholder-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M12 16v-4"></path>
                    <path d="M12 8h.01"></path>
                  </svg>
                </div>
              {% endif %}
            </div>

            <div class="ai-icon-text-content-{{ ai_gen_id }}">
              {% if header != blank %}
                <h3 class="ai-icon-text-header-{{ ai_gen_id }}">{{ header }}</h3>
              {% endif %}

              {% if text != blank %}
                <div class="ai-icon-text-text-{{ ai_gen_id }}">{{ text }}</div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {% unless has_content %}
        <div class="ai-icon-text-empty-state-{{ ai_gen_id }}">
          Add headers and text to display your icon features
        </div>
      {% endunless %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Icon text grid",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
