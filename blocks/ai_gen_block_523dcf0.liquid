        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Item style"
    },
    {
      "type": "range",
      "id": "item_padding",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Item padding",
      "default": 20
    },
    {
      "type": "color",
      "id": "item_background_color",
      "label": "Item background",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "range",
      "id": "item_border_radius",
