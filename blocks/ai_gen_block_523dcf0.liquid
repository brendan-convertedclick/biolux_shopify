      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Overlay opacity",
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_padding_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Section padding mobile",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Section padding desktop",
      "default": 60
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Gap mobile",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Gap desktop",
      "default": 30
    },
    {
      "type": "select",
      "id": "alignment",
