{% doc %}
  @prompt
    one column image no space in between the other column text, the colum for text, I want 2 columns one with image without space the other column for text. Allow heading font weight editand font selection
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-column-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-two-column-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    gap: 0;
    flex-direction: {{ block.settings.layout }};
  }

  .ai-two-column-image-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    width: {{ block.settings.image_width }}%;
  }

  .ai-two-column-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-two-column-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
  }

  .ai-two-column-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-two-column-text-{{ ai_gen_id }} {
    flex: 0 0 {{ 100 | minus: block.settings.image_width }}%;
    width: {{ 100 | minus: block.settings.image_width }}%;
    padding: {{ block.settings.text_padding }}px;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.vertical_alignment }};
    align-items: {{ block.settings.horizontal_alignment }};
    text-align: {{ block.settings.text_alignment }};
    background-color: {{ block.settings.text_background_color }};
  }

  .ai-two-column-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
  }

  .ai-two-column-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-two-column-content-{{ ai_gen_id }} p {
    margin: 0 0 16px 0;
  }

  .ai-two-column-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-two-column-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-two-column-image-{{ ai_gen_id }},
    .ai-two-column-text-{{ ai_gen_id }} {
      flex: 0 0 100%;
      width: 100%;
    }

    .ai-two-column-text-{{ ai_gen_id }} {
      padding: {{ block.settings.text_padding | times: 0.7 }}px;
    }

    .ai-two-column-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-two-column-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<two-column-block-{{ ai_gen_id }} class="ai-two-column-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-column-wrapper-{{ ai_gen_id }}">
    <div class="ai-two-column-image-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="ai-two-column-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-two-column-text-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-two-column-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-two-column-content-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}
    </div>
  </div>
</two-column-block-{{ ai_gen_id }}>

<script>
  (function() {
    class TwoColumnBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('two-column-block-{{ ai_gen_id }}', TwoColumnBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image and text columns",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        {
          "value": "row",
          "label": "Left"
        },
        {
          "value": "row-reverse",
          "label": "Right"
        }
      ],
      "default": "row"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image width",
      "min": 30,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Your heading here"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add your text content here. This column is perfect for detailed descriptions, product information, or any other content you want to highlight.</p>"
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#1c1c1c"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Spacing below",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Body text style"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color",
      "default": "#1c1c1c"
    },
    {
      "type": "header",
      "content": "Text column"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "Horizontal alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "text_padding",
      "label": "Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "text_background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Image and text columns"
    }
  ]
}
{% endschema %}
